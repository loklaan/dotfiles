direction: right

claude-code.shape: rectangle
claude-code.style.3d: true
claude-code: |md
  ## Claude Code

  Primary code agent for all repos.
|

rules: {
  label: Rules
  style.multiple: true

  prompt-output
  coding
}

skills: {
  label: Skills
  style.multiple: true
  grid-columns: 1

  env: {
    label: Environment
    coding
    architecture
    devil
  }

  coding-topic: {
    label: Coding
    effect-ts
    errors
    frontend-design
    shell
  }

  writing: {
    label: Writing
    writing
    prompts
    compress
  }

  agent: {
    label: Agent
    authoring
    costs
    extract
  }

  process: {
    label: Process
    pm
    tmux-panes
  }

  checkpoints: {
    label: Checkpoints
    challenge
    sweep
    patch
    handoff
  }
}

claude-code -> rules
claude-code -> skills

rules.coding -> skills.env.coding: {
  style.stroke-dash: 3
}
