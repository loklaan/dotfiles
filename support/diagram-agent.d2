direction: down

claude-code.shape: rectangle
claude-code.style.3d: true
claude-code: |md
  ## Claude Code

  Primary code agent for all repos.
|

rules: {
  label: Rules
  style.multiple: true

  coding-system-prompts
  prompt-output
}

skills: {
  label: Skills
  style.multiple: true
  grid-columns: 2

  coding: {
    label: Coding
    comments
    effect-ts
    errors
    negation
    shell
  }

  writing-group: {
    label: Writing
    writing
    prompts
    compress
  }

  pm: {
    label: Project Management
    organising-work
    self-interview
  }

  meta: {
    label: Meta
    architecture
    extensions
  }

  peon-ping: {
    label: Peon Ping
    label.near: top-center
    style.opacity: 0.7
    style.font-color: "#888888"

    subtitle: "(Homebrew)"
    subtitle.style.font-size: 13
    subtitle.style.font-color: "#888888"
    subtitle.shape: text
  }
}

claude-code -> rules
claude-code -> skills
