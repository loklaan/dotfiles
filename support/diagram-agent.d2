direction: right

claude-code.shape: rectangle
claude-code.style.3d: true
claude-code: |md
  ## Claude Code

  Primary code agent for all repos.
|

rules: {
  label: Rules
  style.multiple: true

  coding
  prompt-output
}

skills: {
  label: Skills
  style.multiple: true
  grid-columns: 2

  env: {
    label: Environment
    coding
    architecture
    devil
  }

  coding-topic: {
    label: Coding
    comments
    effect-ts
    errors
    shell
  }

  authoring: {
    label: Authoring
    writing
    prompts
    compress
    handoff
    pm
    agent-authoring
  }

  peon-ping: {
    label: Peon Ping
    label.near: top-center
    style.opacity: 0.7
    style.font-color: "#888888"

    subtitle: "(Vendored/External)"
    subtitle.style.font-size: 13
    subtitle.style.font-color: "#888888"
    subtitle.shape: text
  }
}

claude-code -> rules
claude-code -> skills
