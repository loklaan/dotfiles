{{- $lib := printf "%s/.local/lib/tmux-resurrect-code-agents" .chezmoi.homeDir -}}
{
  "Notification": [
    {
      "matcher": "permission_prompt",
      "hooks": [
        {
          "type": "command",
          "command": "notify 'Claude needs your permission'"
        }
      ]
    },
    {
      "matcher": "idle_prompt",
      "hooks": [
        {
          "type": "command",
          "command": "notify 'Claude is waiting for your input'"
        }
      ]
    },
    {
      "matcher": "auth_success",
      "hooks": [
        {
          "type": "command",
          "command": "notify 'Claude authentication successful'"
        }
      ]
    },
    {
      "matcher": "elicitation_dialog",
      "hooks": [
        {
          "type": "command",
          "command": "notify 'Claude needs more information'"
        }
      ]
    }
  ],
  "SessionStart": [
    {
      "matcher": "",
      "hooks": [
        {
          "type": "command",
          "command": "bash {{ $lib }}/track.sh claude"
        },
        {
          "type": "command",
          "command": "bash {{ $lib }}/sync-credentials.sh"
        }
      ]
    }
  ],
  "SessionEnd": [
    {
      "matcher": "",
      "hooks": [
        {
          "type": "command",
          "command": "bash {{ $lib }}/cleanup.sh"
        }
      ]
    }
  ]
}
