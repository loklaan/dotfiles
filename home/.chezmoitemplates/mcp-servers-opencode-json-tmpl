{
  {{ if ne "" .emailWork -}}
  "otter": {
    "type": "local",
    "enabled": true,
    "command": [ "otter", "mcp", "serve" ]
  },
  {{ end -}}
  "effect-docs": {
    "type": "local",
    "enabled": true,
    "command": ["npx", "-y", "effect-mcp@latest" ]
  },
  "pdf-tools": {
    "type": "local",
    "enabled": true,
    "command": ["uvx", "mcp-pdf"]
  },
  "figma-desktop": {
    "type": "remote",
    "enabled": true,
    "url": "http://127.0.0.1:3845/mcp"
  }
}
