{{- $omoVersion := output "mise" "current" "npm:oh-my-openagent" | trim -}}
{{- $llmproxyLocal := dig "openCodeWorkPluginLocalPath" "" . -}}
{{- $llmproxyVersion := "" -}}
{{- if eq "" $llmproxyLocal -}}
{{-   $llmproxyVersion = output "npm" "view" "@canva/opencode-plugin-llmproxy" "version" | trim -}}
{{- end -}}
{{- /* Semver validation (finding #4): reject non-empty versions that don't match strict semver.
     regexMatch is an unanchored search — the ^...$ anchors are the security boundary.
     A malformed non-empty version (e.g. "1.0.0$(id)") aborts the render loudly.
     An empty version soft-degrades: the sync line is skipped rather than emitting "pkg@". */ -}}
{{- $semverRe := `^[0-9]+\.[0-9]+\.[0-9]+(-[0-9A-Za-z-]+(\.[0-9A-Za-z-]+)*)?(\+[0-9A-Za-z-]+(\.[0-9A-Za-z-]+)*)?$` -}}
{{- if and (ne "" $omoVersion) (not (regexMatch $semverRe $omoVersion)) -}}
{{-   fail (printf "omo version %q is not valid semver — aborting render to prevent shell injection" $omoVersion) -}}
{{- end -}}
{{- if and (ne "" $llmproxyVersion) (not (regexMatch $semverRe $llmproxyVersion)) -}}
{{-   fail (printf "llmproxy version %q is not valid semver — aborting render to prevent shell injection" $llmproxyVersion) -}}
{{- end -}}
#!/usr/bin/env bash
set -euo pipefail

IFS=$'\n\t'

source "${HOME}/.local/lib/bash-logging.sh"
source "${HOME}/.local/lib/tool-cache-sync.sh"
setup_session_logging "$(basename "$0")"

# content-hash: {{ printf "%s|%s|%s" $omoVersion $llmproxyVersion $llmproxyLocal | sha256sum }}
# omo-version-tracked: {{ $omoVersion }}
# llmproxy-version-tracked: {{ $llmproxyVersion }}{{ if ne "" $llmproxyLocal }} (overridden by local path: {{ $llmproxyLocal }}){{ end }}

#/ Usage:
#/   run_onchange_after_install-067-sync-opencode-plugins.sh
#/
#/ Description:
#/   Bridges current plugin versions into OpenCode's sticky private plugin
#/   cache. See .agents/rules/agent-orchestration.md "Plugin Versioning" for
#/   the architectural rationale (sticky cache, npm not bun, ETARGET self-heal).
#/
#/   Two plugins, two version-resolution sources:
#/     - oh-my-openagent — version from `mise current` (it's a CLI mise pins)
#/     - @canva/opencode-plugin-llmproxy — version from `npm view` against
#/       the depot registry (it's a plugin-only package, not in mise)
#/
#/   The combined version string is content-hashed so this script re-runs
#/   whenever either version advances.
usage() { grep '^#/' "$0" | cut -c4-; }

eval "$(mise activate bash --quiet)"

tcs_require_command opencode || exit 0

cache_dir=$(tcs_get_opencode_cache) || exit 0

{{- if ne "" $omoVersion }}
tcs_npm_sync "$cache_dir" "oh-my-openagent@{{ $omoVersion }}"
{{- end }}
{{- if eq "" $llmproxyLocal }}
{{- if ne "" $llmproxyVersion }}
tcs_npm_sync "$cache_dir" "@canva/opencode-plugin-llmproxy@{{ $llmproxyVersion }}"
{{- end }}
{{- else }}
# llmproxy plugin is loaded from local dist path, no npm sync needed: {{ $llmproxyLocal }}
{{- end }}
