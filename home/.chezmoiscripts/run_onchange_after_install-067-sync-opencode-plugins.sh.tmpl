{{- $omoVersion := output "mise" "current" "npm:oh-my-openagent" | trim -}}
{{- $llmproxyLocal := dig "openCodeWorkPluginLocalPath" "" . -}}
{{- $llmproxyVersion := "" -}}
{{- if and (eq "" $llmproxyLocal) (eq .machineProfile "work") -}}
{{-   $llmproxyVersion = output "npm" "view" "@canva/opencode-plugin-llmproxy" "version" | trim -}}
{{- end -}}
#!/usr/bin/env bash
set -euo pipefail

IFS=$'\n\t'

source "${HOME}/.local/lib/bash-logging.sh"
source "${HOME}/.local/lib/tool-cache-sync.sh"
setup_session_logging "$(basename "$0")"

# content-hash: {{ printf "%s|%s|%s" $omoVersion $llmproxyVersion $llmproxyLocal | sha256sum }}
# omo-version-tracked: {{ $omoVersion }}
# llmproxy-version-tracked: {{ $llmproxyVersion }}{{ if ne "" $llmproxyLocal }} (local override: {{ $llmproxyLocal }}){{ end }}

#/ Usage:
#/   run_onchange_after_install-067-sync-opencode-plugins.sh
#/
#/ Description:
#/   Forces OpenCode to re-resolve its @latest plugins by clearing their cache
#/   dirs. OpenCode installs an @latest plugin once and thereafter treats the
#/   presence of packages/<spec>/node_modules/<pkg> as a cache hit — it never
#/   re-checks the registry, so a plugin frozen at first-install version
#/   indefinitely (see packages/core/src/npm.ts Npm.add in sst/opencode). There
#/   is no CLI flag, env var, or lockfile check that re-resolves @latest;
#/   deleting the cache dir is the only lever, and OpenCode reinstalls the
#/   current @latest on next launch.
#/
#/   The tracked plugin versions are content-hashed above, so this runs only
#/   when a version advances; in steady state it is a no-op. A running OpenCode
#/   process still needs a restart to pick up the reinstall — OpenCode has no
#/   hot-reload.
#/
#/   Version sources: oh-my-openagent from `mise current`;
#/   @canva/opencode-plugin-llmproxy from `npm view` (work profile only, and
#/   skipped entirely when a local dist path overrides it).
usage() { grep '^#/' "$0" | cut -c4-; }

cache_dir=$(tcs_get_opencode_cache) || exit 0
packages_dir="${cache_dir}/packages"
[ -d "$packages_dir" ] || exit 0

# tcs_bust_opencode_plugin <packages_dir> <sanitized-spec-dir>
tcs_bust_opencode_plugin "$packages_dir" "oh-my-openagent@latest"
{{- if and (eq "" $llmproxyLocal) (eq .machineProfile "work") }}
tcs_bust_opencode_plugin "$packages_dir" "@canva/opencode-plugin-llmproxy@latest"
tcs_bust_opencode_plugin "$packages_dir" "@canva/opencode-plugin-llmproxy"
{{- end }}
