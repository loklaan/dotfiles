#!/usr/bin/env bash
set -euo pipefail

IFS=$'\n\t'

# Normalize TMPDIR (strip trailing slash for consistent path construction)
TMPDIR="${TMPDIR:-/tmp}"
TMPDIR="${TMPDIR%/}"

# Source shared logging library and setup session logging
source "${HOME}/.local/lib/bash-logging.sh"
setup_session_logging "$(basename "$0")"

#/ Usage:
#/   run_after_install-900-setup-status.sh
#/
#/ Description:
#/   Checks setup status after chezmoi apply and reminds about
#/   incomplete configuration.
#/
#/ Options:
#/   --help:      Display this help message
usage() { grep '^#/' "$0" | cut -c4-; }

main() {
  local has_bws="false"
  local has_signing="false"

  if [ -f "{{ .bwsTokenPath }}" ]; then
    has_bws="true"
  fi

  {{- if ne "" .signingKey }}
  has_signing="true"
  {{- end }}

  if [ "$has_bws" = "false" ] || [ "$has_signing" = "false" ]; then
    echo ""
    warning "╍ Dotfiles setup incomplete"
    if [ "$has_bws" = "false" ]; then
      info "╍ Missing: BWS token (for npm auth, GitHub tokens)"
    fi
    if [ "$has_signing" = "false" ]; then
      info "╍ Missing: Signing key (for git commit signing)"
    fi
    echo ""
    info "╍ Run 'dotfiles-setup' for instructions"
  fi
}

main "$@"
