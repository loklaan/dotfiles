#!/usr/bin/env bash
set -euo pipefail

IFS=$'\n\t'

# Normalize TMPDIR (strip trailing slash for consistent path construction)
TMPDIR="${TMPDIR:-/tmp}"
TMPDIR="${TMPDIR%/}"

# Source shared logging library and setup session logging
source "${HOME}/.local/lib/bash-logging.sh"
setup_session_logging "$(basename "$0")"

#/ Usage:
#/   run_after_install-056-mcpproxy-daemon.sh
#/
#/ Description:
#/   Manages the mcpproxy-go daemon. On macOS, cleans up legacy launchd
#/   agents and opens the native MCPProxy.app (Homebrew cask). On Linux,
#/   tears down the legacy systemd --user unit and starts the df-mcpproxy
#/   Pitchfork daemon. Verifies the service is responding on its internal port.
#/   Opt-out via the mcpproxyGate chezmoi flag.
#/
#/ Options:
#/   --help:      Display this help message
usage() { grep '^#/' "$0" | cut -c4-; }

parse_args() {
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --help)
        usage
        exit 0
        ;;
      *)
        usage
        fatal "Unknown argument: $1"
        ;;
    esac
  done
}

start_darwin() {
  local enabled={{ dig "mcpproxyGate" true . }}
  if [ "$enabled" != "true" ]; then
    info "▶ mcpproxy (macOS, opt-out)"
    info "╍ skipping MCPProxy.app launch"
    return 0
  fi

  local domain="gui/$(id -u)"

  info "▶ mcpproxy (macOS, opt-in)"

  # Unload legacy launchd agents (replaced by native MCPProxy.app)
  local label
  for label in io.mcpproxy.serve io.mcpproxy.tray; do
    if launchctl print "${domain}/${label}" >/dev/null 2>&1; then
      launchctl bootout "${domain}/${label}" 2>/dev/null || true
      info "╍ unloaded legacy ${label}"
    fi
    rm -f "${HOME}/Library/LaunchAgents/${label}.plist"
  done

  # Open MCPProxy.app if installed (idempotent — noop if already running)
  local app="/Applications/MCPProxy.app"
  if [ -d "$app" ]; then
    open -a "$app"
    info "╍ opened MCPProxy.app"
  else
    warning "╍ MCPProxy.app not found (install via: brew install --cask mcpproxy)"
    return 0
  fi
}

start_linux() {
  local enabled={{ dig "mcpproxyGate" true . }}

  if [ "$enabled" != "true" ]; then
    info "▶ mcpproxy (Linux, opt-out)"

    if command -v pitchfork >/dev/null 2>&1; then
      pitchfork stop df-mcpproxy 2>/dev/null || true
      info "╍ stopped df-mcpproxy daemon"
    else
      info "╍ Pitchfork not installed; no daemon to stop"
    fi
    return 0
  fi

  info "▶ mcpproxy (Linux, opt-in)"

  # Activate mise so the mcpproxy shim is on PATH
  eval "$(mise activate bash --quiet)"

  if ! command -v mcpproxy >/dev/null 2>&1; then
    warning "╍ mcpproxy not found, skipping (install via: mise install)"
    return 0
  fi

  # Tear down the legacy systemd --user unit if present. Older setups managed
  # mcpproxy via ~/.config/systemd/user/mcpproxy.service; pitchfork now owns the
  # lifecycle. The unit holds an exclusive lock on the bolt db
  # (~/.mcpproxy/config.db), so if it stays enabled pitchfork's df-mcpproxy
  # crash-loops with "database is locked by another process".
  if command -v systemctl >/dev/null 2>&1; then
    local _unit="mcpproxy.service"
    if systemctl --user cat "$_unit" >/dev/null 2>&1; then
      systemctl --user disable --now "$_unit" >/dev/null 2>&1 || true
      info "╍ disabled legacy systemd --user $_unit"
      # Remove the orphan unit file; no longer managed by chezmoi.
      rm -f "${HOME}/.config/systemd/user/${_unit}"
      systemctl --user daemon-reload >/dev/null 2>&1 || true
    fi
  fi

  pitchfork stop df-mcpproxy 2>/dev/null || true
  pitchfork start --quiet df-mcpproxy
  info "╍ started df-mcpproxy via pitchfork"

  sleep 2
  if curl -sf http://127.0.0.1:{{ .ports.mcpproxy.internal }}/ -o /dev/null 2>&1; then
    info "╍ mcpproxy responding on port {{ .ports.mcpproxy.internal }}"
  else
    warning "╍ mcpproxy may not be ready yet (port {{ .ports.mcpproxy.internal }} not responding)"
  fi
}

main() {
  parse_args "$@"

  case "$(uname -s)" in
    Darwin) start_darwin ;;
    Linux)  start_linux ;;
    *)
      warning "▶ mcpproxy daemon"
      warning "╍ unsupported OS: $(uname -s), skipping"
      return 0
      ;;
  esac
}

main "$@"
