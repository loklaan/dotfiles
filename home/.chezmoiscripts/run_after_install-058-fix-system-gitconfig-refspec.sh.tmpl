{{- if eq .machineProfile "work" -}}
#!/usr/bin/env bash
set -euo pipefail

IFS=$'\n\t'

source "${HOME}/.local/lib/bash-logging.sh"
setup_session_logging "$(basename "$0")"

#/ Usage:
#/   fix-system-gitconfig-refspec.sh
#/
#/ Description:
#/   Scrubs two recurring corruptions an external provisioning tool writes into
#/   the system gitconfig (the `[managedconfig]`-tagged tool on work machines):
#/
#/   1. A `^refs/heads/*` negative-glob fetch refspec on remote.origin.fetch.
#/      Negative globs are valid git syntax but rejected by every Rust-based git
#/      implementation (gix/gitoxide/jj), which panics tools like mise on every
#/      invocation.
#/
#/   2. A whitespace-only `credential.helper` entry (literally `helper = " "`).
#/      git expands a non-empty helper value into `git credential-<value>`, so a
#/      single space invokes `git-credential- ` — printing
#/      `git: 'credential-' is not a git command` on every HTTPS git operation.
#/      An EMPTY value means "reset the helper list", so the fix is to remove the
#/      whitespace entry (not blank it), leaving the real osxkeychain/oauth
#/      helpers intact.
#/
#/   The source re-applies both on each run, so a one-shot manual fix doesn't
#/   stick. This script runs on every chezmoi apply to keep the file clean.
#/
#/   Also registers `managedconfig.optout` entries (remote.origin.fetch and
#/   credential.helper) — a convention some enterprise provisioning tools honour
#/   to skip re-managing specific keys. Belt and suspenders: if the opt-out is
#/   respected we're done; if not, this script's own cleanup runs next apply.
#/
#/   Work-machine only — gated on `.emailWork`. Personal machines don't
#/   have external tooling writing to the system gitconfig.
#/
#/ Options:
#/   --help:  Display this help message
usage() { grep '^#/' "$0" | cut -c4-; }

parse_args() {
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --help) usage; exit 0 ;;
      *) usage; fatal "Unknown argument: $1" ;;
    esac
  done
}

system_gitconfig() {
  # Prefer Homebrew-prefixed system gitconfig (arm64 and x86_64 cellars).
  # Fall back to /etc/gitconfig if neither exists — git's own default.
  if [ -f /opt/homebrew/etc/gitconfig ]; then
    echo /opt/homebrew/etc/gitconfig
  elif [ -f /usr/local/etc/gitconfig ]; then
    echo /usr/local/etc/gitconfig
  elif [ -f /etc/gitconfig ]; then
    echo /etc/gitconfig
  else
    echo ""
  fi
}

remove_broken_refspec() {
  local config="$1"
  local current
  # `--get-all` returns nonzero when the key is absent — suppress it so the
  # script doesn't abort under `set -e`.
  current=$(git config --file "$config" --get-all remote.origin.fetch 2>/dev/null || true)
  if [ -z "$current" ]; then
    return 0
  fi

  # Match any negative-glob refspec on refs/heads/ — the exact prefix varies
  # between tools but the shape (leading ^ with a trailing glob) is what
  # trips gix/gitoxide/jj.
  if echo "$current" | grep -Eq '^\^refs/heads/.*\*'; then
    git config --file "$config" --unset-all remote.origin.fetch
    info "removed negative-glob refspec from $config"
  fi
}

remove_broken_credential_helper() {
  local config="$1"
  # git expands a non-empty credential.helper value V into `git credential-V`.
  # The managed tool writes `helper = " "` (a single space), so git runs
  # `git-credential- ` and prints `'credential-' is not a git command` on every
  # HTTPS op. An EMPTY value is special ("reset the list"); a whitespace value
  # is not — so we must delete the offending entry, not blank it.
  #
  # `--unset-all <key> <value-regex>` removes only entries whose value matches.
  # `^[[:space:]]*$` matches the whitespace-only (and empty) entries while
  # leaving real helpers (osxkeychain, oauth) untouched. Returns nonzero when
  # nothing matches — suppressed so `set -e` doesn't abort.
  if git config --file "$config" --get-all credential.helper 2>/dev/null \
       | grep -Eq '^[[:space:]]*$'; then
    git config --file "$config" --unset-all credential.helper '^[[:space:]]*$' 2>/dev/null || true
    info "removed whitespace-only credential.helper from $config"
  fi
}

register_optout() {
  local config="$1" key="$2"
  # `managedconfig.optout` is a multi-valued key convention used by some
  # enterprise provisioning tools: entries list config paths to leave alone
  # on subsequent runs. Adding the key signals intent even when the tool
  # doesn't honour it.
  if git config --file "$config" --get-all managedconfig.optout 2>/dev/null \
       | grep -Fxq "$key"; then
    return 0
  fi
  git config --file "$config" --add managedconfig.optout "$key"
  info "registered managedconfig.optout for $key in $config"
}

main() {
  parse_args "$@"

  local config
  config=$(system_gitconfig)
  if [ -z "$config" ]; then
    # No system gitconfig at all — nothing to clean. This is expected on
    # machines without external tooling managing a system-level gitconfig.
    return 0
  fi

  if [ ! -w "$config" ]; then
    warning "$config is not writable; skipping (needs: chmod +w or sudo)"
    return 0
  fi

  remove_broken_refspec "$config"
  remove_broken_credential_helper "$config"
  register_optout "$config" remote.origin.fetch
  register_optout "$config" credential.helper
}

main "$@"
{{ end -}}
