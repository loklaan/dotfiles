{{- if eq .chezmoi.os "linux" -}}
#!/usr/bin/env bash
# Runs every chezmoi apply on Linux. Manages the orca-server systemd unit
# lifecycle. Install is handled by mise (http: backend → AppImage); this
# script no longer touches apt or downloads anything.
set -euo pipefail

IFS=$'\n\t'

TMPDIR="${TMPDIR:-/tmp}"
TMPDIR="${TMPDIR%/}"

source "${HOME}/.local/lib/bash-logging.sh"
setup_session_logging "$(basename "$0")"

#/ Usage:
#/   run_after_install-059-orca-server.sh
#/
#/ Description:
#/   Manages the orca-server systemd-user unit lifecycle on Linux Coder
#/   workspaces. Opt-in via the `orcaServer` chezmoi flag.
#/
#/   When `orcaServer` is true:
#/     - Verifies orca is installed via mise (the AppImage resolved by
#/       `mise which orca`)
#/     - Verifies FUSE is available (AppImage requires it)
#/     - Enables and starts the systemd unit
#/   When `orcaServer` is false:
#/     - Stops and disables the unit (real opt-out, not just unit-file removal)
#/
#/   Install of orca itself is handled by mise's http: backend (see
#/   home/private_dot_config/mise/config.toml.tmpl). This script does NOT
#/   download or apt-install anything.
#/
#/   macOS: orca runs as Orca.app from the Homebrew cask, not via this script
#/   or systemd. The script renders empty on macOS.
#/
#/ Options:
#/   --help:      Display this help message
usage() { grep '^#/' "$0" | cut -c4-; }

parse_args() {
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --help) usage; exit 0 ;;
      *) usage; fatal "Unknown argument: $1" ;;
    esac
  done
}

verify_orca_installed() {
  if ! command -v mise >/dev/null 2>&1; then
    warning "╍ mise not on PATH — cannot resolve orca install"
    return 1
  fi
  local orca_path
  orca_path=$(mise which orca 2>/dev/null || echo "")
  if [ -z "$orca_path" ] || [ ! -x "$orca_path" ]; then
    warning "╍ orca not yet installed by mise. Try: mise install"
    return 1
  fi
  info "╍ orca AppImage available at ${orca_path}"
}

verify_fuse() {
  # AppImages require FUSE2 to mount themselves at runtime.
  # On modern Ubuntu/Debian, libfuse2t64 (or libfuse2 on older releases)
  # provides this. We don't install it here — that's install-my-packages's
  # job — but we surface a clear warning if it's missing.
  if ! command -v fusermount >/dev/null 2>&1 && ! command -v fusermount3 >/dev/null 2>&1; then
    warning "╍ FUSE not available; orca AppImage may fail to start"
    warning "  Install: sudo apt install -y libfuse2t64 (Ubuntu 24.04+) or libfuse2"
    return 1
  fi
}

manage_linux() {
  local enabled={{ .orcaServer }}

  if [ "$enabled" != "true" ]; then
    info "▶ orca server (Linux, opt-out)"

    # Stop the running unit even if the unit file is gone — chezmoi removes
    # the unit file before this script runs (template renders empty), but
    # the in-memory service can still be active.
    if systemctl --user is-active --quiet orca-server.service 2>/dev/null; then
      systemctl --user stop orca-server.service 2>/dev/null || true
      info "╍ stopped orca-server.service"
    fi
    if systemctl --user is-enabled --quiet orca-server.service 2>/dev/null; then
      systemctl --user disable orca-server.service 2>/dev/null || true
      info "╍ disabled orca-server.service"
    fi
    # Clear any 'failed' state — the unit file is gone, so SuccessExitStatus
    # no longer covers exit-code 1 from orca-serve's normal SIGTERM exit.
    systemctl --user reset-failed orca-server.service 2>/dev/null || true
    systemctl --user daemon-reload 2>/dev/null || true
    return 0
  fi

  info "▶ orca server (Linux, opt-in)"

  if ! verify_orca_installed; then
    warning "╍ skipping unit lifecycle — orca not installed"
    return 0
  fi

  verify_fuse || true   # warn but don't block; some boxes have FUSE preconfigured

  systemctl --user daemon-reload
  systemctl --user enable orca-server.service

  if systemctl --user is-active --quiet orca-server.service; then
    # Restart on every apply — picks up potential AppImage version bumps
    # (mise re-installs in place, but the running process holds the old
    # extracted squashfs view until restart).
    systemctl --user restart orca-server.service
    info "╍ restarted orca-server.service (picks up any AppImage version change)"
  else
    systemctl --user start orca-server.service
    info "╍ started orca-server.service"
  fi

  sleep 2
  if systemctl --user is-active --quiet orca-server.service; then
    info "╍ orca-server.service is active"
  else
    warning "╍ orca-server.service did not stay active — check: journalctl --user -u orca-server.service"
  fi
}

main() {
  parse_args "$@"
  manage_linux
}

main "$@"
{{- end }}
