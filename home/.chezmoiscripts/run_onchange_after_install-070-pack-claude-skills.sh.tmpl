{{- if or (eq .chezmoi.os "darwin") (and (eq .chezmoi.os "linux") (or (env "DISPLAY") (env "WAYLAND_DISPLAY"))) -}}
{{- /* Composite hash of all skill source files + externals TOML. */ -}}
{{- /* Changes here cause run_onchange_ to re-execute the script. */ -}}
{{- $skillsGlob := joinPath .chezmoi.sourceDir "dot_claude/exact_skills" "**" -}}
{{- $hash := include ".chezmoiexternals/claude-skills.toml" | sha256sum -}}
{{- $srcPrefix := printf "%s/" .chezmoi.sourceDir -}}
{{- range (glob $skillsGlob | sortAlpha) -}}
{{-   if stat . -}}
{{-     if not (stat .).isDir -}}
{{-       $hash = printf "%s%s" $hash (include (trimPrefix $srcPrefix .) | sha256sum) -}}
{{-     end -}}
{{-   end -}}
{{- end -}}
#!/usr/bin/env bash
# skills-content-hash: {{ $hash | sha256sum }}
set -euo pipefail

IFS=$'\n\t'

# Normalize TMPDIR (strip trailing slash for consistent path construction)
TMPDIR="${TMPDIR:-/tmp}"
TMPDIR="${TMPDIR%/}"

# Source shared logging library and setup session logging
source "${HOME}/.local/lib/bash-logging.sh"
setup_session_logging "$(basename "$0")"

#/ Usage:
#/   run_onchange_after_install-070-pack-claude-skills.sh
#/
#/ Description:
#/   Packs Claude skills from ~/.claude/skills/ into individual zip files
#/   for drag-and-drop installation into Claude Desktop's capabilities panel.
#/   Only repacks skills whose content has changed since the last run.
#/   Opens the output directory in the system file manager when complete.
#/
#/ Output Directory:
#/   ~/.cache/claude-skill-packs/
usage() { grep '^#/' "$0" | cut -c4-; }

SKILLS_DIR="${HOME}/.claude/skills"
OUTPUT_DIR="${HOME}/.cache/claude-skill-packs"
MANIFEST_FILE="${OUTPUT_DIR}/.skill-hashes"

hash_skill() {
  local skill_dir="$1"
  find "$skill_dir" -type f \
    -not -name '.DS_Store' \
    -not -name '.skills-cli.json' \
    -not -name '.git*' \
    -not -path '*/.git/*' \
    | sort \
    | xargs shasum -a 256 \
    | shasum -a 256 \
    | cut -d' ' -f1
}

get_stored_hash() {
  local skill_name="$1"
  if [ -f "$MANIFEST_FILE" ]; then
    grep "  ${skill_name}$" "$MANIFEST_FILE" | cut -d' ' -f1 || true
  fi
}

pack_skill() {
  local skill_dir="$1"
  local skill_name
  skill_name="$(basename "$skill_dir")"
  local zip_path="${OUTPUT_DIR}/${skill_name}.zip"

  rm -f "$zip_path"

  (cd "$SKILLS_DIR" && zip -r "$zip_path" "$skill_name/" \
    -x '*/.git*' \
    -x '*/.DS_Store' \
    -x '*/.skills-cli.json' \
  ) > /dev/null
}

clean_stale_zips() {
  local valid_skills=("$@")

  for zip_file in "$OUTPUT_DIR"/*.zip; do
    [ -f "$zip_file" ] || continue
    local zip_name
    zip_name="$(basename "$zip_file" .zip)"

    local found=false
    for skill_name in "${valid_skills[@]}"; do
      if [ "$zip_name" = "$skill_name" ]; then
        found=true
        break
      fi
    done

    if [ "$found" = false ]; then
      rm -f "$zip_file"
      info "╍ Removed stale zip: ${zip_name}.zip"
    fi
  done
}

main() {
  if [ ! -d "$SKILLS_DIR" ]; then
    warning "╍ Skills directory not found: $SKILLS_DIR"
    return 0
  fi

  mkdir -p "$OUTPUT_DIR"

  # Discover all skills
  local all_skills=()
  for skill_dir in "$SKILLS_DIR"/*/; do
    [ -d "$skill_dir" ] || continue
    [ -f "${skill_dir}SKILL.md" ] || continue
    all_skills+=("$(basename "$skill_dir")")
  done

  if [ ${#all_skills[@]} -eq 0 ]; then
    info "╍ No skills found"
    return 0
  fi

  local total=${#all_skills[@]}
  local changed_skills=()
  local new_manifest=""

  for skill_name in "${all_skills[@]}"; do
    local skill_dir="${SKILLS_DIR}/${skill_name}"
    local current_hash
    current_hash="$(hash_skill "$skill_dir")"

    local stored_hash
    stored_hash="$(get_stored_hash "$skill_name")"

    local zip_path="${OUTPUT_DIR}/${skill_name}.zip"

    new_manifest="${new_manifest}${current_hash}  ${skill_name}"$'\n'

    if [ "$current_hash" = "$stored_hash" ] && [ -f "$zip_path" ]; then
      continue
    fi

    pack_skill "$skill_dir"
    changed_skills+=("$skill_name")
  done

  clean_stale_zips "${all_skills[@]}"

  # Save manifest (sorted by skill name)
  printf '%s' "$new_manifest" | sort -t' ' -k3 > "$MANIFEST_FILE"

  local changed_count=${#changed_skills[@]}

  if [ "$changed_count" -eq 0 ]; then
    info "▶ Packing Claude skills for Desktop"
    info "╍ All ${total} skills up to date"
    return 0
  fi

  if [ "$changed_count" -eq "$total" ]; then
    info "▶ Packing Claude skills for Desktop"
    info "╍ All ${total} skills packed to ${OUTPUT_DIR}/"
  else
    info "▶ Packing Claude skills for Desktop (${changed_count} of ${total} changed)"
    info ""
    info "$(printf '  %-24s %s' "Skill" "Zip")"
    info "$(printf '  %-24s %s' "─────" "───")"
    for skill_name in "${changed_skills[@]}"; do
      info "$(printf '  %-24s %s' "$skill_name" "${skill_name}.zip")"
    done
    info ""
    info "  → ${OUTPUT_DIR}/"
  fi

  # Open output directory in system file manager
  if [ "$(uname)" = "Darwin" ]; then
    open "$OUTPUT_DIR"
  elif command -v xdg-open &>/dev/null; then
    xdg-open "$OUTPUT_DIR"
  fi
}

main "$@"
{{ end -}}
