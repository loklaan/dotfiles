{{- /* chezmoi:modify-template */ -}}
{{- $base := fromJson (default "{}" .chezmoi.stdin) -}}
{{- $config := $base -}}

{{- /* Globally disable peon-ping. Overtriggers in OpenCode sessions where
       the thin adapter fires UserPromptSubmit on every tool call. CLI
       commands (peon volume, peon notifications, etc.) write other keys
       into this file, so we only overlay our preferences. */ -}}
{{- $config = $config | setValueAtPath "enabled" false -}}

{{- /* Keep these as sensible defaults if peon is re-enabled later. */ -}}
{{- $config = $config | setValueAtPath "silent_window_seconds" 30 -}}
{{- $config = $config | setValueAtPath "suppress_subagent_complete" true -}}
{{- $config = $config | setValueAtPath "suppress_delegate_sessions" true -}}
{{- $config = $config | setValueAtPath "annoyed_threshold" 10 -}}

{{ $config | toPrettyJson }}
