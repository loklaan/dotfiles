{{- /* chezmoi:modify-template */ -}}
{{- $base := fromJson (default "{}" .chezmoi.stdin) -}}

{{- /* Resolve API keys from Bitwarden Secrets via the soft-fail wrapper so
       per-secret access gaps (a machine account without Context7 access,
       for example) produce an empty key rather than aborting apply. */ -}}
{{- $bwsToken := "" -}}
{{- if and (lookPath "bws") (stat .bwsTokenPath) -}}
{{-   $bwsToken = include .bwsTokenPath | trim -}}
{{- end -}}
{{- $bwsGet := joinPath .chezmoi.homeDir ".local/lib/bws-get-or-empty" -}}
{{- $context7Key := "" -}}
{{- $exaKey := "" -}}
{{- $pushbulletToken := "" -}}
{{- /* dig the data var so machines whose active config predates it (not yet
       re-inited) degrade gracefully instead of aborting apply on a missing key. */ -}}
{{- $pushbulletSecretId := dig "bwsIdPushbulletAccessToken" "" . -}}
{{- if and (ne "" $bwsToken) (stat $bwsGet) -}}
{{-   $context7Key = output $bwsGet .bwsIdContext7ApiKey $bwsToken | trim -}}
{{-   $exaKey = output $bwsGet .bwsIdExaApiKey $bwsToken | trim -}}
{{-   if ne "" $pushbulletSecretId -}}
{{-     $pushbulletToken = output $bwsGet $pushbulletSecretId $bwsToken | trim -}}
{{-   end -}}
{{- end -}}

{{- /* Build our managed server list */ -}}
{{- $servers := list -}}

{{- if ne "" .emailWork -}}
{{-   $servers = append $servers (dict
        "name" "otter"
        "command" "otter"
        "args" (list "mcp" "serve")
        "protocol" "stdio"
        "enabled" true
      ) -}}
{{- end -}}

{{- /* Pushbullet MCP: local single-file Deno server. Only registered when the
       access token resolves from Bitwarden, since the server is useless without
       it; a missing token therefore omits the server rather than registering a
       broken one. The token is passed via env (read by Config.redacted). The
       deno invocation lives in the script's shebang, so we exec it directly. */ -}}
{{- if ne "" $pushbulletToken -}}
{{-   $servers = append $servers (dict
        "name" "pushbullet"
        "command" (joinPath .chezmoi.homeDir ".local/bin/pushbullet-mcp")
        "args" (list)
        "protocol" "stdio"
        "enabled" true
        "env" (dict "PUSHBULLET_ACCESS_TOKEN" $pushbulletToken)
      ) -}}
{{- end -}}

{{- $servers = append $servers (dict
      "name" "effect-docs"
      "command" "npx"
      "args" (list "-y" "effect-mcp@latest")
      "protocol" "stdio"
      "enabled" true
    ) -}}

{{- /* Smithers: durable, code-defined workflow orchestrator. Exposed as an MCP
       server so the lead agent can OPERATE it — run deterministic workflow
       graphs (Sequence/Branch/Ralph-with-predicate, schema-validated handoffs)
       for by-step mid-horizon work, with opencode as the worker. Runs on bun
       (its CLI shebang is bun); bunx resolves via the mise shim like npx/uvx. */ -}}
{{- $servers = append $servers (dict
      "name" "smithers"
      "command" "bunx"
      "args" (list "smithers-orchestrator" "--mcp")
      "protocol" "stdio"
      "enabled" true
    ) -}}

{{- $servers = append $servers (dict
      "name" "pdf-tools"
      "command" "uvx"
      "args" (list "mcp-pdf")
      "protocol" "stdio"
      "enabled" true
    ) -}}

{{- $servers = append $servers (dict
      "name" "chrome-devtools"
      "command" "npx"
      "args" (list "-y" "chrome-devtools-mcp@latest")
      "protocol" "stdio"
      "enabled" true
    ) -}}

{{- $servers = append $servers (dict
      "name" "figma-desktop"
      "url" "http://127.0.0.1:3845/mcp"
      "protocol" "http"
      "enabled" true
    ) -}}

{{- /* Remote MCP servers (moved from oh-my-openagent defaults) */ -}}
{{- $context7Headers := dict -}}
{{- if ne "" $context7Key -}}
{{-   $context7Headers = dict "CONTEXT7_API_KEY" $context7Key -}}
{{- end -}}
{{- $servers = append $servers (dict
      "name" "context7"
      "url" "https://mcp.context7.com/mcp"
      "protocol" "http"
      "headers" $context7Headers
      "enabled" true
    ) -}}

{{- $exaHeaders := dict -}}
{{- if ne "" $exaKey -}}
{{-   $exaHeaders = dict "x-api-key" $exaKey -}}
{{- end -}}
{{- $servers = append $servers (dict
      "name" "websearch"
      "url" "https://mcp.exa.ai"
      "protocol" "http"
      "headers" $exaHeaders
      "enabled" true
    ) -}}

{{- /* Notion: hosted, actively-maintained remote MCP. Streamable HTTP with
       user-based OAuth (no API key / bearer token), so first use prompts an
       OAuth flow whose grant the proxy persists in its own runtime state. */ -}}
{{- $servers = append $servers (dict
      "name" "notion"
      "url" "https://mcp.notion.com/mcp"
      "protocol" "http"
      "enabled" true
    ) -}}

{{- /* Merge existing server entries to preserve runtime state (quarantined,
       created, updated, oauth) while ensuring our definitions are present.
       For each managed server, find the existing entry and overlay our fields. */ -}}
{{- $existingServers := list -}}
{{- if hasKey $base "mcpServers" -}}
{{-   $existingServers = get $base "mcpServers" -}}
{{- end -}}

{{- $mergedServers := list -}}
{{- range $our := $servers -}}
{{-   $merged := dict -}}
{{-   range $existing := $existingServers -}}
{{-     if eq (get $existing "name") (get $our "name") -}}
{{-       $merged = $existing -}}
{{-     end -}}
{{-   end -}}
{{-   $merged = merge $our $merged -}}
{{-   $mergedServers = append $mergedServers $merged -}}
{{- end -}}

{{- /* Overlay our managed keys, preserve everything else */ -}}
{{- $config := $base -}}
{{- $config = $config | setValueAtPath "listen" "127.0.0.1:18321" -}}
{{- $config = $config | setValueAtPath "data_dir" (printf "%s/.mcpproxy" .chezmoi.homeDir) -}}
{{- $config = $config | setValueAtPath "top_k" 5 -}}
{{- $config = $config | setValueAtPath "tools_limit" 15 -}}
{{- $config = $config | setValueAtPath "tool_response_limit" 20000 -}}
{{- $config = $config | setValueAtPath "mcpServers" $mergedServers -}}
{{- $config = $config | setValueAtPath "routing_mode" "retrieve_tools" -}}
{{- $config = $config | setValueAtPath "telemetry.enabled" false -}}

{{ $config | toPrettyJson }}
