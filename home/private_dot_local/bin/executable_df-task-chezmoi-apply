#!/usr/bin/env bash
set -euo pipefail

IFS=$'\n\t'

TMPDIR="${TMPDIR:-/tmp}"
TMPDIR="${TMPDIR%/}"

source "${HOME}/.local/lib/bash-logging.sh"
setup_session_logging "$(basename "$0")"

#/ Usage:
#/   df-task-chezmoi-apply
#/
#/ Description:
#/   Wrapper around `chezmoi apply` invoked from the `[tasks."chezmoi:apply"]`
#/   mise task (and `tasks.update` via `depends_post`).
#/
#/   Hoisted out of mise.toml so the task body lives next to other
#/   dotfiles-task-* scripts and so it can be run directly for debugging.
#/
#/   When stdin is not a TTY (CI, agent shells), chezmoi's
#/   "X has changed since last write — overwrite/skip?" prompt would otherwise
#/   crash with "could not open a new TTY". This wrapper detects
#/   non-interactive contexts and adds `--force --no-tty` so the apply
#/   converges instead of halting. Override by exporting CHEZMOI_INTERACTIVE=1
#/   to force the prompt-capable path.
#/
#/   Note: this script is NOT invoked from any mise `[hooks].postinstall` hook.
#/   Such a hook would re-enter `chezmoi apply` from inside the
#/   `mise install`/`mise upgrade` calls that `install-050-install-packages.sh`
#/   runs during an outer `chezmoi apply`, deadlocking on chezmoi's
#/   persistent-state lock. Tool versions are converged by lifecycle scripts
#/   that run later in the outer apply instead.
#/
#/   On success: silent. On failure: surfaces chezmoi's error output and
#/   propagates the exit code.
#/
#/ Environment:
#/   CHEZMOI_VERBOSE       When set to "1", invokes chezmoi with -v.
#/   CHEZMOI_INTERACTIVE   When set to "1", keeps prompts even without a TTY.
#/                         When "0", forces non-interactive even with a TTY.
#/                         Unset: auto-detect from stdin.
#/
#/ Options:
#/   --help    Display this help message
usage() { grep '^#/' "$0" | cut -c4-; }

parse_args() {
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --help) usage; exit 0 ;;
      *) usage; fatal "Unknown argument: $1" ;;
    esac
  done
}

# Resolve interactive vs non-interactive mode. Non-interactive adds
# `--force --no-tty` so unattended runs converge instead of trying to
# prompt. See header comment for the override knob.
resolve_mode_flags() {
  local override="${CHEZMOI_INTERACTIVE:-}"
  case "$override" in
    1) return 0 ;;
    0) printf '%s\n' --force --no-tty; return 0 ;;
  esac
  if [ -t 0 ]; then
    return 0
  fi
  printf '%s\n' --force --no-tty
}

main() {
  parse_args "$@"

  if ! command -v chezmoi >/dev/null 2>&1; then
    fatal "chezmoi not on PATH"
  fi

  local -a mode_flags=()
  while IFS= read -r flag; do
    [ -n "$flag" ] && mode_flags+=("$flag")
  done < <(resolve_mode_flags)

  local -a verbose_flags=()
  if [ "${CHEZMOI_VERBOSE:-0}" = "1" ]; then
    verbose_flags+=(-v)
  fi

  chezmoi apply "${mode_flags[@]}" "${verbose_flags[@]}"
}

main "$@"
