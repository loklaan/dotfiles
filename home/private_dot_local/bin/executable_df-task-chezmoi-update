#!/usr/bin/env bash
set -euo pipefail

IFS=$'\n\t'

TMPDIR="${TMPDIR:-/tmp}"
TMPDIR="${TMPDIR%/}"

source "${HOME}/.local/lib/bash-logging.sh"
setup_session_logging "$(basename "$0")"

#/ Usage:
#/   df-task-chezmoi-update
#/
#/ Description:
#/   Wrapper around `chezmoi update` (git pull on the source repo, then
#/   apply). Sibling to dotfiles-task-chezmoi-apply; same TTY-aware
#/   semantics so unattended runs (agent shells, CI, piped invocations)
#/   converge instead of dying on the "X has changed since last write"
#/   prompt with "could not open a new TTY".
#/
#/   In interactive shells (stdin attached to a TTY) it runs plain
#/   `chezmoi update` so prompts still surface for the human at the
#/   keyboard.
#/
#/ Environment:
#/   CHEZMOI_VERBOSE       When set to "1", invokes chezmoi with -v.
#/   CHEZMOI_INTERACTIVE   When set to "1", keeps prompts even without a TTY.
#/                         When "0", forces non-interactive even with a TTY.
#/                         Unset: auto-detect from stdin.
#/
#/ Options:
#/   --help    Display this help message
usage() { grep '^#/' "$0" | cut -c4-; }

parse_args() {
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --help) usage; exit 0 ;;
      *) usage; fatal "Unknown argument: $1" ;;
    esac
  done
}

resolve_mode_flags() {
  local override="${CHEZMOI_INTERACTIVE:-}"
  case "$override" in
    1) return 0 ;;
    0) printf '%s\n' --force --no-tty; return 0 ;;
  esac
  if [ -t 0 ]; then
    return 0
  fi
  printf '%s\n' --force --no-tty
}

main() {
  parse_args "$@"

  if ! command -v chezmoi >/dev/null 2>&1; then
    fatal "chezmoi not on PATH"
  fi

  local -a mode_flags=()
  while IFS= read -r flag; do
    [ -n "$flag" ] && mode_flags+=("$flag")
  done < <(resolve_mode_flags)

  local -a verbose_flags=()
  if [ "${CHEZMOI_VERBOSE:-0}" = "1" ]; then
    verbose_flags+=(-v)
  fi

  chezmoi update "${mode_flags[@]}" "${verbose_flags[@]}"
}

main "$@"
