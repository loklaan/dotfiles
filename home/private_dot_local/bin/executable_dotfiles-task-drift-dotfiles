#!/usr/bin/env bash
set -euo pipefail

IFS=$'\n\t'

TMPDIR="${TMPDIR:-/tmp}"
TMPDIR="${TMPDIR%/}"

source "${HOME}/.local/lib/bash-logging.sh"

#/ Usage:
#/   dotfiles-task-drift-dotfiles
#/
#/ Description:
#/   Drift checker for the dotfiles repo itself. Counts commits HEAD is
#/   behind origin/main and emits the count in the shared drift schema.
#/
#/   Output: JSON array on stdout. Single-element when behind, else [].
#/   Soft-fails (returns []) when:
#/     - chezmoi not on PATH
#/     - source path is not a git repo
#/     - network fetch fails
#/
#/ Options:
#/   --help    Display this help message
usage() { grep '^#/' "$0" | cut -c4-; }

while [ "$#" -gt 0 ]; do
  case "$1" in
    --help) usage; exit 0 ;;
    *) shift ;;
  esac
done

main() {
  if ! command -v chezmoi >/dev/null 2>&1; then
    echo "[]"
    return 0
  fi
  if ! command -v jq >/dev/null 2>&1 || ! command -v git >/dev/null 2>&1; then
    echo "[]"
    return 0
  fi

  local source_dir repo_root
  source_dir=$(chezmoi source-path 2>/dev/null) || { echo "[]"; return 0; }
  repo_root=$(cd "$source_dir" && cd .. && pwd)

  if [ ! -d "${repo_root}/.git" ]; then
    echo "[]"
    return 0
  fi

  # Best-effort fetch; ignore network errors
  git -C "$repo_root" fetch -q origin main 2>/dev/null || true

  local behind
  behind=$(git -C "$repo_root" rev-list --count HEAD..origin/main 2>/dev/null || echo "0")

  if [ "$behind" -le 0 ] 2>/dev/null; then
    echo "[]"
    return 0
  fi

  local installed latest
  installed=$(git -C "$repo_root" rev-parse --short HEAD 2>/dev/null || echo "")
  latest=$(git -C "$repo_root" rev-parse --short origin/main 2>/dev/null || echo "")

  jq -n -c \
    --arg name "dotfiles" \
    --arg installed "$installed" \
    --arg latest "$latest" \
    --argjson behind "$behind" \
    '[{name:$name, installed:$installed, latest:$latest, behind:$behind, source:"git:dotfiles"}]'
}

main
