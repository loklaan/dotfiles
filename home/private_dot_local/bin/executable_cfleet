#!/usr/bin/env bash
set -euo pipefail

IFS=$'\n\t'

TMPDIR="${TMPDIR:-/tmp}"
TMPDIR="${TMPDIR%/}"

source "${HOME}/.local/lib/bash-logging.sh"

#/ Usage:
#/   cfleet [OPTIONS] -- <mise-task> [args...]
#/   cfleet [OPTIONS] <mise-task> [args...]
#/
#/ Description:
#/   Run a mise task on every running Coder workspace, in parallel.
#/   Modelled on the chezmoi-preflight pattern: a small composable primitive,
#/   not a workflow-aware orchestrator. Whatever task you can `mise run`
#/   locally, you can run on the fleet.
#/
#/   Discovery is dynamic via `coder list -o json` (filtered to running
#/   workspaces by default). No static inventory.
#/
#/ Options:
#/   --include-local       Also run the task on this machine (before the fleet)
#/   --local-only          Run only on this machine (skip the fleet)
#/   --filter <expr>       jq filter against `coder list -o json`
#/                         (default: '.[] | select(.latest_build.status == "running") | .name')
#/   --parallel <N>        Max concurrent SSH targets (default: 4)
#/   --dry-run             Print the matrix; don't execute
#/   --help                Display this help message
#/
#/ Examples:
#/   cfleet update                          # `mise run update` on every running box
#/   cfleet --include-local update          # me first, then every box
#/   cfleet --local-only drift:check        # local convergence only
#/   cfleet --dry-run update                # preview the fan-out
#/
#/ Output:
#/   Per-host structured: [<ws>] ok | [<ws>] FAIL: <reason>
#/   Per-host stdout/stderr captured to $TMPDIR/cfleet-<ts>/<ws>.log
#/   Aggregate exit code = max of per-host codes (0 only if all succeeded)
usage() { grep '^#/' "$0" | cut -c4-; }

INCLUDE_LOCAL=0
LOCAL_ONLY=0
FILTER='.[] | select(.latest_build.status == "running") | .name'
PARALLEL=4
DRY_RUN=0
TASK_AND_ARGS=()

parse_args() {
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --help) usage; exit 0 ;;
      --include-local) INCLUDE_LOCAL=1; shift ;;
      --local-only) LOCAL_ONLY=1; shift ;;
      --filter) FILTER="$2"; shift 2 ;;
      --parallel) PARALLEL="$2"; shift 2 ;;
      --dry-run) DRY_RUN=1; shift ;;
      --) shift; TASK_AND_ARGS=("$@"); return ;;
      -*) usage >&2; fatal "Unknown option: $1" ;;
      *) TASK_AND_ARGS=("$@"); return ;;
    esac
  done
}

require_tools() {
  command -v mise >/dev/null 2>&1 || fatal "mise not on PATH"
  if [ "$LOCAL_ONLY" -ne 1 ]; then
    command -v coder >/dev/null 2>&1 || fatal "coder CLI not found (needed for fleet dispatch)"
    command -v jq    >/dev/null 2>&1 || fatal "jq not found"
  fi
}

list_workspaces() {
  coder list -o json 2>/dev/null | jq -r "$FILTER"
}

run_local() {
  local task="$1"; shift
  info "[local] mise run $task $*"
  if [ "$DRY_RUN" -eq 1 ]; then return 0; fi
  if mise run "$task" "$@"; then
    _print green "[local] ok" >&2
    return 0
  else
    local rc=$?
    _print red "[local] FAIL ($rc)" >&2
    return "$rc"
  fi
}

run_remote() {
  local ws="$1" log_dir="$2"; shift 2
  local task="$1"; shift
  local log_file="${log_dir}/${ws}.log"
  local cmd="mise run $task"
  for a in "$@"; do
    cmd="$cmd $(printf '%q' "$a")"
  done
  info "[$ws] $cmd"
  if [ "$DRY_RUN" -eq 1 ]; then return 0; fi
  if ssh -o ConnectTimeout=15 "coder.${ws}" "$cmd" >"$log_file" 2>&1; then
    _print green "[$ws] ok" >&2
    return 0
  else
    local rc=$?
    _print red "[$ws] FAIL ($rc) — see $log_file" >&2
    return "$rc"
  fi
}

main() {
  parse_args "$@"

  if [ "${#TASK_AND_ARGS[@]}" -eq 0 ]; then
    usage >&2
    fatal "no mise task specified"
  fi

  require_tools

  local task="${TASK_AND_ARGS[0]}"
  local task_args=("${TASK_AND_ARGS[@]:1}")
  local ts log_dir
  ts=$(date +"%Y%m%d_%H%M%S")
  log_dir="${TMPDIR}/cfleet-${ts}"
  mkdir -p "$log_dir"

  local max_rc=0

  # 1. Optional local-first run
  if [ "$INCLUDE_LOCAL" -eq 1 ] || [ "$LOCAL_ONLY" -eq 1 ]; then
    if ! run_local "$task" "${task_args[@]}"; then
      max_rc=$?
    fi
  fi

  if [ "$LOCAL_ONLY" -eq 1 ]; then
    [ "$max_rc" -ne 0 ] && return "$max_rc"
    return 0
  fi

  # 2. Fleet dispatch
  local workspaces
  workspaces=$(list_workspaces)
  if [ -z "$workspaces" ]; then
    warning "no running workspaces matched filter"
    return "$max_rc"
  fi

  info "fan-out: $(echo "$workspaces" | wc -l | tr -d ' ') workspace(s) · parallelism=$PARALLEL · log_dir=$log_dir"

  local pids=() ws
  local running=0
  while IFS= read -r ws; do
    [ -z "$ws" ] && continue
    while [ "$running" -ge "$PARALLEL" ]; do
      wait -n 2>/dev/null || true
      running=$((running - 1))
    done
    run_remote "$ws" "$log_dir" "$task" "${task_args[@]}" &
    pids+=("$!")
    running=$((running + 1))
  done <<< "$workspaces"

  for pid in "${pids[@]}"; do
    if ! wait "$pid"; then
      local rc=$?
      [ "$rc" -gt "$max_rc" ] && max_rc=$rc
    fi
  done

  if [ "$max_rc" -eq 0 ]; then
    _print green "cfleet: all targets ok"
  else
    _print yellow "cfleet: completed with $max_rc max-rc — inspect $log_dir"
  fi
  return "$max_rc"
}

main "$@"
