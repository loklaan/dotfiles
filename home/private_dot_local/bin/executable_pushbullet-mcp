#!/usr/bin/env -S deno run --allow-net=api.pushbullet.com --allow-env

// Pushbullet MCP server (Deno + Effect v4 beta). Tools for sending pushes via
// the Pushbullet REST API v2 (https://docs.pushbullet.com), spoken over stdio.
//
// CRITICAL: stdout is the NDJSON-RPC channel — all logging must go to stderr,
// or the protocol breaks. NodeStdio/NodeRuntime from @effect/platform-node run
// under Deno via its node: compatibility layer. The PUSHBULLET_ACCESS_TOKEN has
// full account access, so it is held as Redacted and never logged.
// Effect v4 beta import paths verified against effect@4.0.0-beta.80.

import { Config, Context, Effect, Layer, Logger, Redacted, Schema } from "npm:effect@4.0.0-beta.80"
import { McpServer, Tool, Toolkit } from "npm:effect@4.0.0-beta.80/unstable/ai"
import {
  FetchHttpClient,
  HttpClient,
  HttpClientRequest,
  HttpClientResponse,
} from "npm:effect@4.0.0-beta.80/unstable/http"
import { NodeRuntime, NodeStdio } from "npm:@effect/platform-node@4.0.0-beta.80"

class PushbulletError extends Schema.TaggedErrorClass<PushbulletError>()("PushbulletError", {
  message: Schema.String,
  cause: Schema.Unknown,
}) {}

const PushResult = Schema.Struct({
  iden: Schema.String,
  type: Schema.String,
  active: Schema.Boolean,
})

const Device = Schema.Struct({
  iden: Schema.String,
  nickname: Schema.optional(Schema.String),
  model: Schema.optional(Schema.String),
  active: Schema.Boolean,
  created: Schema.optional(Schema.Number),
})
const DevicesResponse = Schema.Struct({
  devices: Schema.Array(Device),
})

class Pushbullet extends Context.Service<Pushbullet, {
  sendNote(params: {
    readonly title: string
    readonly body: string
    readonly device_iden?: string | undefined
  }): Effect.Effect<typeof PushResult.Type, PushbulletError>
  sendLink(params: {
    readonly title: string
    readonly body: string
    readonly url: string
    readonly device_iden?: string | undefined
  }): Effect.Effect<typeof PushResult.Type, PushbulletError>
  listDevices(): Effect.Effect<ReadonlyArray<typeof Device.Type>, PushbulletError>
}>()("pushbullet-mcp/Pushbullet") {
  static readonly layer = Layer.effect(
    Pushbullet,
    Effect.gen(function* () {
      const token = yield* Config.redacted("PUSHBULLET_ACCESS_TOKEN")

      const client = (yield* HttpClient.HttpClient).pipe(
        HttpClient.mapRequest((request) =>
          request.pipe(
            HttpClientRequest.prependUrl("https://api.pushbullet.com/v2"),
            HttpClientRequest.setHeader("Access-Token", Redacted.value(token)),
            HttpClientRequest.acceptJson,
          )
        ),
        HttpClient.filterStatusOk,
      )

      const postPush = Effect.fn("Pushbullet.postPush")(function* (
        body: Record<string, string>,
      ) {
        return yield* HttpClientRequest.post("/pushes").pipe(
          HttpClientRequest.bodyJsonUnsafe(body),
          client.execute,
          Effect.flatMap(HttpClientResponse.schemaBodyJson(PushResult)),
          Effect.mapError((cause) =>
            new PushbulletError({ message: "Failed to send push", cause })
          ),
        )
      })

      const sendNote = Effect.fn("Pushbullet.sendNote")(function* (params: {
        readonly title: string
        readonly body: string
        readonly device_iden?: string | undefined
      }) {
        return yield* postPush({
          type: "note",
          title: params.title,
          body: params.body,
          ...(params.device_iden ? { device_iden: params.device_iden } : {}),
        })
      })

      const sendLink = Effect.fn("Pushbullet.sendLink")(function* (params: {
        readonly title: string
        readonly body: string
        readonly url: string
        readonly device_iden?: string | undefined
      }) {
        return yield* postPush({
          type: "link",
          title: params.title,
          body: params.body,
          url: params.url,
          ...(params.device_iden ? { device_iden: params.device_iden } : {}),
        })
      })

      const listDevices = Effect.fn("Pushbullet.listDevices")(function* () {
        const response = yield* client.get("/devices", {
          urlParams: { active: "true" },
        }).pipe(
          Effect.flatMap(HttpClientResponse.schemaBodyJson(DevicesResponse)),
          Effect.mapError((cause) =>
            new PushbulletError({ message: "Failed to list devices", cause })
          ),
        )
        return response.devices
      })

      return Pushbullet.of({ sendNote, sendLink, listDevices })
    }),
  ).pipe(Layer.provide(FetchHttpClient.layer))
}

const SendNote = Tool.make("send_note", {
  description:
    "Send a text notification (a Pushbullet \"note\") to the user's phones, " +
    "tablets, and computers. Use this when the user wants to be notified, " +
    "pinged, alerted, or reminded about something that is plain text with no " +
    "associated link \u2014 for example a task finishing, a status update, or a " +
    "message to themselves. For a notification whose primary payload is a URL, " +
    "use send_link instead. This delivers a real notification to physical " +
    "devices, so only call it when notification is clearly intended.",
  parameters: Schema.Struct({
    title: Schema.String.annotate({
      description: "Short headline shown as the notification title.",
    }),
    body: Schema.String.annotate({
      description: "Main notification text shown beneath the title.",
    }),
    device_iden: Schema.optional(
      Schema.String.annotate({
        description:
          "Deliver only to one device, identified by its iden from " +
          "list_devices. Omit to broadcast to all of the user's devices.",
      }),
    ),
  }),
  success: Schema.Struct({
    iden: Schema.String,
    delivered: Schema.Boolean,
  }),
  failure: Schema.String,
})
  .annotate(Tool.Title, "Send Pushbullet Note")
  .annotate(Tool.Readonly, false)
  .annotate(Tool.Destructive, false)
  .annotate(Tool.Idempotent, false)
  .annotate(Tool.OpenWorld, true)

const SendLink = Tool.make("send_link", {
  description:
    "Send a clickable link notification (a Pushbullet \"link\" push) to the " +
    "user's phones, tablets, and computers. Use this when the user wants to be " +
    "notified with a URL they can open \u2014 for example sharing a page to their " +
    "phone, or sending themselves a link to read later. When the notification " +
    "has no URL, use send_note instead. This delivers a real notification to " +
    "physical devices, so only call it when notification is clearly intended.",
  parameters: Schema.Struct({
    title: Schema.String.annotate({
      description: "Short headline shown as the notification title.",
    }),
    body: Schema.String.annotate({
      description: "Descriptive text shown beneath the title.",
    }),
    url: Schema.String.annotate({
      description: "The URL to deliver; tapping the notification opens it.",
    }),
    device_iden: Schema.optional(
      Schema.String.annotate({
        description:
          "Deliver only to one device, identified by its iden from " +
          "list_devices. Omit to broadcast to all of the user's devices.",
      }),
    ),
  }),
  success: Schema.Struct({
    iden: Schema.String,
    delivered: Schema.Boolean,
  }),
  failure: Schema.String,
})
  .annotate(Tool.Title, "Send Pushbullet Link")
  .annotate(Tool.Readonly, false)
  .annotate(Tool.Destructive, false)
  .annotate(Tool.Idempotent, false)
  .annotate(Tool.OpenWorld, true)

const ListDevices = Tool.make("list_devices", {
  description:
    "List the user's active Pushbullet devices and their idens. Use this to " +
    "discover which devices exist before targeting one, or when the user asks " +
    "where a notification can be sent. Returns each device's iden, which can " +
    "then be passed as device_iden to send_note or send_link to reach a single " +
    "device. Read-only: it does not send any notification.",
  parameters: Schema.Struct({}),
  success: Schema.Array(
    Schema.Struct({
      iden: Schema.String,
      nickname: Schema.optional(Schema.String),
      model: Schema.optional(Schema.String),
    }),
  ),
  failure: Schema.String,
})
  .annotate(Tool.Title, "List Pushbullet Devices")
  .annotate(Tool.Readonly, true)
  .annotate(Tool.Destructive, false)
  .annotate(Tool.Idempotent, true)
  .annotate(Tool.OpenWorld, true)

const PushbulletToolkit = Toolkit.make(SendNote, SendLink, ListDevices)

const ToolkitLayer = McpServer.toolkit(PushbulletToolkit).pipe(
  Layer.provideMerge(
    PushbulletToolkit.toLayer(
      Effect.gen(function* () {
        const pb = yield* Pushbullet
        return {
          send_note: ({ title, body, device_iden }) =>
            pb.sendNote({ title, body, device_iden }).pipe(
              Effect.map((r) => ({ iden: r.iden, delivered: r.active })),
              Effect.catchTag("PushbulletError", (e) => Effect.fail(e.message)),
            ),
          send_link: ({ title, body, url, device_iden }) =>
            pb.sendLink({ title, body, url, device_iden }).pipe(
              Effect.map((r) => ({ iden: r.iden, delivered: r.active })),
              Effect.catchTag("PushbulletError", (e) => Effect.fail(e.message)),
            ),
          list_devices: () =>
            pb.listDevices().pipe(
              Effect.map((devices) =>
                devices.map((d) => ({
                  iden: d.iden,
                  nickname: d.nickname,
                  model: d.model,
                }))
              ),
              Effect.catchTag("PushbulletError", (e) => Effect.fail(e.message)),
            ),
        }
      }),
    ),
  ),
  Layer.provide(Pushbullet.layer),
)

const ServerLayer = ToolkitLayer.pipe(
  Layer.provide(
    McpServer.layerStdio({
      name: "Pushbullet MCP",
      version: "1.0.0",
    }),
  ),
  Layer.provide(NodeStdio.layer),
  // stdout is the JSON-RPC channel, so logs must go to stderr.
  Layer.provide(Logger.layer([Logger.consolePretty({ stderr: true })])),
)

// `selftest`/`list-devices` exercise just the HTTP client (no stdio/RPC), so the
// client can be verified in isolation from the MCP protocol. Writes only to
// stderr and never starts the server, keeping stdout clean for the default path.
const runSelfTest = Effect.gen(function* () {
  const pb = yield* Pushbullet
  const devices = yield* pb.listDevices()
  yield* Effect.logInfo(`Pushbullet OK: ${devices.length} active device(s)`)
  for (const d of devices) {
    yield* Effect.logInfo(`  ${d.iden} ${d.nickname ?? "(no nickname)"} ${d.model ?? ""}`)
  }
}).pipe(
  Effect.provide(Pushbullet.layer),
  Effect.provide(Logger.layer([Logger.consolePretty({ stderr: true })])),
)

if (import.meta.main) {
  const command = Deno.args[0]
  if (command === "selftest" || command === "list-devices") {
    Effect.runPromiseExit(runSelfTest).then((exit) => {
      Deno.exit(exit._tag === "Success" ? 0 : 1)
    })
  } else {
    Layer.launch(ServerLayer).pipe(NodeRuntime.runMain)
  }
}

// ===========================================================================
// Testing. The HTTP client is the chief risk: does it reach Pushbullet,
// authenticate, and decode responses? Offline tests cover schema decode and
// tool annotations; the integration test hits the real API when a token is set.
//
//   deno test --allow-net=api.pushbullet.com --allow-env pushbullet-mcp
//
// Offline tests run unconditionally. The integration test is ignored unless
// PUSHBULLET_ACCESS_TOKEN is set, so the default run needs no secret. Provide a
// real token to exercise the live round-trip:
//   PUSHBULLET_ACCESS_TOKEN="$(bws-get-or-empty <uuid> "$(cat ~/.config/chezmoi/secrets/bws-access-token.txt)")" \
//     deno test --allow-net=api.pushbullet.com --allow-env pushbullet-mcp
//
// CLI smoke (same client path, human-readable) once the token is exported:
//   ./pushbullet-mcp selftest
//
// Two paths can only be checked manually:
//   - stdio contract: pipe a JSON-RPC `initialize` to `./pushbullet-mcp` and
//     confirm STDOUT carries ONLY JSON-RPC (logs must be on STDERR).
//   - mcpproxy e2e: after `chezmoi apply`, confirm the "pushbullet" server is
//     listed and a tool call works through your agent. If absent, the token did
//     not resolve — see .agents/rules/secrets-architecture.md / `dotfiles-setup`.
// ===========================================================================

const decodeNote = Schema.decodeUnknownSync(PushResult)
const decodeDevice = Schema.decodeUnknownSync(Device)
const decodeDevices = Schema.decodeUnknownSync(DevicesResponse)

// Minimal `@effect/vitest`-style adapter: run an Effect as a Deno test, failing
// the test if the Effect fails. `ignore` is evaluated before the body, so a
// skipped test never builds its layers (important: the integration test must
// not construct Pushbullet.layer when no token is present).
const itEffect = <E>(
  name: string,
  effect: Effect.Effect<unknown, E>,
  options?: { readonly ignore?: boolean },
) =>
  Deno.test({
    name,
    ignore: options?.ignore ?? false,
    fn: async () => {
      const exit = await Effect.runPromiseExit(effect)
      if (exit._tag === "Failure") {
        throw new Error(`Effect failed: ${JSON.stringify(exit.cause)}`)
      }
    },
  })

const assert = (cond: boolean, msg: string) =>
  cond ? Effect.void : Effect.fail(new Error(msg))

Deno.test("Device schema decodes a real /v2/devices entry", () => {
  const device = decodeDevice({
    iden: "ujpah72o0",
    nickname: "Galaxy S8",
    model: "SM-G950F",
    active: true,
    created: 1.49,
    pushable: true,
  })
  if (device.iden !== "ujpah72o0" || device.nickname !== "Galaxy S8") {
    throw new Error(`unexpected decode: ${JSON.stringify(device)}`)
  }
})

Deno.test("Device schema tolerates a missing nickname/model", () => {
  const device = decodeDevice({ iden: "x1", active: true })
  if (device.nickname !== undefined || device.model !== undefined) {
    throw new Error("optional fields should decode to undefined")
  }
})

Deno.test("DevicesResponse decodes the list envelope", () => {
  const res = decodeDevices({
    devices: [{ iden: "a", active: true }, { iden: "b", active: false }],
  })
  if (res.devices.length !== 2) throw new Error("expected 2 devices")
})

Deno.test("PushResult decodes a real /v2/pushes response", () => {
  const push = decodeNote({
    iden: "ujpah72o0sjAoRtnM0jc",
    type: "note",
    active: true,
    dismissed: false,
    title: "t",
    body: "b",
  })
  if (push.iden !== "ujpah72o0sjAoRtnM0jc" || push.active !== true) {
    throw new Error(`unexpected decode: ${JSON.stringify(push)}`)
  }
})

Deno.test("tool annotations encode the intended MCP permission hints", () => {
  const expected = {
    send_note: { readOnly: false, destructive: false, idempotent: false },
    send_link: { readOnly: false, destructive: false, idempotent: false },
    list_devices: { readOnly: true, destructive: false, idempotent: true },
  }
  for (const tool of [SendNote, SendLink, ListDevices]) {
    const e = expected[tool.name as keyof typeof expected]
    const a = tool.annotations
    if (
      Context.get(a, Tool.Readonly) !== e.readOnly ||
      Context.get(a, Tool.Destructive) !== e.destructive ||
      Context.get(a, Tool.Idempotent) !== e.idempotent ||
      Context.get(a, Tool.OpenWorld) !== true
    ) {
      throw new Error(`annotation mismatch for ${tool.name}`)
    }
  }
})

itEffect(
  "Config injection reads PUSHBULLET_ACCESS_TOKEN as a Redacted value [needs token]",
  Effect.gen(function* () {
    const token = yield* Config.redacted("PUSHBULLET_ACCESS_TOKEN")
    yield* assert(Redacted.isRedacted(token), "token did not resolve to a Redacted value")
    yield* assert(Redacted.value(token).length > 0, "token resolved but is empty")
    yield* assert(`${token}` === "<redacted>", "Redacted value leaked via string coercion")
  }),
  { ignore: !Deno.env.get("PUSHBULLET_ACCESS_TOKEN") },
)

itEffect(
  "HTTP client round-trips against the real Pushbullet API [needs token]",
  Effect.gen(function* () {
    const pb = yield* Pushbullet
    const devices = yield* pb.listDevices()
    yield* assert(Array.isArray(devices), "listDevices did not return an array")
  }).pipe(Effect.provide(Pushbullet.layer)),
  { ignore: !Deno.env.get("PUSHBULLET_ACCESS_TOKEN") },
)

// DESTRUCTIVE smoke: actually sends a note to the newest device. Double-gated —
// needs both a token AND PUSHBULLET_SMOKE_SEND=1 — so it never fires on a plain
// `deno test`, only when explicitly opted in:
//   PUSHBULLET_ACCESS_TOKEN=… PUSHBULLET_SMOKE_SEND=1 deno test --allow-net=api.pushbullet.com --allow-env pushbullet-mcp
itEffect(
  "sends a real note to the newest device [needs token + PUSHBULLET_SMOKE_SEND=1]",
  Effect.gen(function* () {
    const pb = yield* Pushbullet
    const devices = yield* pb.listDevices()
    yield* assert(devices.length > 0, "no devices to send to")

    // "Newest" = most recently created; fall back to list order when the API
    // omits `created` for a device.
    const newest = devices.reduce((a, b) => (b.created ?? 0) >= (a.created ?? 0) ? b : a)
    yield* Effect.logInfo(`Sending to newest device: ${newest.nickname ?? newest.iden}`)

    const result = yield* pb.sendNote({
      title: "a message left on the rooftops",
      body:
        "Heya you — slugcat says hi. Another cycle, another rain rolling in, and " +
        "here we still are, scurrying between the pipes. Eat your batflies, mind " +
        "your karma, and look to the moon when it all gets heavy. We'll make it " +
        "to the void sea eventually — no rush. Pebbles believes in you. (I do too.)",
      device_iden: newest.iden,
    })
    yield* assert(result.active, "push was created but not active")
  }).pipe(Effect.provide(Pushbullet.layer)),
  {
    ignore: !Deno.env.get("PUSHBULLET_ACCESS_TOKEN") ||
      Deno.env.get("PUSHBULLET_SMOKE_SEND") !== "1",
  },
)
