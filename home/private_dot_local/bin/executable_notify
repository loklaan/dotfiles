#!/usr/bin/env bash

#/ Usage:
#/   notify [OPTIONS] <message>
#/
#/ Description:
#/   Cross-platform desktop notification.
#/
#/   On macOS: prefers `terminal-notifier` when present (custom icons +
#/   brand identity); falls back to `osascript display notification`.
#/
#/   On Linux: uses `notify-send` from libnotify-bin / libnotify.
#/
#/ Options:
#/   --title <str>      Notification title (default: "Notification")
#/   --subtitle <str>   Notification subtitle (macOS / terminal-notifier only;
#/                      ignored on Linux + osascript fallback)
#/   --icon <path>      Absolute path to icon image (.png / .icns).
#/                      macOS terminal-notifier passes via -contentImage
#/                      (right-side thumbnail). The left-side app icon is
#/                      always terminal-notifier's default — macOS 14+ blocks
#/                      CLI customisation of the app-identity icon by design.
#/                      Linux notify-send passes via --icon.
#/                      osascript fallback ignores it (no AppleScript icon API).
#/   --sender <bundle>  macOS terminal-notifier only: borrow another app's
#/                      identity (e.g. com.apple.Terminal) so the notification
#/                      shows that app's icon. Useful when no --icon is set.
#/   --help             Display this help message
#/
#/ Examples:
#/   notify "Build complete"
#/   notify --title "dotfiles" --subtitle "drift" --icon ~/.local/share/dotfiles/icon.png "3 tools behind"
#/
#/ Exit codes:
#/   0   Notification dispatched
#/   1   Underlying notifier missing or failed
usage() { grep '^#/' "$0" | cut -c4- ; exit 0 ; }

TITLE="Notification"
SUBTITLE=""
ICON=""
SENDER=""

while [ "$#" -gt 0 ]; do
  case "$1" in
    --help) usage ;;
    --title) TITLE="$2"; shift 2 ;;
    --subtitle) SUBTITLE="$2"; shift 2 ;;
    --icon) ICON="$2"; shift 2 ;;
    --sender) SENDER="$2"; shift 2 ;;
    --) shift; break ;;
    -*) echo "notify: unknown option: $1" >&2; usage ;;
    *) break ;;
  esac
done

MESSAGE="${1:-}"

if [ -z "$MESSAGE" ]; then
  usage
fi

main() {
  case "$OSTYPE" in
    darwin*)
      if command -v terminal-notifier >/dev/null 2>&1; then
        local args=(-message "$MESSAGE" -title "$TITLE")
        [ -n "$SUBTITLE" ] && args+=(-subtitle "$SUBTITLE")
        [ -n "$ICON" ]     && args+=(-contentImage "$ICON")
        [ -n "$SENDER" ]   && args+=(-sender "$SENDER")
        terminal-notifier "${args[@]}"
        return $?
      fi

      # Fallback: osascript. No icon support, no subtitle support beyond AppleScript.
      local script="display notification \"$MESSAGE\" with title \"$TITLE\""
      [ -n "$SUBTITLE" ] && script="$script subtitle \"$SUBTITLE\""
      osascript -e "$script"
      ;;
    linux*)
      if ! command -v notify-send >/dev/null 2>&1; then
        echo "notify-send not found. Install libnotify-bin (apt) or libnotify (apk/yum)." >&2
        return 1
      fi
      local args=("$TITLE" "$MESSAGE")
      [ -n "$ICON" ] && args=(--icon "$ICON" "${args[@]}")
      notify-send "${args[@]}"
      ;;
    cygwin*|msys*)
      echo "Notifications not supported on $OSTYPE" >&2
      return 1
      ;;
    *)
      echo "Platform $OSTYPE not supported" >&2
      return 1
      ;;
  esac
}

main
