#!/usr/bin/env -S DENO_NO_PACKAGE_JSON=1 deno run -q --allow-run=coder,ssh,ssh-add,gpgconf,gpg,mise,jq,rsync,scp,du,tput,/opt/homebrew/opt/ncurses/bin/infocmp --allow-net --allow-read --allow-write --allow-env

// cw — Coder Workspaces CLI. Deno + Effect v4 rewrite of the original bash
// tool. Preserves the three public subcommands (`connect`, `fleet`, `migrate`),
// the bare workspace shorthand, and the zsh completion output.

import {
  Config,
  Console,
  Data,
  Effect,
  Layer,
  Schema,
  Sink,
  Stream,
} from "npm:effect@4.0.0-beta.83";
import {
  FileSystem,
  layerNoop as fileSystemLayerNoop,
} from "npm:effect@4.0.0-beta.83/FileSystem";
import { layer as pathLayer, Path } from "npm:effect@4.0.0-beta.83/Path";
import { Argument, Command, Flag } from "npm:effect@4.0.0-beta.83/unstable/cli";
import {
  ChildProcess,
  ChildProcessSpawner,
} from "npm:effect@4.0.0-beta.83/unstable/process";

const fatal = (msg: string): never => {
  console.error(`fatal ${msg}`);
  Deno.exit(1);
};

// ============================================================================
// Usage text
// ============================================================================

const TOP_USAGE = `Usage:
  cw <subcommand> [args...]
  cw <workspace> [mode] [directory]    (shorthand for \`cw connect ...\`)

Description:
  One-stop CLI for Coder dev boxes. Connect to a single workspace, fan a
  mise task across the whole fleet, or migrate working state between boxes.

Subcommands:
  connect <ws> [mode] [dir]   Attach to a workspace (ssh/vscode/claude/app)
  fleet [opts] <mise-task>    Run a mise task across running workspaces
  migrate [opts]              Pull working state from an old devbox to a new one
  completion zsh              Output zsh completion script

  Bare \`cw <workspace> ...\` is shorthand for \`cw connect <workspace> ...\`.

Examples:
  cw for-tasks                # SSH into for-tasks
  cw connect for-tasks-2 vscode
  cw fleet --include-local update
  cw migrate

Options:
  --help    Display this message (or \`cw <subcommand> --help\` for a subcommand)
`;

const CONNECT_USAGE = `Usage:
  cw connect <workspace> [mode] [directory]

Description:
  Connect to a Coder workspace in various modes. Built-in modes handle
  SSH, VSCode, and Claude Code sessions. Any other mode is passed through
  to \`coder open app\` as a workspace app slug (so like: intellij, cursor).

Arguments:
  workspace    Workspace name (e.g. for-tasks, for-tasks-2)
  mode         ssh (default), vscode, claude, ccyolo, or any app slug
               available on the coder box (cursor, intellij, code-server)
  directory    Project path on the remote (~/dev/me/<project>)

Examples:
  cw connect for-tasks                # SSH into for-tasks
  cw connect for-tasks-2 vscode       # Open in VS Code
  cw connect for-tasks-2 cursor       # Open Cursor via coder
  cw connect for-tasks-2 intellij     # Open IntelliJ via coder
  cw connect for-tasks code-server    # Open code-server in browser
  cw connect for-tasks claude         # SSH + Claude Code
  cw connect for-prs ccyolo           # YOLO mode
`;

const FLEET_USAGE = `Usage:
  cw fleet [OPTIONS] -- <mise-task> [args...]
  cw fleet [OPTIONS] <mise-task> [args...]

Description:
  Run a mise task on every running Coder workspace, in parallel.
  A small composable primitive, not a workflow-aware orchestrator.
  Whatever task you can \`mise run\` locally, you can run on the fleet.

  Discovery is dynamic via \`coder list -o json\` (filtered to running
  workspaces by default). No static inventory.

Options:
  --include-local       Also run the task on this machine (before the fleet)
  --local-only          Run only on this machine (skip the fleet)
  --filter <jq-expr>    jq filter against \`coder list -o json\`; output workspace names
                        (default: '.[] | select(.latest_build.status == "running") | .name')
  --parallel <N>        Max concurrent SSH targets (default: 4)
  --dry-run             Print the matrix; don't execute

Examples:
  cw fleet update                          # \`mise run update\` on every running box
  cw fleet --include-local update          # me first, then every box
  cw fleet --local-only drift:check        # local convergence only
  cw fleet --filter '.[] | select(.name == "for-tasks-1") | .name' update
  cw fleet --dry-run update                # preview the fan-out

Output:
  Per-host structured: [<ws>] ok | [<ws>] FAIL: <reason>
  Per-host stdout/stderr captured to $TMPDIR/cw-fleet-<ts>/<ws>.log
  Aggregate exit code = max of per-host codes (0 only if all succeeded)
`;

const MIGRATE_USAGE = `Usage:
  cw migrate [OPTIONS]

Description:
  Migrates working state from an old devbox to a new one.
  Run on the DESTINATION (new) devbox — it pulls from the source via SSH.

  Transfers small repos, shell history, tool configs, and editor state.
  Large repos should be re-cloned on the new devbox.

  Before transferring, audits source repos for unpushed branches to
  prevent data loss.

Default Migration Paths:
  dev/                          Small git repos
  .claude/                      Claude Code state
  .claude.json                  Claude Code config
  .zsh_history                  Shell history
  .z                            Directory jump history
  .local/share/tmux/resurrect   Tmux resurrect session snapshots

Default Audit Paths:
  dev/             Scanned recursively for git repos

Options:
  --manifest PATH:  Custom manifest file (default: ~/.config/cw-migrate/manifest)

Manifest Format (~/.config/cw-migrate/manifest):
  # Paths relative to $HOME
  [migrate]
  dev
  .claude
  .claude.json

  [audit]
  dev
`;

const ZSH_COMPLETION = String.raw`#compdef cw

_cw() {
  local -a subcommands
  subcommands=(
    'connect:Attach to a workspace (ssh/vscode/claude/app)'
    'fleet:Run a mise task across running workspaces'
    'migrate:Pull working state from an old devbox to a new one'
    'completion:Output shell completion script'
  )

  _cw_workspaces() {
    local -a workspaces
    if command -v coder >/dev/null 2>&1 && command -v jq >/dev/null 2>&1; then
      workspaces=("\${(@f)$(coder list -o json 2>/dev/null | jq -r '.[].name')}")
    fi
    _describe 'workspace' workspaces
  }

  _cw_modes() {
    local ws="$1"
    local -a modes=(
      'ssh:SSH into workspace'
      'vscode:Open in VS Code'
      'claude:SSH + Claude Code'
      'ccyolo:SSH + Claude Code YOLO mode'
    )
    if command -v coder >/dev/null 2>&1 && command -v jq >/dev/null 2>&1; then
      local -a apps
      apps=("\${(@f)$(coder list -o json 2>/dev/null | jq -r --arg ws "$ws" '
        .[] | select(.name == $ws)
        | .latest_build.resources[].agents[]?.apps[]?
        | .slug + ":" + .display_name
      ' 2>/dev/null)}")
      [[ \${#apps} -gt 0 && -n "\${apps[1]}" ]] && modes+=("\${apps[@]}")
    fi
    _describe 'mode' modes
  }

  _cw_mise_tasks() {
    local -a tasks
    if command -v mise >/dev/null 2>&1; then
      tasks=("\${(@f)$(mise tasks ls --no-header 2>/dev/null | awk '{print $1}')}")
    fi
    _describe 'mise task' tasks
  }

  local sub="\${words[2]}"

  case "$sub" in
    connect)
      case $CURRENT in
        3) _cw_workspaces ;;
        4) _cw_modes "$words[3]" ;;
        5) _message 'remote directory path (optional)' ;;
      esac
      ;;
    fleet)
      local -a fleet_opts=(
        '--include-local:Also run on this machine'
        '--local-only:Run only on this machine'
        '--filter:jq expression that outputs workspace names'
        '--parallel:Max concurrent SSH targets'
        '--dry-run:Print the matrix; do not execute'
      )
      if [[ "$words[CURRENT]" == -* ]]; then
        _describe 'option' fleet_opts
      else
        _cw_mise_tasks
      fi
      ;;
    migrate)
      _describe 'option' '(--manifest:Custom manifest file)'
      ;;
    completion)
      _describe 'shell' '(zsh:zsh completion)'
      ;;
    *)
      if [[ $CURRENT -eq 2 ]]; then
        _describe 'subcommand' subcommands
        _cw_workspaces
      elif [[ $CURRENT -eq 3 ]]; then
        _cw_modes "$words[2]"
      elif [[ $CURRENT -eq 4 ]]; then
        _message 'remote directory path (optional)'
      fi
      ;;
  esac
}

_cw "$@"
`;

// ============================================================================
// Small platform helpers
// ============================================================================

interface CommandResult {
  readonly code: number;
  readonly stdout: string;
  readonly stderr: string;
}

type StdioOption = "inherit" | "piped" | "null";

interface RunOptions {
  readonly stdin?: StdioOption;
  readonly stdout?: StdioOption;
  readonly stderr?: StdioOption;
  readonly input?: string;
  readonly cwd?: string;
}

const text = new TextEncoder();

const pipeInput = (value: string): Stream.Stream<Uint8Array> =>
  Stream.make(text.encode(value));

const stdinOption = (
  options: RunOptions,
): ChildProcess.CommandOptions["stdin"] =>
  options.input !== undefined
    ? pipeInput(options.input)
    : options.stdin === "inherit"
    ? "inherit"
    : options.stdin === "piped"
    ? "pipe"
    : "ignore";

const outputOption = (
  option: StdioOption | undefined,
): ChildProcess.CommandOptions["stdout"] =>
  option === "inherit" ? "inherit" : option === "null" ? "ignore" : "pipe";

const streamText = (stream: Stream.Stream<Uint8Array, unknown>) =>
  stream.pipe(
    Stream.decodeText(),
    Stream.runFold(() => "", (acc, chunk) => acc + chunk),
    Effect.orElseSucceed(() => ""),
  );

const runCommand = (
  spawner: ChildProcessSpawner.ChildProcessSpawner["Service"],
  cmd: string,
  args: ReadonlyArray<string>,
  options: RunOptions = {},
): Effect.Effect<CommandResult> =>
  Effect.gen(function* () {
    const handle = yield* spawner.spawn(
      ChildProcess.make(cmd, args, {
        cwd: options.cwd,
        stdin: stdinOption(options),
        stdout: outputOption(options.stdout),
        stderr: outputOption(options.stderr),
      }),
    );
    const collected = yield* Effect.all({
      stdout: streamText(handle.stdout),
      stderr: streamText(handle.stderr),
      code: handle.exitCode,
    }, { concurrency: "unbounded" });
    return {
      code: Number(collected.code),
      stdout: collected.stdout,
      stderr: collected.stderr,
    };
  }).pipe(
    Effect.scoped,
    Effect.orElseSucceed(() => ({ code: 127, stdout: "", stderr: "" })),
  );

const runChild = (
  cmd: string,
  args: ReadonlyArray<string>,
  options?: RunOptions,
): Effect.Effect<
  CommandResult,
  never,
  ChildProcessSpawner.ChildProcessSpawner
> =>
  Effect.gen(function* () {
    const spawner = yield* ChildProcessSpawner.ChildProcessSpawner;
    return yield* runCommand(spawner, cmd, args, options);
  });

const consoleValue = (value: string): string =>
  value.endsWith("\n") ? value.slice(0, -1) : value;

const writeStdout = (value: string): Effect.Effect<void> =>
  Console.log(consoleValue(value));

const writeStderr = (value: string): Effect.Effect<void> =>
  Console.error(consoleValue(value));

const logInfo = (value: string): Effect.Effect<void> =>
  writeStderr(`[INFO] ${value}\n`);

const logWarning = (value: string): Effect.Effect<void> =>
  writeStderr(`[WARN] ${value}\n`);

const logError = (value: string): Effect.Effect<void> =>
  writeStderr(`[ERROR] ${value}\n`);

const tmpdir = Config.string("TMPDIR").pipe(
  Config.withDefault("/tmp"),
  Effect.orDie,
  Effect.map((value) => value.replace(/\/$/, "")),
);

const home = Config.string("HOME").pipe(Config.withDefault(""), Effect.orDie);

const pad2 = (n: number): string => n.toString().padStart(2, "0");
const timestamp = (): string => {
  const d = new Date();
  return `${d.getFullYear()}${pad2(d.getMonth() + 1)}${pad2(d.getDate())}_` +
    `${pad2(d.getHours())}${pad2(d.getMinutes())}${pad2(d.getSeconds())}`;
};

const shellQuote = (value: string): string =>
  value === "" ? "''" : `'${value.replaceAll("'", `'\\''`)}'`;

const maxCode = (codes: ReadonlyArray<number>): number =>
  codes.reduce((max, code) => Math.max(max, code), 0);

const mkdirp = (path: string) =>
  Effect.gen(function* () {
    const fs = yield* FileSystem;
    yield* fs.makeDirectory(path, { recursive: true });
  }).pipe(
    Effect.mapError((cause) =>
      new Error(`failed to create ${path}: ${String(cause)}`)
    ),
  );

const writeTextFile = (
  path: string,
  value: string,
) =>
  Effect.gen(function* () {
    const fs = yield* FileSystem;
    yield* fs.writeFileString(path, value);
  }).pipe(
    Effect.mapError((cause) =>
      new Error(`failed to write ${path}: ${String(cause)}`)
    ),
  );

const readTextFile = (path: string) =>
  Effect.gen(function* () {
    const fs = yield* FileSystem;
    return yield* fs.readFileString(path);
  }).pipe(Effect.orElseSucceed(() => null));

const fileExists = (path: string) =>
  Effect.gen(function* () {
    const fs = yield* FileSystem;
    yield* fs.stat(path);
    return true;
  }).pipe(Effect.orElseSucceed(() => false));

const hasCommand = (cmd: string) =>
  Effect.gen(function* () {
    if (cmd.includes("/")) return yield* fileExists(cmd);
    const pathEnv = yield* Config.string("PATH").pipe(Config.withDefault(""));
    const path = yield* Path;
    for (const dir of pathEnv.split(":")) {
      if (dir !== "" && (yield* fileExists(path.join(dir, cmd)))) return true;
    }
    return false;
  }).pipe(Effect.orElseSucceed(() => false));

const requireCommand = (cmd: string, message: string) =>
  Effect.gen(function* () {
    if (!(yield* hasCommand(cmd))) fatal(message);
  });

// ============================================================================
// Coder JSON schema
// ============================================================================

const CoderWorkspace = Schema.Struct({
  name: Schema.String,
  latest_build: Schema.Struct({
    status: Schema.String,
    resources: Schema.optional(Schema.Array(Schema.Unknown)),
  }),
});
type CoderWorkspace = typeof CoderWorkspace.Type;

const CoderWorkspaces = Schema.Array(CoderWorkspace);
const decodeWorkspaces = Schema.decodeUnknownSync(CoderWorkspaces);

const parseJson = (value: string): unknown => JSON.parse(value) as unknown;

const coderListJson = (): Effect.Effect<
  string,
  Error,
  ChildProcessSpawner.ChildProcessSpawner
> =>
  runChild("coder", ["list", "-o", "json"]).pipe(
    Effect.flatMap((res) =>
      res.code === 0
        ? Effect.succeed(res.stdout)
        : Effect.fail(new Error("coder list failed"))
    ),
  );

const listCoderWorkspaces = (): Effect.Effect<
  ReadonlyArray<CoderWorkspace>,
  Error,
  ChildProcessSpawner.ChildProcessSpawner
> =>
  coderListJson().pipe(
    Effect.flatMap((json) =>
      Effect.try({
        try: () => decodeWorkspaces(parseJson(json)),
        catch: (cause) =>
          new Error(`failed to decode coder list: ${String(cause)}`),
      })
    ),
  );

const isRunning = (ws: CoderWorkspace): boolean =>
  ws.latest_build.status === "running";

const coderIsRunning = (name: string) =>
  listCoderWorkspaces().pipe(
    Effect.map((workspaces) =>
      workspaces.some((ws) => ws.name === name && isRunning(ws))
    ),
    Effect.orElseSucceed(() => false),
  );

// ============================================================================
// connect — HAND-OVER terminal attach
// ============================================================================

interface ConnectEnv {
  readonly log: boolean;
  readonly preflight: boolean;
  readonly checkCommands: boolean;
}

const defaultConnectEnv: ConnectEnv = {
  log: true,
  preflight: true,
  checkCommands: true,
};

const gpgSshOptionsFromPreflightOutput = (
  output: string,
  localSocket: string,
): ReadonlyArray<string> => {
  const options: string[] = [];
  for (const line of output.split(/\r?\n/)) {
    if (line.startsWith("GPG_SOCKET:")) {
      const remoteSocket = line.slice("GPG_SOCKET:".length);
      if (remoteSocket !== "" && localSocket !== "") {
        options.push("-o", "StreamLocalBindUnlink=yes");
        options.push("-o", `RemoteForward ${remoteSocket}:${localSocket}`);
      }
    } else if (line === "TERMINFO_OK:1") {
      options.push(
        "-o",
        "SendEnv TERM_PROGRAM -o SendEnv TERM_PROGRAM_VERSION -o SendEnv COLORTERM",
      );
    }
  }
  return options;
};

const coderPreflight = (
  env: ConnectEnv,
  host: string,
) =>
  Effect.gen(function* () {
    if (!env.preflight) return [];

    let script = "";
    let gpgLocalSocket = "";

    if ((yield* hasCommand("gpgconf")) && (yield* hasCommand("gpg"))) {
      const socketRes = yield* runChild("gpgconf", [
        "--list-dirs",
        "agent-extra-socket",
      ]);
      gpgLocalSocket = socketRes.code === 0 ? socketRes.stdout.trim() : "";
      if (gpgLocalSocket !== "") {
        yield* runChild("gpgconf", ["--launch", "gpg-agent"], {
          stdout: "null",
          stderr: "null",
        });
        const pubkeys = yield* runChild("gpg", ["--armor", "--export"], {
          stderr: "null",
        });
        const ownertrust = yield* runChild(
          "gpg",
          ["--export-ownertrust"],
          {
            stderr: "null",
          },
        );
        if (pubkeys.code === 0 && pubkeys.stdout !== "") {
          yield* logInfo("🔑  Forwarding GPG agent…");
          const pubkeysB64 = btoa(pubkeys.stdout);
          const ownertrustB64 = ownertrust.code === 0
            ? btoa(ownertrust.stdout)
            : "";
          script += `(
gpg_socket=$(gpgconf --list-dirs agent-socket 2>/dev/null) || exit 0
gpgconf --kill gpg-agent 2>/dev/null || true
[ -S "$gpg_socket" ] && rm -f "$gpg_socket"
sleep 1
printf '%s' '${pubkeysB64}' | base64 -d | gpg --batch --import 2>/dev/null || true
printf '%s' '${ownertrustB64}' | base64 -d | gpg --batch --import-ownertrust 2>/dev/null || true
gpgconf --kill gpg-agent 2>/dev/null || true
[ -S "$gpg_socket" ] && rm -f "$gpg_socket"
echo "GPG_SOCKET:${"${gpg_socket}"}"
)
`;
        }
      }
    }

    const ghosttyResources = yield* Config.string("GHOSTTY_RESOURCES_DIR").pipe(
      Config.withDefault(""),
    );
    if (ghosttyResources !== "") {
      const homebrewPrefix = yield* Config.string("HOMEBREW_PREFIX").pipe(
        Config.withDefault("/opt/homebrew"),
      );
      const path = yield* Path;
      const infocmp = path.join(homebrewPrefix, "opt/ncurses/bin/infocmp");
      if (yield* fileExists(infocmp)) {
        const terminfo = yield* runChild(
          infocmp,
          ["-x", "xterm-ghostty"],
          {
            stderr: "null",
          },
        );
        if (terminfo.code === 0 && terminfo.stdout !== "") {
          yield* logInfo("🖥️  Installing xterm-ghostty terminfo…");
          script += `(printf '%s' '${
            btoa(terminfo.stdout)
          }' | base64 -d | tic -x - 2>/dev/null && echo 'TERMINFO_OK:1' || echo 'TERMINFO_OK:0')\n`;
        }
      }
    }

    const sshAdd = yield* runChild("ssh-add", ["-L"], {
      stdout: "piped",
      stderr: "null",
    });
    if (sshAdd.code === 0) {
      yield* logInfo("🔑  Forwarding SSH public key…");
      script += `(
mkdir -p ~/.ssh
if ssh-add -L > ~/.ssh/id_rsa.pub 2>/dev/null; then
  chmod 644 ~/.ssh/id_rsa.pub
  echo "SSH_PUBKEY_OK:1"
else
  rm -f ~/.ssh/id_rsa.pub
  echo "SSH_PUBKEY_OK:0"
fi
)
`;
    }

    if (script === "") return [];

    const opts = ["-o", "ConnectTimeout=10"];
    const homeDir = yield* home;
    if (yield* fileExists(`${homeDir}/.ssh/coder.conf.sh`)) {
      opts.push("-o", "PermitLocalCommand=no", "-o", "ClearAllForwardings=yes");
    }
    const preflight = yield* runChild("ssh", [...opts, host, "/bin/sh"], {
      input: script,
      stdin: "piped",
      stdout: "piped",
      stderr: "null",
    });
    if (preflight.code !== 0) return [];
    return gpgSshOptionsFromPreflightOutput(preflight.stdout, gpgLocalSocket);
  }).pipe(Effect.orElseSucceed(() => []));

const connectCommand = (
  args: ReadonlyArray<string>,
  env: ConnectEnv = defaultConnectEnv,
) =>
  Effect.gen(function* () {
    if (args[0] === "--help") {
      yield* writeStdout(CONNECT_USAGE);
      return 0;
    }
    if (args.length < 1) {
      yield* writeStderr(CONNECT_USAGE);
      fatal("connect requires a workspace name");
    }
    if (env.checkCommands) {
      yield* requireCommand("coder", "coder CLI not found");
    }

    const ws = args[0];
    const mode = args[1] ?? "ssh";
    const directory = args[2] ?? "";

    if (!(yield* coderIsRunning(ws))) {
      yield* logInfo(`workspace '${ws}' is not running — starting it…`);
      const start = yield* runChild("coder", ["start", ws], {
        stdin: "inherit",
        stdout: "inherit",
        stderr: "inherit",
      });
      if (start.code !== 0) return start.code;
    }

    const host = `coder.${ws}`;
    const sshOpts = ["ssh", "claude", "ccyolo"].includes(mode)
      ? yield* coderPreflight(env, host)
      : [];

    switch (mode) {
      case "ssh": {
        const remote = directory === ""
          ? "/usr/bin/zsh -l"
          : `cd ${shellQuote(directory)} && /usr/bin/zsh -l`;
        const res = yield* runChild("ssh", [
          "-tt",
          ...sshOpts,
          host,
          remote,
        ], {
          stdin: "inherit",
          stdout: "inherit",
          stderr: "inherit",
        });
        return res.code;
      }
      case "vscode": {
        const vscodeArgs = ["open", "vscode", "--generate-token", ws];
        if (directory !== "") vscodeArgs.push(directory);
        yield* logInfo(
          `Opening VS Code: ${ws}${directory ? ` at ${directory}` : ""}`,
        );
        const res = yield* runChild("coder", vscodeArgs, {
          stdin: "inherit",
          stdout: "inherit",
          stderr: "inherit",
        });
        return res.code;
      }
      case "claude":
      case "ccyolo": {
        const base = mode === "claude"
          ? "claude"
          : "claude --dangerously-skip-permissions --permission-mode bypassPermissions --model global.anthropic.claude-opus-4-7";
        const cmd = directory === ""
          ? base
          : `cd ${shellQuote(directory)} && ${base}`;
        const res = yield* runChild("ssh", [
          "-tt",
          ...sshOpts,
          host,
          "/usr/bin/zsh",
          "-lc",
          cmd,
        ], {
          stdin: "inherit",
          stdout: "inherit",
          stderr: "inherit",
        });
        return res.code;
      }
      default: {
        yield* logInfo(`Opening ${mode}: ${ws}`);
        const res = yield* runChild("coder", ["open", "app", ws, mode], {
          stdin: "inherit",
          stdout: "inherit",
          stderr: "inherit",
        });
        return res.code;
      }
    }
  });

// ============================================================================
// fleet — bounded FAN-OUT
// ============================================================================

const DEFAULT_FLEET_FILTER =
  '.[] | select(.latest_build.status == "running") | .name';

interface FleetOptions {
  readonly includeLocal: boolean;
  readonly localOnly: boolean;
  readonly filter: string;
  readonly parallel: number;
  readonly dryRun: boolean;
  readonly taskAndArgs: ReadonlyArray<string>;
}

type FleetParseResult = Data.TaggedEnum<{
  Ok: { readonly options: FleetOptions };
  Help: Record<never, never>;
  Error: { readonly message: string };
}>;
const FleetParseResult = Data.taggedEnum<FleetParseResult>();

const fleetIncludeLocalFlag = Flag.boolean("include-local");
const fleetLocalOnlyFlag = Flag.boolean("local-only");
const fleetFilterFlag = Flag.string("filter").pipe(
  Flag.withDefault(DEFAULT_FLEET_FILTER),
);
const fleetParallelFlag = Flag.integer("parallel").pipe(Flag.withDefault(4));
const fleetDryRunFlag = Flag.boolean("dry-run");
const fleetTaskArgs = Argument.string("mise-task").pipe(Argument.variadic);
const fleetCli = Command.make("fleet", {
  includeLocal: fleetIncludeLocalFlag,
  localOnly: fleetLocalOnlyFlag,
  filter: fleetFilterFlag,
  parallel: fleetParallelFlag,
  dryRun: fleetDryRunFlag,
  taskAndArgs: fleetTaskArgs,
});

const parseFleetArgs = (args: ReadonlyArray<string>): FleetParseResult => {
  void fleetCli;
  let includeLocal = false;
  let localOnly = false;
  let filter = DEFAULT_FLEET_FILTER;
  let parallel = 4;
  let dryRun = false;
  let i = 0;
  while (i < args.length) {
    const arg = args[i];
    switch (arg) {
      case "--help":
        return FleetParseResult.Help();
      case "--include-local":
        includeLocal = true;
        i++;
        break;
      case "--local-only":
        localOnly = true;
        i++;
        break;
      case "--filter":
        if (args[i + 1] === undefined) {
          return FleetParseResult.Error({
            message: "--filter requires an expression",
          });
        }
        filter = args[i + 1];
        i += 2;
        break;
      case "--parallel": {
        if (args[i + 1] === undefined) {
          return FleetParseResult.Error({
            message: "--parallel requires a number",
          });
        }
        const parsed = Number.parseInt(args[i + 1], 10);
        if (!Number.isFinite(parsed) || parsed < 1) {
          return FleetParseResult.Error({
            message: "--parallel must be a positive integer",
          });
        }
        parallel = parsed;
        i += 2;
        break;
      }
      case "--dry-run":
        dryRun = true;
        i++;
        break;
      case "--":
        return FleetParseResult.Ok({
          options: {
            includeLocal,
            localOnly,
            filter,
            parallel,
            dryRun,
            taskAndArgs: args.slice(i + 1),
          },
        });
      default:
        if (arg.startsWith("-")) {
          return FleetParseResult.Error({ message: `Unknown option: ${arg}` });
        }
        return FleetParseResult.Ok({
          options: {
            includeLocal,
            localOnly,
            filter,
            parallel,
            dryRun,
            taskAndArgs: args.slice(i),
          },
        });
    }
  }
  return FleetParseResult.Ok({
    options: {
      includeLocal,
      localOnly,
      filter,
      parallel,
      dryRun,
      taskAndArgs: [],
    },
  });
};

interface FleetEnv {
  readonly checkCommands: boolean;
}

interface FleetTargetOk {
  readonly host: string;
  readonly code: 0;
  readonly logFile?: string;
}

interface FleetTargetFail {
  readonly host: string;
  readonly code: number;
  readonly logFile?: string;
}

type HostEither = Data.TaggedEnum<{
  Right: { readonly right: FleetTargetOk };
  Left: { readonly left: FleetTargetFail };
}>;
const HostEither = Data.taggedEnum<HostEither>();

const chooseDefaultFleetWorkspaces = (
  workspaces: ReadonlyArray<CoderWorkspace>,
): ReadonlyArray<string> => workspaces.filter(isRunning).map((ws) => ws.name);

const listFleetWorkspaces = (
  _env: FleetEnv,
  filter: string,
) =>
  Effect.gen(function* () {
    const json = yield* coderListJson();
    const workspaces = decodeWorkspaces(parseJson(json));
    if (filter === DEFAULT_FLEET_FILTER) {
      return chooseDefaultFleetWorkspaces(workspaces);
    }

    // Preserve the legacy --filter CLI as a jq expression. The JSON is still
    // schema-decoded first, so malformed coder output fails before jq runs.
    const jq = yield* runChild("jq", ["-r", filter], { input: json });
    if (jq.code !== 0) {
      return yield* Effect.fail(new Error(`jq filter failed (${jq.code})`));
    }
    return jq.stdout.split(/\r?\n/).map((line) => line.trim()).filter(Boolean);
  });

const fleetCommandString = (
  task: string,
  args: ReadonlyArray<string>,
): string =>
  [
    'export PATH="$HOME/.local/share/mise/shims:$HOME/.local/bin:$PATH"',
    `cd "$HOME/.local/share/chezmoi" && mise run ${shellQuote(task)} ${
      args.map(shellQuote).join(" ")
    }`.trimEnd(),
  ].join("; ");

const remoteZshCommand = (cmd: string): string =>
  `/usr/bin/zsh -lc ${shellQuote(cmd)}`;

const runFleetLocal = (
  _env: FleetEnv,
  options: FleetOptions,
  task: string,
  args: ReadonlyArray<string>,
) =>
  Effect.gen(function* () {
    yield* logInfo(
      `[local] mise run ${task} ${args.join(" ")}`.trimEnd(),
    );
    if (options.dryRun) {
      return HostEither.Right({ right: { host: "local", code: 0 } });
    }
    const res = yield* runChild("mise", ["run", task, ...args], {
      stdin: "inherit",
      stdout: "inherit",
      stderr: "inherit",
    });
    if (res.code === 0) {
      yield* writeStderr("[local] ok\n");
      return HostEither.Right({ right: { host: "local", code: 0 } });
    }
    yield* writeStderr(`[local] FAIL (${res.code})\n`);
    return HostEither.Left({
      left: { host: "local", code: res.code },
    });
  });

const runFleetRemote = (
  _env: FleetEnv,
  options: FleetOptions,
  ws: string,
  logDir: string,
  task: string,
  args: ReadonlyArray<string>,
) =>
  Effect.gen(function* () {
    const logFile = `${logDir}/${ws}.log`;
    const cmd = fleetCommandString(task, args);
    yield* logInfo(`[${ws}] ${cmd}`);
    if (options.dryRun) {
      return HostEither.Right({
        right: { host: ws, code: 0, logFile },
      });
    }
    const res = yield* runChild("ssh", [
      "-o",
      "ConnectTimeout=15",
      `coder.${ws}`,
      remoteZshCommand(cmd),
    ]);
    yield* writeTextFile(logFile, res.stdout + res.stderr);
    if (res.code === 0) {
      yield* writeStderr(`[${ws}] ok\n`);
      return HostEither.Right({
        right: { host: ws, code: 0, logFile },
      });
    }
    yield* writeStderr(`[${ws}] FAIL (${res.code}) — see ${logFile}\n`);
    return HostEither.Left({
      left: { host: ws, code: res.code, logFile },
    });
  });

const fleetResultCode = (results: ReadonlyArray<HostEither>): number =>
  maxCode(
    results.map((result) =>
      result._tag === "Right" ? result.right.code : result.left.code
    ),
  );

const fleetCommand = (
  args: ReadonlyArray<string>,
  env: FleetEnv = { checkCommands: true },
) =>
  Effect.gen(function* () {
    const parsed = parseFleetArgs(args);
    if (parsed._tag === "Help") {
      yield* writeStdout(FLEET_USAGE);
      return 0;
    }
    if (parsed._tag === "Error") {
      yield* writeStderr(FLEET_USAGE);
      return fatal(parsed.message);
    }
    const options = parsed.options;
    if (options.taskAndArgs.length === 0) {
      yield* writeStderr(FLEET_USAGE);
      fatal("no mise task specified");
    }

    if (env.checkCommands) yield* requireCommand("mise", "mise not on PATH");
    if (env.checkCommands && !options.localOnly) {
      yield* requireCommand(
        "coder",
        "coder CLI not found (needed for fleet dispatch)",
      );
      if (options.filter !== DEFAULT_FLEET_FILTER) {
        yield* requireCommand("jq", "jq not found");
      }
    }

    const [task, ...taskArgs] = options.taskAndArgs;
    const tmp = yield* tmpdir;
    const logDir = `${tmp}/cw-fleet-${timestamp()}`;
    return yield* Effect.acquireRelease(
      mkdirp(logDir).pipe(Effect.as(logDir)),
      () => Effect.void,
    ).pipe(
      Effect.flatMap((scopedLogDir) =>
        runFleetWithLogDir(env, options, task, taskArgs, scopedLogDir)
      ),
      Effect.scoped,
    );
  });

const runFleetWithLogDir = (
  env: FleetEnv,
  options: FleetOptions,
  task: string,
  taskArgs: ReadonlyArray<string>,
  logDir: string,
) =>
  Effect.gen(function* () {
    const localResults: HostEither[] = [];
    if (options.includeLocal || options.localOnly) {
      localResults.push(yield* runFleetLocal(env, options, task, taskArgs));
    }

    if (options.localOnly) {
      return fleetResultCode(localResults);
    }

    const workspaces = yield* listFleetWorkspaces(env, options.filter);
    if (workspaces.length === 0) {
      yield* logWarning("no running workspaces matched filter");
      return fleetResultCode(localResults);
    }

    yield* logInfo(
      `fan-out: ${workspaces.length} workspace(s) · parallelism=${options.parallel} · log_dir=${logDir}`,
    );
    const remoteResults = yield* Effect.forEach(
      workspaces,
      (ws) => runFleetRemote(env, options, ws, logDir, task, taskArgs),
      { concurrency: options.parallel },
    );

    const code = fleetResultCode([...localResults, ...remoteResults]);
    if (code === 0) {
      yield* writeStdout("cw fleet: all targets ok\n");
    } else {
      yield* writeStdout(
        `cw fleet: completed with ${code} max-rc — inspect ${logDir}\n`,
      );
    }
    return code;
  });

// ============================================================================
// migrate — supervised subprocess workflow
// ============================================================================

const MIGRATE_DEFAULT_PATHS = [
  "dev",
  ".claude",
  ".claude.json",
  ".zsh_history",
  ".z",
  ".local/share/tmux/resurrect",
];

const MIGRATE_DEFAULT_AUDIT_PATHS = ["dev"];

interface MigrateManifest {
  readonly migrate: ReadonlyArray<string>;
  readonly audit: ReadonlyArray<string>;
}

interface MigrateState extends MigrateManifest {
  readonly sourceHost: string;
  readonly existingPaths: ReadonlyArray<string>;
}

const defaultManifestPath = home.pipe(
  Effect.map((homeDir) => `${homeDir}/.config/cw-migrate/manifest`),
);

type MigrateParseResult = Data.TaggedEnum<{
  Ok: { readonly manifestPath: string };
  Help: Record<never, never>;
  Error: { readonly message: string };
}>;
const MigrateParseResult = Data.taggedEnum<MigrateParseResult>();

const migrateManifestFlag = Flag.string("manifest").pipe(
  Flag.withDescription("Custom manifest file"),
);
const migrateCli = Command.make("migrate", { manifest: migrateManifestFlag });

const parseMigrateArgs = (
  args: ReadonlyArray<string>,
): Effect.Effect<MigrateParseResult> =>
  Effect.gen(function* () {
    void migrateCli;
    let manifest = yield* defaultManifestPath;
    for (let i = 0; i < args.length; i++) {
      switch (args[i]) {
        case "--manifest":
          if (args[i + 1] === undefined) {
            return MigrateParseResult.Error({
              message: "--manifest requires a path argument",
            });
          }
          manifest = args[i + 1];
          i++;
          break;
        case "--help":
          return MigrateParseResult.Help();
        default:
          return MigrateParseResult.Error({
            message: `Unknown argument: ${args[i]}`,
          });
      }
    }
    return MigrateParseResult.Ok({ manifestPath: manifest });
  });

const parseManifest = (content: string): MigrateManifest => {
  let section = "";
  const migrate: string[] = [];
  const audit: string[] = [];
  for (const raw of content.split(/\r?\n/)) {
    const line = raw.replace(/#.*$/, "").trim();
    if (line === "") continue;
    const heading = /^\[(.+)]$/.exec(line);
    if (heading) {
      section = heading[1];
      continue;
    }
    if (section === "migrate") migrate.push(line);
    else if (section === "audit") audit.push(line);
    else console.error(`warning Unknown manifest section: [${section}]`);
  }
  if (migrate.length === 0) fatal("Manifest has no [migrate] entries");
  return { migrate, audit };
};

const loadMigrateManifest = (
  manifestPath: string,
) =>
  Effect.gen(function* () {
    const content = yield* readTextFile(manifestPath);
    if (content === null) {
      if (manifestPath === (yield* defaultManifestPath)) {
        yield* logInfo("╍ No manifest found, using defaults");
        return {
          migrate: MIGRATE_DEFAULT_PATHS,
          audit: MIGRATE_DEFAULT_AUDIT_PATHS,
        };
      }
      return fatal(`Manifest not found: ${manifestPath}`);
    }
    yield* logInfo(`╍ Loading manifest from ${manifestPath}`);
    return parseManifest(content);
  });

const promptRequired = (label: string): string => {
  const value = prompt(label) ?? "";
  return value.trim();
};

type MigrateSourceConnection = Data.TaggedEnum<{
  Connected: { readonly sourceHost: string };
  Failed: Record<never, never>;
}>;
const MigrateSourceConnection = Data.taggedEnum<MigrateSourceConnection>();

const connectMigrateSource = () =>
  Effect.gen(function* () {
    yield* writeStdout("\nSource devbox\n\n");
    yield* writeStdout("Enter the SSH host of the OLD devbox to pull from.\n");
    yield* writeStdout("  - Coder devbox:  coder.<workspace-name>\n");
    yield* writeStdout("  - Any SSH host:  user@hostname\n\n");
    const sourceHost = promptRequired("Source host: ");
    if (sourceHost === "") fatal("No source host specified");
    yield* logInfo(`▶ Testing SSH connection to ${sourceHost}`);
    const res = yield* runChild("ssh", [
      "-o",
      "ConnectTimeout=10",
      sourceHost,
      "echo ok",
    ], {
      stdout: "null",
      stderr: "null",
    });
    if (res.code !== 0) {
      yield* logError(`Cannot connect to ${sourceHost}`);
      yield* writeStderr("Try: coder config-ssh\n");
      return MigrateSourceConnection.Failed();
    }
    yield* logInfo("╍ Connection OK");
    return MigrateSourceConnection.Connected({ sourceHost });
  });

const remoteHereDoc = (values: ReadonlyArray<string>): string =>
  values.join("\n");

const auditRepos = (
  sourceHost: string,
  auditPaths: ReadonlyArray<string>,
) =>
  Effect.gen(function* () {
    if (auditPaths.length === 0) {
      yield* logInfo("╍ No audit paths configured, skipping repo check");
      return 0;
    }
    yield* writeStdout("\nChecking source repos for unpushed branches...\n\n");
    const paths = remoteHereDoc(auditPaths);
    const script = `set -euo pipefail
audit_paths=()
while IFS= read -r p; do
  [[ -z "\${p}" ]] && continue
  audit_paths+=("\${p}")
done <<< ${shellQuote(paths)}
for audit_path in "\${audit_paths[@]}"; do
  full_path="\${HOME}/\${audit_path}"
  if [[ ! -d "\${full_path}" ]]; then continue; fi
  while IFS= read -r git_dir; do
    [[ -z "\${git_dir}" ]] && continue
    repo_dir=$(dirname "\${git_dir}")
    repo_rel="\${repo_dir#\${HOME}/}"
    has_issues=false
    while IFS= read -r branch; do
      [[ -z "\${branch}" ]] && continue
      upstream_ref=$(git -C "\${repo_dir}" rev-parse --abbrev-ref "\${branch}@{upstream}" 2>/dev/null || true)
      if [[ -z "\${upstream_ref}" ]]; then
        echo "ISSUE|\${repo_rel}|\${branch} (no remote tracking branch)"
        has_issues=true
      else
        ahead_count=$(git -C "\${repo_dir}" rev-list --count "\${upstream_ref}..\${branch}" 2>/dev/null || echo "0")
        if [[ "\${ahead_count}" -gt 0 ]]; then
          echo "ISSUE|\${repo_rel}|\${branch} (\${ahead_count} unpushed commit(s))"
          has_issues=true
        fi
      fi
    done < <(git -C "\${repo_dir}" for-each-ref --format='%(refname:short)' refs/heads/)
    if [[ "\${has_issues}" == "false" ]]; then echo "OK|\${repo_rel}"; fi
  done < <(find "\${full_path}" -name .git -type d 2>/dev/null)
done
`;
    const res = yield* runChild("ssh", [sourceHost, "bash", "-s"], {
      input: script,
    });
    const output = res.stdout.trim();
    if (output === "") {
      yield* logInfo("╍ No git repos found in audit paths");
      return 0;
    }
    let hasUnpushed = false;
    let currentRepo = "";
    for (const line of output.split(/\r?\n/)) {
      const [status, repoPath, detail] = line.split("|");
      if (status === "OK") {
        yield* writeStdout(`  ~/${repoPath} — all branches pushed\n`);
      }
      if (status === "ISSUE") {
        if (repoPath !== currentRepo) {
          yield* writeStdout(`  ~/${repoPath}\n`);
          currentRepo = repoPath;
        }
        yield* writeStdout(`    [ ] ${detail}\n`);
        hasUnpushed = true;
      }
    }
    yield* writeStdout("\n");
    if (hasUnpushed) {
      yield* logWarning(
        "Unpushed branches found! Push them first or they will be lost.",
      );
      const confirm = promptRequired("Continue anyway? [y/N]: ");
      if (confirm !== "y" && confirm !== "Y") {
        yield* logInfo(
          "Aborted. Push branches on the source and re-run.",
        );
        return 1;
      }
    } else {
      yield* logInfo("╍ All repo branches are pushed");
    }
    return 0;
  });

const validateMigratePaths = (
  sourceHost: string,
  paths: ReadonlyArray<string>,
) =>
  Effect.gen(function* () {
    const script = `set -euo pipefail
while IFS= read -r path; do
  [[ -z "\${path}" ]] && continue
  if [[ -e "\${HOME}/\${path}" ]]; then echo "EXISTS|\${path}"; else echo "MISSING|\${path}"; fi
done <<< ${shellQuote(remoteHereDoc(paths))}
`;
    const res = yield* runChild("ssh", [sourceHost, "bash", "-s"], {
      input: script,
    });
    const existing: string[] = [];
    for (const line of res.stdout.split(/\r?\n/)) {
      const [status, path] = line.split("|");
      if (status === "EXISTS") existing.push(path);
      if (status === "MISSING") {
        yield* logWarning(`Not found on source: ~/${path}`);
      }
    }
    yield* logInfo(
      `╍ Found ${existing.length}/${paths.length} items to migrate`,
    );
    if (existing.length === 0) fatal("Nothing to migrate!");
    return existing;
  });

const showMigrateSummary = (
  sourceHost: string,
  paths: ReadonlyArray<string>,
) =>
  Effect.gen(function* () {
    yield* writeStdout("\nItems to migrate:\n\n");
    const script = `set -euo pipefail
size_args=()
while IFS= read -r path; do
  [[ -z "\${path}" ]] && continue
  size=$(du -sh "\${HOME}/\${path}" 2>/dev/null | cut -f1)
  echo "\${path}|\${size}"
  size_args+=("\${HOME}/\${path}")
done <<< ${shellQuote(remoteHereDoc(paths))}
total=$(du -shc "\${size_args[@]}" 2>/dev/null | tail -1 | cut -f1)
echo "TOTAL|\${total}"
`;
    const res = yield* runChild("ssh", [sourceHost, "bash", "-s"], {
      input: script,
    });
    for (const line of res.stdout.split(/\r?\n/)) {
      if (line === "") continue;
      const [path, size] = line.split("|");
      if (path === "TOTAL") yield* writeStdout(`\n  Total: ${size}\n`);
      else yield* writeStdout(`  ${`~/${path}`.padEnd(45)} ${size}\n`);
    }
    yield* writeStdout("\n");
  });

const parentOf = (path: string): string => {
  const idx = path.lastIndexOf("/");
  return idx === -1 ? "." : path.slice(0, idx);
};

const doRsync = (state: MigrateState) =>
  Effect.gen(function* () {
    yield* writeStdout("\n");
    yield* logWarning(
      "This will overwrite matching paths locally. Continue? [y/N]",
    );
    const confirm = promptRequired("");
    if (confirm !== "y" && confirm !== "Y") {
      yield* logInfo("Aborted");
      return 0;
    }
    yield* logInfo("▶ Creating local directory structure");
    for (const path of state.existingPaths) {
      const parent = parentOf(path);
      const homeDir = yield* home;
      if (parent !== ".") yield* mkdirp(`${homeDir}/${parent}`);
    }
    let failed = 0;
    for (const path of state.existingPaths) {
      const parent = parentOf(path);
      const homeDir = yield* home;
      const localDir = parent === "." ? `${homeDir}/` : `${homeDir}/${parent}/`;
      yield* logInfo(`╍ Pulling ~/${path}`);
      const res = yield* runChild("rsync", [
        "-az",
        `${state.sourceHost}:~/${path}`,
        localDir,
      ], {
        stdin: "inherit",
        stdout: "inherit",
        stderr: "inherit",
      });
      if (res.code === 0) yield* writeStdout("    done\n");
      else {
        yield* logError(`Failed to pull ~/${path}`);
        failed++;
      }
    }
    yield* writeStdout("\n");
    if (failed === 0) {
      yield* logInfo(
        `▶ Migration complete! All ${state.existingPaths.length} items pulled.`,
      );
    } else {
      yield* logWarning(`Migration finished with ${failed} failure(s)`);
    }
    return failed === 0 ? 0 : 1;
  });

const doTar = (state: MigrateState) =>
  Effect.gen(function* () {
    const archiveName = `devbox-migration-${timestamp()}.tar.gz`;
    const remoteArchive = `/tmp/${archiveName}`;
    yield* writeStdout("\nCreating tar archive on source\n\n");
    const script = `set -euo pipefail
paths=()
while IFS= read -r path; do
  [[ -z "\${path}" ]] && continue
  paths+=("\${path}")
done <<< ${shellQuote(remoteHereDoc(state.existingPaths))}
tar -czf ${shellQuote(remoteArchive)} -C "\${HOME}" "\${paths[@]}"
`;
    yield* logInfo(`▶ Creating archive on ${state.sourceHost}`);
    let res = yield* runChild("ssh", [state.sourceHost, "bash", "-s"], {
      input: script,
      stdin: "piped",
      stdout: "inherit",
      stderr: "inherit",
    });
    if (res.code !== 0) return res.code;
    yield* logInfo("╍ Pulling archive");
    res = yield* runChild("scp", [
      `${state.sourceHost}:${remoteArchive}`,
      `/tmp/${archiveName}`,
    ], {
      stdin: "inherit",
      stdout: "inherit",
      stderr: "inherit",
    });
    if (res.code !== 0) return res.code;
    const size = yield* runChild("du", ["-sh", `/tmp/${archiveName}`]);
    yield* logInfo(
      `╍ Archive saved: /tmp/${archiveName} (${
        size.stdout.split(/\s+/, 1)[0] ?? "?"
      })`,
    );
    yield* writeStdout(
      "\nTo extract:\n  cd ~ && tar -xzf /tmp/${archiveName}\n\n",
    );
    yield* logInfo("╍ Cleaning up remote archive");
    yield* runChild("ssh", [state.sourceHost, "rm", "-f", remoteArchive]);
    return 0;
  });

const doChecklist = (state: MigrateState) =>
  Effect.gen(function* () {
    yield* writeStdout("\nMigration Checklist\n\n");
    yield* writeStdout(
      `Pull these paths from ${state.sourceHost}:~ to local ~:\n\n`,
    );
    for (const path of state.existingPaths) {
      yield* writeStdout(`  [ ] ~/${path}\n`);
    }
    yield* writeStdout("\nExample for each:\n");
    yield* writeStdout(`  rsync -az ${state.sourceHost}:~/PATH ~/PATH\n\n`);
    yield* writeStdout("After copying:\n\n");
    yield* writeStdout("  [ ] Run chezmoi apply to restore dotfiles\n");
    yield* writeStdout("  [ ] Verify git repos have correct remotes\n\n");
    return 0;
  });

const migrateCommand = (
  args: ReadonlyArray<string>,
) =>
  Effect.gen(function* () {
    const parsed = yield* parseMigrateArgs(args);
    if (parsed._tag === "Help") {
      yield* writeStdout(MIGRATE_USAGE);
      return 0;
    }
    if (parsed._tag === "Error") {
      yield* writeStderr(MIGRATE_USAGE);
      return fatal(parsed.message);
    }
    const manifestPath = parsed.manifestPath;
    yield* writeStdout("\nDevbox Migration\n\n");
    const manifest = yield* loadMigrateManifest(manifestPath);
    const sourceConnection: MigrateSourceConnection =
      yield* connectMigrateSource();
    if (sourceConnection._tag === "Failed") return 1;
    const sourceHost = sourceConnection.sourceHost;
    const auditCode = yield* auditRepos(sourceHost, manifest.audit);
    if (auditCode !== 0) return 0;
    const existingPaths = yield* validateMigratePaths(
      sourceHost,
      manifest.migrate,
    );
    yield* showMigrateSummary(sourceHost, existingPaths);
    const state: MigrateState = { ...manifest, sourceHost, existingPaths };
    yield* writeStdout("Transfer method\n\n");
    yield* writeStdout("  1) rsync  — pull directly over SSH\n");
    yield* writeStdout(
      "  2) tar    — archive on source, pull here, extract manually\n",
    );
    yield* writeStdout("  3) list   — just show what to copy\n\n");
    const choice = promptRequired("Choose [1/2/3]: ");
    const code = choice === "1"
      ? yield* doRsync(state)
      : choice === "2"
      ? yield* doTar(state)
      : choice === "3"
      ? yield* doChecklist(state)
      : (() => fatal(`Invalid choice: ${choice}`))();
    yield* writeStdout("\n");
    yield* logWarning(
      "Credentials are NOT included — migrate these yourself:",
    );
    yield* writeStdout("  ~/.ssh/  ~/.aws/  ~/.gnupg/  ~/.npmrc\n\n");
    yield* logWarning(
      "Run chezmoi apply on this devbox to restore dotfiles.",
    );
    yield* writeStdout("\n");
    return code;
  });

// ============================================================================
// main
// ============================================================================

const main = (args: ReadonlyArray<string>) =>
  Effect.gen(function* () {
    if (args.length < 1) {
      yield* writeStdout(TOP_USAGE);
      return 1;
    }
    const [command, ...rest] = args;
    switch (command) {
      case "--help":
      case "help":
        yield* writeStdout(TOP_USAGE);
        return 0;
      case "completion":
        if (rest[0] === "zsh") {
          yield* writeStdout(ZSH_COMPLETION);
          return 0;
        }
        yield* writeStderr(TOP_USAGE);
        fatal(`Unknown completion shell: ${rest[0] ?? ""}. Supported: zsh`);
        return 1;
      case "connect":
        return yield* connectCommand(rest);
      case "fleet":
        return yield* fleetCommand(rest);
      case "migrate":
        return yield* migrateCommand(rest);
      default:
        if (command.startsWith("-")) {
          yield* writeStderr(TOP_USAGE);
          fatal(`Unknown option: ${command}`);
        }
        return yield* connectCommand(args);
    }
  });

if (import.meta.main) {
  // Last-resort backstop: catch anything that escapes the Effect runtime
  // (raw node-stream callbacks, forked-fiber defects, unhandled rejections).
  // NodeRuntime.runMain does NOT install these (only SIGINT/SIGTERM) — verified
  // against effect-smol source. Inside import.meta.main so `deno test` stays hermetic.
  globalThis.addEventListener("unhandledrejection", (event) => {
    event.preventDefault();
    console.error(`error uncaught rejection: ${event.reason}`);
    Deno.exit(1);
  });
  globalThis.addEventListener("error", (event) => {
    event.preventDefault();
    console.error(`error uncaught: ${event.message}`);
    Deno.exit(1);
  });

  const command = Deno.args[0];
  const serviceFree = command === undefined || command === "--help" ||
    command === "help" ||
    (command === "connect" && Deno.args[1] === "--help") ||
    (command === "fleet" && Deno.args[1] === "--help") ||
    (command === "migrate" && Deno.args[1] === "--help") ||
    (command === "completion" && Deno.args[1] === "zsh");
  const program = serviceFree ? main(Deno.args) : Effect.promise(async () => {
    const childProcess = await import("node:child_process");
    const fs = await import("node:fs/promises");
    const nodeFileSystemLayer = fileSystemLayerNoop({
      makeDirectory: (path, options) =>
        Effect.tryPromise({
          try: () =>
            fs.mkdir(path, {
              recursive: options?.recursive,
              mode: options?.mode,
            }),
          catch: (cause) => cause as never,
        }).pipe(Effect.asVoid),
      readFileString: (path, encoding = "utf8") =>
        Effect.tryPromise({
          try: () =>
            fs.readFile(path, { encoding: encoding as BufferEncoding }),
          catch: (cause) => cause as never,
        }),
      stat: (path) =>
        Effect.tryPromise({
          try: () => fs.stat(path),
          catch: (cause) => cause as never,
        }).pipe(Effect.map((stat) => stat as never)),
      writeFileString: (path, content) =>
        Effect.tryPromise({
          try: () => fs.writeFile(path, content),
          catch: (cause) => cause as never,
        }).pipe(Effect.asVoid),
    });
    const nodeChildProcessLayer = Layer.succeed(
      ChildProcessSpawner.ChildProcessSpawner,
      ChildProcessSpawner.make((command) =>
        Effect.gen(function* () {
          if (!ChildProcess.isStandardCommand(command)) {
            return yield* Effect.fail(
              new Error("piped commands are unsupported") as never,
            );
          }
          const stdin = command.options.stdin ?? "pipe";
          const stdout = command.options.stdout ?? "pipe";
          const stderr = command.options.stderr ?? "pipe";
          const stdio = [
            stdin === "inherit"
              ? "inherit"
              : stdin === "ignore"
              ? "ignore"
              : "pipe",
            stdout === "inherit"
              ? "inherit"
              : stdout === "ignore"
              ? "ignore"
              : "pipe",
            stderr === "inherit"
              ? "inherit"
              : stderr === "ignore"
              ? "ignore"
              : "pipe",
          ];
          const child = childProcess.spawn(command.command, [...command.args], {
            cwd: command.options.cwd,
            detached: command.options.detached,
            env: command.options.extendEnv === false
              ? command.options.env as NodeJS.ProcessEnv | undefined
              : { ...process.env, ...command.options.env },
            shell: command.options.shell,
            stdio: stdio as never,
          }) as unknown as {
            readonly pid?: number;
            readonly exitCode: number | null;
            readonly stdin: NodeJS.WritableStream | null;
            readonly stdout: NodeJS.ReadableStream | null;
            readonly stderr: NodeJS.ReadableStream | null;
            once(event: "exit", listener: (code: number | null) => void): void;
            once(event: "error", listener: () => void): void;
            kill(signal?: NodeJS.Signals): boolean;
            unref(): void;
            ref(): void;
          };
          if (typeof stdin !== "string" && child.stdin !== null) {
            // A broken stdin pipe (remote shell closes its end before we
            // finish writing) surfaces as an async 'error' event on the
            // stream, separately from the write() callback. An unhandled
            // 'error' on a Node stream throws as an uncaught exception
            // ("write EPIPE"), so attach a swallowing listener — the write
            // callback below already resolves EPIPE/closed-stream cleanly.
            child.stdin.on("error", () => {});
            yield* (stdin as Stream.Stream<Uint8Array>).pipe(
              Stream.runForEach((chunk) =>
                Effect.promise(() =>
                  new Promise<void>((resolve, reject) => {
                    child.stdin!.write(
                      chunk,
                      (error?: Error | null) => {
                        if (!error) return resolve();
                        const code = (error as NodeJS.ErrnoException)?.code;
                        if (
                          code === "EPIPE" ||
                          code === "ERR_STREAM_DESTROYED" ||
                          code === "ERR_STREAM_WRITE_AFTER_END"
                        ) {
                          return resolve();
                        }
                        reject(error);
                      },
                    );
                  })
                )
              ),
              Effect.ensuring(
                Effect.sync(() => {
                  try {
                    child.stdin?.end();
                  } catch {
                    // already closed
                  }
                }),
              ),
              Effect.catchCause(() => Effect.void),
              Effect.forkChild,
            );
          }
          const exitCode = Effect.promise(() =>
            new Promise<number>((resolve) => {
              child.once("exit", (code) => resolve(code ?? 1));
              child.once("error", () => resolve(127));
            })
          ).pipe(Effect.map(ChildProcessSpawner.ExitCode));
          const outputStream = (stream: NodeJS.ReadableStream | null) =>
            stream === null ? Stream.empty : Stream.fromAsyncIterable(
              stream as AsyncIterable<Uint8Array>,
              (cause) => cause as never,
            );
          return ChildProcessSpawner.makeHandle({
            pid: ChildProcessSpawner.ProcessId(child.pid ?? 0),
            exitCode,
            isRunning: Effect.sync(() => child.exitCode === null),
            kill: (options) =>
              Effect.sync(() =>
                void child.kill(options?.killSignal ?? "SIGTERM")
              ),
            stdin: Sink.drain,
            stdout: outputStream(child.stdout),
            stderr: outputStream(child.stderr),
            all: Stream.empty,
            getInputFd: () => Sink.drain,
            getOutputFd: () => Stream.empty,
            unref: Effect.sync(() => {
              child.unref();
              return Effect.sync(() => child.ref());
            }),
          });
        })
      ),
    );
    return Layer.mergeAll(
      nodeChildProcessLayer,
      nodeFileSystemLayer,
      pathLayer,
    );
  })
    .pipe(
      Effect.flatMap((runtimeLayer) =>
        main(Deno.args).pipe(Effect.provide(runtimeLayer))
      ),
    );
  Effect.runPromiseExit(program as Effect.Effect<number, Error>).then(
    (exit) => {
      if (exit._tag === "Success") Deno.exit(exit.value);
      console.error(exit.cause);
      Deno.exit(1);
    },
  ).catch((err) => {
    console.error(err);
    Deno.exit(1);
  });
}

// ============================================================================
// Tests — pure/mocked. Must pass offline:
//   deno test home/private_dot_local/bin/executable_cw
// ============================================================================

const assertEq = <T>(actual: T, expected: T): void => {
  if (actual !== expected) {
    throw new Error(
      `assertion failed: ${JSON.stringify(actual)} !== ${
        JSON.stringify(expected)
      }`,
    );
  }
};

class MockChildProcessSpawner {
  readonly calls: Array<
    { cmd: string; args: ReadonlyArray<string>; options?: RunOptions }
  > = [];
  constructor(private readonly results: ReadonlyArray<CommandResult>) {}

  readonly service = ChildProcessSpawner.make((command) => {
    if (!ChildProcess.isStandardCommand(command)) {
      return Effect.fail(
        new Error("mock only supports standard commands") as never,
      );
    }
    const options = command.options;
    this.calls.push({
      cmd: command.command,
      args: command.args,
      options: {
        cwd: options.cwd,
        stdin: options.stdin === "inherit"
          ? "inherit"
          : options.stdin === "ignore"
          ? "null"
          : "piped",
        stdout: options.stdout === "inherit"
          ? "inherit"
          : options.stdout === "ignore"
          ? "null"
          : "piped",
        stderr: options.stderr === "inherit"
          ? "inherit"
          : options.stderr === "ignore"
          ? "null"
          : "piped",
      },
    });
    const result = this.results[this.calls.length - 1] ??
      { code: 0, stdout: "", stderr: "" };
    return Effect.succeed(ChildProcessSpawner.makeHandle({
      pid: ChildProcessSpawner.ProcessId(this.calls.length),
      exitCode: Effect.succeed(ChildProcessSpawner.ExitCode(result.code)),
      isRunning: Effect.succeed(false),
      kill: () => Effect.void,
      stdin: Sink.drain,
      stdout: result.stdout === ""
        ? Stream.empty
        : Stream.make(text.encode(result.stdout)),
      stderr: result.stderr === ""
        ? Stream.empty
        : Stream.make(text.encode(result.stderr)),
      all: Stream.empty,
      getInputFd: () => Sink.drain,
      getOutputFd: () => Stream.empty,
      unref: Effect.succeed(Effect.void),
    }));
  });

  readonly layer = Layer.succeed(
    ChildProcessSpawner.ChildProcessSpawner,
    this.service,
  );
}

if (!import.meta.main) {
  Deno.test("fleet parser preserves options and task args", () => {
    const parsed = parseFleetArgs([
      "--include-local",
      "--parallel",
      "2",
      "--",
      "update",
      "--fast",
    ]);
    if (parsed._tag !== "Ok") throw new Error("expected ok parse");
    assertEq(parsed.options.includeLocal, true);
    assertEq(parsed.options.parallel, 2);
    assertEq(parsed.options.taskAndArgs.join("\0"), "update\0--fast");
  });

  Deno.test("fleet default filter selects running workspace names", () => {
    const selected = chooseDefaultFleetWorkspaces([
      { name: "one", latest_build: { status: "running" } },
      { name: "two", latest_build: { status: "stopped" } },
    ]);
    assertEq(selected.join(","), "one");
  });

  Deno.test("fleet aggregation returns max partial-failure exit", () => {
    const code = fleetResultCode([
      HostEither.Right({ right: { host: "a", code: 0 } }),
      HostEither.Left({ left: { host: "b", code: 7, logFile: "/tmp/b.log" } }),
      HostEither.Left({ left: { host: "c", code: 2, logFile: "/tmp/c.log" } }),
    ]);
    assertEq(code, 7);
  });

  Deno.test("fleet remote command seeds PATH and runs from source repo", () => {
    assertEq(
      fleetCommandString("update", ["--fast"]),
      `export PATH="$HOME/.local/share/mise/shims:$HOME/.local/bin:$PATH"; cd "$HOME/.local/share/chezmoi" && mise run 'update' '--fast'`,
    );
  });

  Deno.test("fleet ssh command preserves multiword remote command", () => {
    assertEq(
      remoteZshCommand("mise run 'update'"),
      "/usr/bin/zsh -lc 'mise run '\\''update'\\'''",
    );
  });

  Deno.test("connect ssh uses hand-over stdio and mirrors child code", async () => {
    const spawner = new MockChildProcessSpawner([
      {
        code: 0,
        stdout: JSON.stringify([{
          name: "box",
          latest_build: { status: "running" },
        }]),
        stderr: "",
      },
      { code: 23, stdout: "", stderr: "" },
    ]);
    const code = await Effect.runPromise(
      connectCommand(["box"], {
        log: false,
        preflight: false,
        checkCommands: false,
      }).pipe(Effect.provide(spawner.layer)) as Effect.Effect<number>,
    );
    assertEq(code, 23);
    const ssh = spawner.calls[1];
    assertEq(ssh.cmd, "ssh");
    assertEq(ssh.options?.stdin, "inherit");
    assertEq(ssh.options?.stdout, "inherit");
    assertEq(ssh.options?.stderr, "inherit");
  });

  Deno.test("coder list schema rejects missing build status", () => {
    let failed = false;
    try {
      decodeWorkspaces([{ name: "bad", latest_build: {} }]);
    } catch {
      failed = true;
    }
    assertEq(failed, true);
  });
}
