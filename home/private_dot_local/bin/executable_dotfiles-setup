#!/usr/bin/env bash
set -euo pipefail

IFS=$'\n\t'

# Normalize TMPDIR (strip trailing slash for consistent path construction)
TMPDIR="${TMPDIR:-/tmp}"
TMPDIR="${TMPDIR%/}"

# Source shared logging library and setup session logging
source "${HOME}/.local/lib/bash-logging.sh"
setup_session_logging "$(basename "$0")"

#/ Usage:
#/   dotfiles-setup [OPTIONS]
#/
#/ Description:
#/   Checks dotfiles configuration status and provides instructions for
#/   completing setup. Run this after initial dotfiles installation.
#/
#/ Options:
#/   --help:      Display this help message
usage() { grep '^#/' "$0" | cut -c4-; }

readonly BWS_TOKEN_PATH="${HOME}/.config/chezmoi/secrets/bws-access-token.txt"

parse_args() {
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --help)
        usage
        exit 0
        ;;
      *)
        usage
        fatal "Unknown argument: $1"
        ;;
    esac
  done
}

check_bws_token() {
  [ -f "$BWS_TOKEN_PATH" ]
}

check_signing_key() {
  local key
  key=$(chezmoi execute-template '{{ .signingKey }}' 2>/dev/null || echo "")
  [ -n "$key" ]
}

print_status() {
  local has_bws="$1"
  local has_signing="$2"

  echo ""
  _print white bold "  Dotfiles Configuration Status"
  echo ""

  if [ "$has_bws" = "true" ]; then
    _print green "  ✓ BWS token"
    _print white dim "    Secrets available (npm auth, GitHub tokens)"
  else
    _print yellow "  ✗ BWS token"
    _print white dim "    Secrets not available (npm auth, GitHub tokens)"
  fi

  echo ""

  if [ "$has_signing" = "true" ]; then
    _print green "  ✓ Signing key"
    _print white dim "    Git commits will be signed"
  else
    _print yellow "  ✗ Signing key"
    _print white dim "    Git commits will not be signed"
  fi

  echo ""
}

print_instructions() {
  local has_bws="$1"
  local has_signing="$2"

  if [ "$has_bws" = "true" ] && [ "$has_signing" = "true" ]; then
    _print green bold "  All configuration complete!"
    echo ""
    return
  fi

  _print cyan bold "  To complete setup:"
  echo ""

  local step=1

  if [ "$has_bws" = "false" ]; then
    _print white bold "  ${step}. Configure BWS access token"
    echo ""
    _print white dim "     Get a token from Bitwarden Secrets Manager:"
    _print white dim "     https://vault.bitwarden.com → Secrets Manager → Machine accounts"
    echo ""
    _print white dim "     Then save it:"
    echo "     mkdir -p ~/.config/chezmoi/secrets"
    echo "     echo 'YOUR_TOKEN' > ${BWS_TOKEN_PATH}"
    echo "     chmod 600 ${BWS_TOKEN_PATH}"
    echo ""
    step=$((step + 1))
  fi

  if [ "$has_signing" = "false" ]; then
    _print white bold "  ${step}. Configure a commit-signing key"
    echo ""
    _print white dim "     GPG: Run 'gpg -K --keyid-format SHORT' to list keys"
    _print white dim "     SSH: Use path like '~/.ssh/id_ed25519.pub'"
    echo ""
    step=$((step + 1))
  fi

  _print white bold "  ${step}. Re-apply dotfiles"
  echo ""

  if [ "$has_signing" = "false" ]; then
    _print white dim "     Re-run install (you'll be prompted for missing values):"
    echo "     \$HOME/.local/share/chezmoi/install.sh"
  else
    _print white dim "     Re-apply to pick up secrets:"
    echo "     chezmoi apply --force"
  fi

  echo ""

  if [ "$has_bws" = "false" ] || [ "$has_signing" = "false" ]; then
    _print white dim "     Or provide everything via environment variables:"
    local env_cmd="     "
    if [ "$has_bws" = "false" ]; then
      env_cmd+="CONFIG_BWS_ACCESS_TOKEN=<token> "
    fi
    if [ "$has_signing" = "false" ]; then
      env_cmd+="CONFIG_SIGNING_KEY=<key> "
    fi
    env_cmd+="\$HOME/.local/share/chezmoi/install.sh"
    _print white dim "$env_cmd"
    echo ""
  fi
}

main() {
  parse_args "$@"

  local has_bws="false"
  local has_signing="false"

  if check_bws_token; then
    has_bws="true"
  fi

  if check_signing_key; then
    has_signing="true"
  fi

  print_status "$has_bws" "$has_signing"
  print_instructions "$has_bws" "$has_signing"
}

main "$@"
