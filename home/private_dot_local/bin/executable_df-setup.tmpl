#!/usr/bin/env bash
set -euo pipefail

IFS=$'\n\t'

# Normalize TMPDIR (strip trailing slash for consistent path construction)
TMPDIR="${TMPDIR:-/tmp}"
TMPDIR="${TMPDIR%/}"

# Source shared logging library and setup session logging
source "${HOME}/.local/lib/bash-logging.sh"
setup_session_logging "$(basename "$0")"

#/ Usage:
#/   dotfiles-setup [OPTIONS]
#/
#/ Description:
#/   Checks dotfiles configuration status and provides instructions for
#/   completing setup. Run this after initial dotfiles installation.
#/
#/ Options:
#/   --help:      Display this help message
#/   --probe-bws: Probe BWS token validity and exit with status:
#/                  0 = valid, 1 = missing/unconfigured, 2 = invalid
#/                Used by chezmoi-preflight.sh as a cheap liveness check.
usage() { grep '^#/' "$0" | cut -c4-; }

readonly BWS_TOKEN_PATH="${HOME}/.config/chezmoi/secrets/bws-access-token.txt"
# Canary secret used to probe BWS token validity. Any live secret ID works;
# GitHub auth token is present on all machines (personal and work) in this
# repo's Bitwarden project.
readonly BWS_PROBE_SECRET_ID="{{ .bwsIdGithubAuthToken }}"

parse_args() {
  PROBE_ONLY="false"
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --help)
        usage
        exit 0
        ;;
      --probe-bws)
        PROBE_ONLY="true"
        shift
        ;;
      *)
        usage
        fatal "Unknown argument: $1"
        ;;
    esac
  done
}

# Probes the BWS token by fetching a canary secret. Returns:
#   0  — token file present AND server accepts it (ok)
#   1  — token file missing (missing)
#   2  — token file present AND server rejects it (invalid)
# On state 2, echoes a short classification of the cause to stdout:
#   "auth"      — server returned invalid_client / 401 / 403 (rotate token)
#   "unknown"   — other failure (network, server 5xx, bws crash)
check_bws_token() {
  if [ ! -f "$BWS_TOKEN_PATH" ]; then
    return 1
  fi

  if ! command -v bws >/dev/null 2>&1; then
    # No bws binary — can't probe, treat as "missing" (templates skip anyway).
    return 1
  fi

  local token
  token=$(tr -d '[:space:]' <"$BWS_TOKEN_PATH")
  if [ -z "$token" ]; then
    return 1
  fi

  local probe_stderr
  probe_stderr=$(bws secret get "$BWS_PROBE_SECRET_ID" \
    --access-token "$token" 2>&1 >/dev/null)
  local rc=$?

  if [ "$rc" -eq 0 ]; then
    return 0
  fi

  # Classify the failure so we can give actionable guidance rather than
  # blaming the user for transient BWS/network issues.
  #
  # "auth" covers any token-is-the-problem case:
  #   - invalid_client        (server rejects the token)
  #   - 401/403               (auth or authorization failure)
  #   - not in a valid format (malformed token, e.g. truncated/corrupted)
  #   - decoding base64       (same — the token string itself is broken)
  # All of these mean "rotate the token" — either the one in Bitwarden is
  # dead, or the local copy is corrupted. Either way, user action is the
  # same as a server-side rejection.
  if printf '%s' "$probe_stderr" \
    | grep -qE 'invalid_client|401 Unauthorized|403 Forbidden|not in a valid format|Error decoding base64'; then
    echo "auth"
  else
    echo "unknown"
  fi
  return 2
}

{{- if and (eq .chezmoi.os "linux") (dig "paseoDaemon" false .) }}

check_paseo_daemon() {
  systemctl --user is-active --quiet paseo-daemon.service
}
{{- end }}

{{- if and (eq .chezmoi.os "linux") (dig "orcaServer" false .) }}

check_orca_server() {
  systemctl --user is-active --quiet orca-server.service
}

# Returns "<installed>|<latest>" — values may be empty on failure.
# Latest is best-effort (network + GitHub API); failures yield empty string.
orca_version_state() {
  local installed="" latest=""
  # Installed version from mise (http: backend installs orca-linux.AppImage
  # into ~/.local/share/mise/installs/http-orca/<version>/). Falls back to
  # dpkg-query for any boxes still on the legacy .deb install.
  if command -v mise >/dev/null 2>&1; then
    installed=$(mise current orca 2>/dev/null || echo "")
  fi
  if [ -z "$installed" ] && command -v dpkg-query >/dev/null 2>&1; then
    installed=$(dpkg-query -W -f='${Version}' orca-ide 2>/dev/null || echo "")
  fi
  if command -v curl >/dev/null 2>&1; then
    latest=$(curl -fsSL --max-time 3 "https://api.github.com/repos/stablyai/orca/releases/latest" 2>/dev/null \
             | sed -n 's/.*"tag_name": *"v\{0,1\}\([^"]*\)".*/\1/p' | head -n 1)
  fi
  printf '%s|%s' "$installed" "$latest"
}
{{- end }}

{{- if ne "" .emailWork }}

check_gh_auth() {
  gh auth status 2>&1 | grep -q "Logged in"
}

check_work_config() {
  # Returns the list of missing work config variable names
  local missing=()
  local val
  val=$(chezmoi execute-template '{{ "{{" }} .signingKey {{ "}}" }}' 2>/dev/null || echo "")
  [ -z "$val" ] && missing+=("signingKey")
  val=$(chezmoi execute-template '{{ "{{" }} .npmWorkRegistry {{ "}}" }}' 2>/dev/null || echo "")
  [ -z "$val" ] && missing+=("npmWorkRegistry")
  val=$(chezmoi execute-template '{{ "{{" }} .openCodeWorkPlugin {{ "}}" }}' 2>/dev/null || echo "")
  [ -z "$val" ] && missing+=("openCodeWorkPlugin")
  val=$(chezmoi execute-template '{{ "{{" }} .jetbrainsLicenseServer {{ "}}" }}' 2>/dev/null || echo "")
  [ -z "$val" ] && missing+=("jetbrainsLicenseServer")
  [ "${#missing[@]}" -gt 0 ] && printf '%s\n' "${missing[@]}"
}
{{- end }}

print_status() {
  local bws_state="$1"
{{- if ne "" .emailWork }}
  local has_gh_auth="$2"
  shift 2
  local -a work_missing=("$@")
{{- end }}

  echo ""
  _print white bold "  Dotfiles Configuration Status"
  echo ""

  case "$bws_state" in
    ok)
      _print green "  ✓ BWS token"
      _print white dim "    Secrets available (npm auth, GitHub tokens)"
      ;;
    invalid-auth)
      _print red "  ✗ BWS token (invalid — server rejected)"
      _print white dim "    Token has expired or been revoked in Bitwarden"
      ;;
    invalid-unknown)
      _print red "  ✗ BWS token (unreachable)"
      _print white dim "    bws probe failed — network, server, or binary issue"
      ;;
    missing)
      _print yellow "  ✗ BWS token (not configured)"
      _print white dim "    Secrets not available (npm auth, GitHub tokens)"
      ;;
  esac
{{- if ne "" .emailWork }}

  echo ""

  if [ "$has_gh_auth" = "true" ]; then
    _print green "  ✓ GitHub CLI auth"
    _print white dim "    Short-lived tokens available via git credential agent"
  else
    _print yellow "  ✗ GitHub CLI auth"
    _print white dim "    Tools needing GitHub access will fail (brew, github-token)"
  fi

  echo ""

  if [ "${#work_missing[@]}" -eq 0 ]; then
    _print green "  ✓ Work config"
    _print white dim "    Signing key, npm registry, tooling configured"
  else
    _print yellow "  ✗ Work config"
    local missing_list
    missing_list=$(printf '%s, ' "${work_missing[@]}")
    missing_list="${missing_list%, }"
    _print white dim "    Missing: ${missing_list}"
  fi
{{- end }}
{{- if and (eq .chezmoi.os "linux") (dig "paseoDaemon" false .) }}

  echo ""

  if check_paseo_daemon; then
    _print green "  ✓ paseo daemon"
    _print white dim "    Listening on :6767 — port-forward from a macbook to connect"
  else
    _print yellow "  ✗ paseo daemon"
    _print white dim "    Opted in but not running. Try: systemctl --user status paseo-daemon"
  fi
{{- end }}
{{- if and (eq .chezmoi.os "linux") (dig "orcaServer" false .) }}

  echo ""

  local _orca_state _orca_installed _orca_latest
  _orca_state=$(orca_version_state)
  _orca_installed="${_orca_state%%|*}"
  _orca_latest="${_orca_state##*|}"

  if check_orca_server; then
    if [ -n "$_orca_installed" ]; then
      _print green "  ✓ orca server (v${_orca_installed})"
    else
      _print green "  ✓ orca server"
    fi
    _print white dim "    Latest upstream: ${_orca_latest:-unknown}"
    if [ -n "$_orca_installed" ] && [ -n "$_orca_latest" ] && [ "$_orca_installed" != "$_orca_latest" ]; then
      _print yellow "    ↑ Upstream ahead. Bump http:orca version in home/private_dot_config/mise/config.toml.tmpl, then chezmoi apply."
    fi
    _print white dim "    Pairing URL: journalctl --user -u orca-server.service | grep -o 'orca://pair#[^ \"]*' | tail -1"
  else
    _print yellow "  ✗ orca server"
    _print white dim "    Opted in but not running. Try: systemctl --user status orca-server"
  fi
{{- end }}

  # ── Drift report (read-only view of last drift:check) ─────────
  echo ""
  local _drift_cache="${HOME}/.cache/dotfiles/drift.json"
  if [ -f "$_drift_cache" ] && command -v jq >/dev/null 2>&1; then
    local _drift_count
    _drift_count=$(jq '.tools | length' "$_drift_cache" 2>/dev/null || echo 0)
    if [ "$_drift_count" -eq 0 ]; then
      _print green "  ✓ Tool drift (no tools behind)"
      _print white dim "    Last checked: $(jq -r '.checked_at' "$_drift_cache" 2>/dev/null)"
    else
      _print yellow "  ⚠ Tool drift (${_drift_count} behind)"
      jq -r '.tools[] | "    \(.name): \(.installed) → \(.latest) [\(.source)]"' "$_drift_cache" 2>/dev/null \
        | while IFS= read -r line; do _print white dim "$line"; done
{{- if eq .chezmoi.os "darwin" }}
      _print white dim "    Refresh: mise run drift:check  ·  Update everything: mise run update"
{{- else }}
      _print white dim "    Refresh: mise run drift:check (manual on Linux; no scheduled notifier)"
{{- end }}
    fi
  else
    _print white dim "  ⋯ Tool drift (no cache)"
{{- if eq .chezmoi.os "darwin" }}
    _print white dim "    Run: mise run drift:check (also runs daily via launchd agent)"
{{- else }}
    _print white dim "    Run: mise run drift:check"
{{- end }}
  fi

  echo ""
}

print_instructions() {
  local bws_state="$1"
{{- if ne "" .emailWork }}
  local has_gh_auth="$2"
  shift 2
  local -a work_missing=("$@")

  if [ "$bws_state" = "ok" ] && [ "$has_gh_auth" = "true" ] && [ "${#work_missing[@]}" -eq 0 ]; then
{{- else }}
  if [ "$bws_state" = "ok" ]; then
{{- end }}
    _print green bold "  All configuration complete!"
    echo ""
    return
  fi

  _print cyan bold "  To complete setup:"
  echo ""

  local step=1

  case "$bws_state" in
    invalid-auth)
      _print white bold "  ${step}. Rotate BWS access token (currently rejected by server)"
      echo ""
      _print white dim "     This machine's token has expired or been revoked."
      _print white dim "     Host: $(hostname)"
      echo ""
      _print white dim "     Steps:"
      _print white dim "       a. Open Bitwarden Secrets Manager:"
      _print white dim "          https://vault.bitwarden.com → Secrets Manager → Machine accounts"
      _print white dim "       b. Find the machine account for this host and rotate its access token"
      _print white dim "       c. Save the new token:"
      echo "          echo 'YOUR_NEW_TOKEN' > ${BWS_TOKEN_PATH}"
      echo "          chmod 600 ${BWS_TOKEN_PATH}"
      echo ""
      _print white dim "     Or, to proceed without secrets (empty values), remove the token:"
      echo "          rm ${BWS_TOKEN_PATH}"
      echo ""
      step=$((step + 1))
      ;;
    invalid-unknown)
      _print white bold "  ${step}. Investigate BWS probe failure"
      echo ""
      _print white dim "     bws could not validate the token. Possible causes:"
      _print white dim "       • Network connectivity to vault.bitwarden.com"
      _print white dim "       • BWS service outage"
      _print white dim "       • bws binary missing / broken install"
      echo ""
      _print white dim "     Reproduce manually to see the raw error:"
      echo "       bws secret get ${BWS_PROBE_SECRET_ID} \\"
      echo "         --access-token \"\$(cat ${BWS_TOKEN_PATH})\""
      echo ""
      step=$((step + 1))
      ;;
    missing)
      _print white bold "  ${step}. Configure BWS access token"
      echo ""
      _print white dim "     Get a token from Bitwarden Secrets Manager:"
      _print white dim "     https://vault.bitwarden.com → Secrets Manager → Machine accounts"
      echo ""
      _print white dim "     Then save it:"
      echo "     mkdir -p ~/.config/chezmoi/secrets"
      echo "     echo 'YOUR_TOKEN' > ${BWS_TOKEN_PATH}"
      echo "     chmod 600 ${BWS_TOKEN_PATH}"
      echo ""
      step=$((step + 1))
      ;;
  esac
{{- if ne "" .emailWork }}

  if [ "$has_gh_auth" = "false" ]; then
    _print white bold "  ${step}. Authenticate GitHub CLI"
    echo ""
    _print white dim "     Run:"
    echo "     gh auth login"
    echo ""
    step=$((step + 1))
  fi

  if [ "${#work_missing[@]}" -gt 0 ]; then
    _print white bold "  ${step}. Configure work-specific values"
    echo ""
    _print white dim "     Run:"
    echo "     chezmoi edit-config"
    echo ""
    _print white dim "     Add under [data]:"
    for var in "${work_missing[@]}"; do
      echo "       ${var} = \"...\""
    done
    echo ""
    step=$((step + 1))
  fi
{{- end }}

  _print white bold "  ${step}. Re-apply dotfiles"
  echo ""
  _print white dim "     Re-apply to pick up changes:"
  echo "     chezmoi apply --force"

  echo ""
}

main() {
  parse_args "$@"

  # --probe-bws: headless mode for chezmoi-preflight.sh.
  # Exit code conveys state; no output (BASH_LOGGING_QUIET already
  # handled by session logging infra). Emits nothing on stdout/stderr
  # so the preflight hook stays noise-free on the happy path.
  if [ "$PROBE_ONLY" = "true" ]; then
    set +e
    check_bws_token >/dev/null 2>&1
    exit $?
  fi

  local bws_state
  local bws_probe_cause=""
{{- if ne "" .emailWork }}
  local has_gh_auth="false"
{{- end }}

  # Capture the classification stdout while still acting on the exit code.
  set +e
  bws_probe_cause=$(check_bws_token)
  local bws_rc=$?
  set -e
  case "$bws_rc" in
    0) bws_state="ok" ;;
    1) bws_state="missing" ;;
    2)
      if [ "$bws_probe_cause" = "auth" ]; then
        bws_state="invalid-auth"
      else
        bws_state="invalid-unknown"
      fi
      ;;
  esac
{{- if ne "" .emailWork }}

  if check_gh_auth; then
    has_gh_auth="true"
  fi

  local -a work_missing
  mapfile -t work_missing < <(check_work_config)

  print_status "$bws_state" "$has_gh_auth" "${work_missing[@]}"
  print_instructions "$bws_state" "$has_gh_auth" "${work_missing[@]}"
{{- else }}
  print_status "$bws_state"
  print_instructions "$bws_state"
{{- end }}
}

main "$@"
