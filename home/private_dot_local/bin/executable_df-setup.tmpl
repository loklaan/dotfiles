#!/usr/bin/env -S DENO_NO_PACKAGE_JSON=1 deno run --no-lock --allow-run=tput{{ if lookPath "bws" }},bws{{ end }}{{ if lookPath "systemctl" }},systemctl{{ end }}{{ if lookPath "mise" }},mise{{ end }}{{ if lookPath "pitchfork" }},pitchfork{{ end }}{{ if lookPath "dpkg-query" }},dpkg-query{{ end }}{{ if lookPath "curl" }},curl{{ end }}{{ if lookPath "gh" }},gh{{ end }}{{ if lookPath "chezmoi" }},chezmoi{{ end }}{{ if lookPath "hostname" }},hostname{{ end }} --allow-read --allow-env --allow-net=api.github.com --allow-ffi

// deno-fmt-ignore-file
// df-setup — dotfiles health-check doctor (Deno + Effect v4 beta).
//
// This is a strict behavioral port of the previous bash implementation. Keep
// output/prose/exit-code semantics in lockstep: `chezmoi-preflight.sh` depends
// on `--probe-bws` returning 0=ok, 1=missing, 2=invalid.

import { Config, Effect, Schema } from "npm:effect@4.0.0-beta.83";

const fatal = (msg: string): never => {
  console.error(`fatal ${msg}`);
  Deno.exit(1);
};

const HELP = `Usage:
  dotfiles-setup [OPTIONS]

Description:
  Checks dotfiles configuration status and provides instructions for
  completing setup. Run this after initial dotfiles installation.

Options:
  --help:      Display this help message
  --probe-bws: Probe BWS token validity and exit with status:
                 0 = valid, 1 = missing/unconfigured, 2 = invalid
               Used by chezmoi-preflight.sh as a cheap liveness check.`;

const bwsTokenPath: Effect.Effect<string> = Effect.gen(function* () {
  const home = yield* Config.string("HOME").pipe(Config.withDefault(""), Effect.orElseSucceed(() => ""));
  return `${home}/.config/chezmoi/secrets/bws-access-token.txt`;
});
// Canary secret used to probe BWS token validity. Any live secret ID works;
// GitHub auth token is present on all machines (personal and work) in this
// repo's Bitwarden project.
const BWS_PROBE_SECRET_ID = "{{ .bwsIdGithubAuthToken }}";

const DriftTool = Schema.Struct({
  name: Schema.String,
  installed: Schema.String,
  latest: Schema.String,
  source: Schema.String,
});
type DriftTool = typeof DriftTool.Type;

const DriftReport = Schema.Struct({
  checked_at: Schema.String,
  tools: Schema.Array(DriftTool),
});
type DriftReport = typeof DriftReport.Type;
const decodeDriftReport = Schema.decodeUnknownSync(DriftReport);

type BwsState = "ok" | "missing" | "invalid-auth" | "invalid-unknown";
type ProbeResult =
  | { readonly state: "ok"; readonly exitCode: 0 }
  | { readonly state: "missing"; readonly exitCode: 1 }
  | {
    readonly state: "invalid-auth" | "invalid-unknown";
    readonly exitCode: 2;
  };

type ParseResult =
  | { readonly kind: "run"; readonly probeOnly: boolean }
  | { readonly kind: "help" };

interface RunResult {
  readonly ok: boolean;
  readonly code: number;
  readonly stdout: string;
  readonly stderr: string;
}

type Color = "red" | "green" | "yellow" | "cyan" | "white";
type Style = "bold" | "dim";

const RESET = "\x1b[0m";
const COLORS: Record<Color, string> = {
  red: "31",
  green: "32",
  yellow: "33",
  cyan: "36",
  white: "37",
};

let colorSupport: boolean | undefined;

const supportedColors = (): boolean => {
  if (colorSupport !== undefined) return colorSupport;
  try {
    const result = new Deno.Command("tput", {
      args: ["colors"],
      stdout: "piped",
      stderr: "null",
    }).outputSync();
    const colors = Number(new TextDecoder().decode(result.stdout).trim());
    colorSupport = Number.isFinite(colors) && colors > 8;
  } catch {
    colorSupport = false;
  }
  return colorSupport;
};

const colorize = (color: Color, styles: readonly Style[], text: string): string => {
  if (!supportedColors()) return text;
  const code = [COLORS[color], ...styles.map((style) => style === "bold" ? "1" : "2")]
    .join(";");
  return `\x1b[${code}m${text}${RESET}`;
};

const print = (color: Color, styles: readonly Style[], text: string): void => {
  console.log(colorize(color, styles, text));
};

const printPlain = (text = ""): void => {
  console.log(text);
};

const parseArgs = (argv: readonly string[]): ParseResult => {
  let probeOnly = false;
  for (const arg of argv) {
    if (arg === "--help") return { kind: "help" };
    if (arg === "--probe-bws") {
      probeOnly = true;
      continue;
    }
    printPlain(HELP);
    fatal(`Unknown argument: ${arg}`);
  }
  return { kind: "run", probeOnly };
};

const run = (cmd: string, args: readonly string[]): Effect.Effect<RunResult> =>
  Effect.tryPromise({
    try: async () => {
      const command = new Deno.Command(cmd, {
        args: [...args],
        stdout: "piped",
        stderr: "piped",
      });
      const { code, stdout, stderr } = await command.output();
      const dec = new TextDecoder();
      return {
        ok: code === 0,
        code,
        stdout: dec.decode(stdout),
        stderr: dec.decode(stderr),
      };
    },
    catch: () => undefined,
  }).pipe(
    Effect.orElseSucceed((): RunResult => ({
      ok: false,
      code: 127,
      stdout: "",
      stderr: "",
    })),
  );

const fileExists = (path: string): Effect.Effect<boolean> =>
  Effect.tryPromise({
    try: async () => {
      const stat = await Deno.stat(path);
      return stat.isFile;
    },
    catch: () => false,
  }).pipe(Effect.orElseSucceed(() => false));

const pathExists = (path: string): Effect.Effect<boolean> =>
  Effect.tryPromise({
    try: async () => {
      await Deno.stat(path);
      return true;
    },
    catch: () => false,
  }).pipe(Effect.orElseSucceed(() => false));

const hasCommand = (cmd: string): Effect.Effect<boolean> =>
  Effect.gen(function* () {
    if (cmd.includes("/")) return yield* pathExists(cmd);
    const pathEnv = yield* Config.string("PATH").pipe(Config.withDefault(""), Effect.orElseSucceed(() => ""));
    for (const dir of pathEnv.split(":")) {
      if (dir === "") continue;
      if (yield* pathExists(`${dir}/${cmd}`)) return true;
    }
    return false;
  }).pipe(Effect.orElseSucceed(() => false));

const readTextFile = (path: string): Effect.Effect<string | null> =>
  Effect.tryPromise({
    try: () => Deno.readTextFile(path),
    catch: () => null,
  }).pipe(Effect.orElseSucceed(() => null));

const parseJson = (text: string | null): unknown => {
  if (text === null) return null;
  try {
    return JSON.parse(text);
  } catch {
    return null;
  }
};

const trimAllWhitespace = (value: string): string => value.replace(/\s/g, "");

// Probes the BWS token by fetching a canary secret. Returns:
//   0  — token file present AND server accepts it (ok)
//   1  — token file missing (missing)
//   2  — token file present AND server rejects it (invalid)
const checkBwsToken: Effect.Effect<ProbeResult> = Effect.gen(function* () {
  const tokenPath = yield* bwsTokenPath;
  if (!(yield* fileExists(tokenPath))) {
    return { state: "missing", exitCode: 1 } as const;
  }

  if (!(yield* hasCommand("bws"))) {
    return { state: "missing", exitCode: 1 } as const;
  }

  const token = trimAllWhitespace((yield* readTextFile(tokenPath)) ?? "");
  if (token === "") {
    return { state: "missing", exitCode: 1 } as const;
  }

  const probe = yield* run("bws", [
    "secret",
    "get",
    BWS_PROBE_SECRET_ID,
    "--access-token",
    token,
  ]);

  if (probe.ok) return { state: "ok", exitCode: 0 } as const;

  if (
    /invalid_client|401 Unauthorized|403 Forbidden|not in a valid format|Error decoding base64/
      .test(probe.stderr)
  ) {
    return { state: "invalid-auth", exitCode: 2 } as const;
  }
  return { state: "invalid-unknown", exitCode: 2 } as const;
});

{{- if and (eq .chezmoi.os "linux") (dig "paseoDaemon" false .) }}

const checkPaseoDaemon: Effect.Effect<boolean> = run("systemctl", [
  "--user",
  "is-active",
  "--quiet",
  "paseo-daemon.service",
]).pipe(Effect.map((result) => result.ok));
{{- end }}

{{- if and (eq .chezmoi.os "linux") (dig "orcaServer" false .) }}

interface OrcaVersionState {
  readonly installed: string;
  readonly latest: string;
}

// orca runs as a Pitchfork daemon (df-orca-server), not a systemd unit. The
// install script (run_after_install-059-orca-server) starts it via
// `pitchfork start df-orca-server`. `pitchfork status` exits 0 and prints
// `Status: running` for a live daemon, so we match that explicitly rather
// than trusting exit code alone (a stopped/failed daemon still exits 0).
const checkOrcaServer: Effect.Effect<boolean> = Effect.gen(function* () {
  const pitchfork = (yield* hasCommand("pitchfork"))
    ? "pitchfork"
    : (yield* run("mise", ["which", "pitchfork"])).stdout.trim();
  if (pitchfork === "") return false;
  const result = yield* run(pitchfork, ["status", "df-orca-server"]);
  return result.ok && /Status:\s*running/.test(result.stdout);
});

// Returns "<installed>|<latest>" — values may be empty on failure.
// Latest is best-effort (network + GitHub API); failures yield empty string.
const orcaVersionState: Effect.Effect<OrcaVersionState> = Effect.gen(function* () {
  let installed = "";
  let latest = "";

  // Installed version from mise (http: backend installs orca-linux.AppImage
  // into ~/.local/share/mise/installs/http-orca/<version>/). Falls back to
  // dpkg-query for any boxes still on the legacy .deb install.
  if (yield* hasCommand("mise")) {
    const result = yield* run("mise", ["current", "orca"]);
    installed = result.ok ? result.stdout.trim() : "";
  }
  if (installed === "" && (yield* hasCommand("dpkg-query"))) {
    const result = yield* run("dpkg-query", ["-W", "-f=${Version}", "orca-ide"]);
    installed = result.ok ? result.stdout.trim() : "";
  }
  if (yield* hasCommand("curl")) {
    const result = yield* run("curl", [
      "-fsSL",
      "--max-time",
      "3",
      "https://api.github.com/repos/stablyai/orca/releases/latest",
    ]);
    const match = result.ok
      ? result.stdout.match(/"tag_name": *"v{0,1}([^"]*)"/)
      : null;
    latest = match?.[1] ?? "";
  }

  return { installed, latest };
});
{{- end }}

{{- if ne "" .emailWork }}

const checkGhAuth: Effect.Effect<boolean> = run("gh", ["auth", "status"]).pipe(
  Effect.map((result) => result.ok && `${result.stdout}${result.stderr}`.includes("Logged in")),
);

const workConfigVars = [
  ["signingKey", '{{ "{{" }} .signingKey {{ "}}" }}'],
  ["npmWorkRegistry", '{{ "{{" }} .npmWorkRegistry {{ "}}" }}'],
  ["openCodeWorkPlugin", '{{ "{{" }} .openCodeWorkPlugin {{ "}}" }}'],
  ["jetbrainsLicenseServer", '{{ "{{" }} .jetbrainsLicenseServer {{ "}}" }}'],
] as const;

const checkWorkConfig: Effect.Effect<ReadonlyArray<string>> = Effect.gen(function* () {
  const missing: string[] = [];
  for (const [name, template] of workConfigVars) {
    const result = yield* run("chezmoi", ["execute-template", template]);
    if (!result.ok || result.stdout.trim() === "") missing.push(name);
  }
  return missing;
});
{{- end }}

const formatMissingList = (missing: ReadonlyArray<string>): string => missing.join(", ");

const printStatus = (
  bwsState: BwsState,
{{- if ne "" .emailWork }}
  hasGhAuth: boolean,
  workMissing: ReadonlyArray<string>,
{{- end }}
): Effect.Effect<void> =>
  Effect.gen(function* () {
    printPlain();
    print("white", ["bold"], "  Dotfiles Configuration Status");
    printPlain();

    switch (bwsState) {
      case "ok":
        print("green", [], "  ✓ BWS token");
        print("white", ["dim"], "    Secrets available (npm auth, GitHub tokens)");
        break;
      case "invalid-auth":
        print("red", [], "  ✗ BWS token (invalid — server rejected)");
        print("white", ["dim"], "    Token has expired or been revoked in Bitwarden");
        break;
      case "invalid-unknown":
        print("red", [], "  ✗ BWS token (unreachable)");
        print("white", ["dim"], "    bws probe failed — network, server, or binary issue");
        break;
      case "missing":
        print("yellow", [], "  ✗ BWS token (not configured)");
        print("white", ["dim"], "    Secrets not available (npm auth, GitHub tokens)");
        break;
    }
{{- if ne "" .emailWork }}

    printPlain();

    if (hasGhAuth) {
      print("green", [], "  ✓ GitHub CLI auth");
      print("white", ["dim"], "    Short-lived tokens available via git credential agent");
    } else {
      print("yellow", [], "  ✗ GitHub CLI auth");
      print("white", ["dim"], "    Tools needing GitHub access will fail (brew, github-token)");
    }

    printPlain();

    if (workMissing.length === 0) {
      print("green", [], "  ✓ Work config");
      print("white", ["dim"], "    Signing key, npm registry, tooling configured");
    } else {
      print("yellow", [], "  ✗ Work config");
      print("white", ["dim"], `    Missing: ${formatMissingList(workMissing)}`);
    }
{{- end }}
{{- if and (eq .chezmoi.os "linux") (dig "paseoDaemon" false .) }}

    printPlain();

    if (yield* checkPaseoDaemon) {
      print("green", [], "  ✓ paseo daemon");
      print("white", ["dim"], "    Listening on :6767 — port-forward from a macbook to connect");
    } else {
      print("yellow", [], "  ✗ paseo daemon");
      print("white", ["dim"], "    Opted in but not running. Try: systemctl --user status paseo-daemon");
    }
{{- end }}
{{- if and (eq .chezmoi.os "linux") (dig "orcaServer" false .) }}

    printPlain();

    const orcaState = yield* orcaVersionState;
    const orcaActive = yield* checkOrcaServer;

    if (orcaActive) {
      if (orcaState.installed !== "") {
        print("green", [], `  ✓ orca server (v${orcaState.installed})`);
      } else {
        print("green", [], "  ✓ orca server");
      }
      print("white", ["dim"], `    Latest upstream: ${orcaState.latest || "unknown"}`);
      if (
        orcaState.installed !== "" && orcaState.latest !== "" &&
        orcaState.installed !== orcaState.latest
      ) {
        print("yellow", [], "    ↑ Upstream ahead. Bump http:orca version in home/private_dot_config/mise/config.toml.tmpl, then chezmoi apply.");
      }
      print("white", ["dim"], "    Pairing URL: pitchfork logs df-orca-server --raw | grep -oE 'orca://pair#[^[:space:]]+' | tail -1");
    } else {
      print("yellow", [], "  ✗ orca server");
      print("white", ["dim"], "    Opted in but not running. Try: pitchfork status df-orca-server (logs: pitchfork logs df-orca-server)");
    }
{{- end }}

    // ── Drift report (read-only view of last drift:check) ─────────
    printPlain();
    const home = yield* Config.string("HOME").pipe(Config.withDefault(""), Effect.orElseSucceed(() => ""));
    const driftCache = `${home}/.cache/dotfiles/drift.json`;
    if ((yield* fileExists(driftCache)) && (yield* hasCommand("jq"))) {
      const parsed = parseJson(yield* readTextFile(driftCache));
      const drift = decodeDrift(parsed);
      const driftCount = drift.tools.length;
      if (driftCount === 0) {
        print("green", [], "  ✓ Tool drift (no tools behind)");
        print("white", ["dim"], `    Last checked: ${drift.checked_at}`);
      } else {
        print("yellow", [], `  ⚠ Tool drift (${driftCount} behind)`);
        for (const tool of drift.tools) {
          print("white", ["dim"], `    ${tool.name}: ${tool.installed} → ${tool.latest} [${tool.source}]`);
        }
{{- if eq .chezmoi.os "darwin" }}
        print("white", ["dim"], "    Refresh: mise run drift:check  ·  Update everything: mise run update");
{{- else }}
        print("white", ["dim"], "    Refresh: mise run drift:check (manual on Linux; no scheduled notifier)");
{{- end }}
      }
    } else {
      print("white", ["dim"], "  ⋯ Tool drift (no cache)");
{{- if eq .chezmoi.os "darwin" }}
      print("white", ["dim"], "    Run: mise run drift:check (also runs daily via launchd agent)");
{{- else }}
      print("white", ["dim"], "    Run: mise run drift:check");
{{- end }}
    }

    printPlain();
  });

const decodeDrift = (parsed: unknown): DriftReport => {
  try {
    return decodeDriftReport(parsed);
  } catch {
    return { checked_at: "", tools: [] };
  }
};

const hostname: Effect.Effect<string> = run("hostname", []).pipe(
  Effect.map((result) => result.ok ? result.stdout.trim() : ""),
);

const printInstructions = (
  bwsState: BwsState,
  tokenPath: string,
{{- if ne "" .emailWork }}
  hasGhAuth: boolean,
  workMissing: ReadonlyArray<string>,
{{- end }}
): Effect.Effect<void> =>
  Effect.gen(function* () {
{{- if ne "" .emailWork }}
    if (bwsState === "ok" && hasGhAuth && workMissing.length === 0) {
{{- else }}
    if (bwsState === "ok") {
{{- end }}
      print("green", ["bold"], "  All configuration complete!");
      printPlain();
      return;
    }

    print("cyan", ["bold"], "  To complete setup:");
    printPlain();

    let step = 1;

    switch (bwsState) {
      case "invalid-auth":
        print("white", ["bold"], `  ${step}. Rotate BWS access token (currently rejected by server)`);
        printPlain();
        print("white", ["dim"], "     This machine's token has expired or been revoked.");
        print("white", ["dim"], `     Host: ${yield* hostname}`);
        printPlain();
        print("white", ["dim"], "     Steps:");
        print("white", ["dim"], "       a. Open Bitwarden Secrets Manager:");
        print("white", ["dim"], "          https://vault.bitwarden.com → Secrets Manager → Machine accounts");
        print("white", ["dim"], "       b. Find the machine account for this host and rotate its access token");
        print("white", ["dim"], "       c. Save the new token:");
        printPlain(`          echo 'YOUR_NEW_TOKEN' > ${tokenPath}`);
        printPlain(`          chmod 600 ${tokenPath}`);
        printPlain();
        print("white", ["dim"], "     Or, to proceed without secrets (empty values), remove the token:");
        printPlain(`          rm ${tokenPath}`);
        printPlain();
        step += 1;
        break;
      case "invalid-unknown":
        print("white", ["bold"], `  ${step}. Investigate BWS probe failure`);
        printPlain();
        print("white", ["dim"], "     bws could not validate the token. Possible causes:");
        print("white", ["dim"], "       • Network connectivity to vault.bitwarden.com");
        print("white", ["dim"], "       • BWS service outage");
        print("white", ["dim"], "       • bws binary missing / broken install");
        printPlain();
        print("white", ["dim"], "     Reproduce manually to see the raw error:");
        printPlain(`       bws secret get ${BWS_PROBE_SECRET_ID} \\`);
        printPlain(`         --access-token "\$(cat ${tokenPath})"`);
        printPlain();
        step += 1;
        break;
      case "missing":
        print("white", ["bold"], `  ${step}. Configure BWS access token`);
        printPlain();
        print("white", ["dim"], "     Get a token from Bitwarden Secrets Manager:");
        print("white", ["dim"], "     https://vault.bitwarden.com → Secrets Manager → Machine accounts");
        printPlain();
        print("white", ["dim"], "     Then save it:");
        printPlain("     mkdir -p ~/.config/chezmoi/secrets");
        printPlain(`     echo 'YOUR_TOKEN' > ${tokenPath}`);
        printPlain(`     chmod 600 ${tokenPath}`);
        printPlain();
        step += 1;
        break;
      case "ok":
        break;
    }
{{- if ne "" .emailWork }}

    if (!hasGhAuth) {
      print("white", ["bold"], `  ${step}. Authenticate GitHub CLI`);
      printPlain();
      print("white", ["dim"], "     Run:");
      printPlain("     gh auth login");
      printPlain();
      step += 1;
    }

    if (workMissing.length > 0) {
      print("white", ["bold"], `  ${step}. Configure work-specific values`);
      printPlain();
      print("white", ["dim"], "     Run:");
      printPlain("     chezmoi edit-config");
      printPlain();
      print("white", ["dim"], "     Add under [data]:");
      for (const variable of workMissing) {
        printPlain(`       ${variable} = "..."`);
      }
      printPlain();
      step += 1;
    }
{{- end }}

    print("white", ["bold"], `  ${step}. Re-apply dotfiles`);
    printPlain();
    print("white", ["dim"], "     Re-apply to pick up changes:");
    printPlain("     chezmoi apply --force");

    printPlain();
  });

const main: Effect.Effect<number> = Effect.gen(function* () {
  const args = parseArgs(Deno.args);

  if (args.kind === "help") {
    printPlain(HELP);
    return 0;
  }

  const bws = yield* checkBwsToken;
  if (args.probeOnly) {
    return bws.exitCode;
  }
{{- if ne "" .emailWork }}

  const hasGhAuth = yield* checkGhAuth;
  const workMissing = yield* checkWorkConfig;
  const tokenPath = yield* bwsTokenPath;

  yield* printStatus(bws.state, hasGhAuth, workMissing);
  yield* printInstructions(bws.state, tokenPath, hasGhAuth, workMissing);
{{- else }}
  const tokenPath = yield* bwsTokenPath;
  yield* printStatus(bws.state);
  yield* printInstructions(bws.state, tokenPath);
{{- end }}
  return 0;
});

if (import.meta.main) {
  // Last-resort backstop: catch anything that escapes the Effect runtime
  // (raw node-stream callbacks, forked-fiber defects, unhandled rejections).
  // NodeRuntime.runMain does NOT install these (only SIGINT/SIGTERM) — verified
  // against effect-smol source. Inside import.meta.main so `deno test` stays hermetic.
  globalThis.addEventListener("unhandledrejection", (event) => {
    event.preventDefault();
    console.error(`error uncaught rejection: ${event.reason}`);
    Deno.exit(1);
  });
  globalThis.addEventListener("error", (event) => {
    event.preventDefault();
    console.error(`error uncaught: ${event.message}`);
    Deno.exit(1);
  });

  Effect.runPromiseExit(main).then((exit) => {
    if (exit._tag === "Success") {
      Deno.exit(exit.value);
    }
    console.error(exit.cause);
    Deno.exit(1);
  }).catch((err) => {
    console.error(err);
    Deno.exit(1);
  });
}
