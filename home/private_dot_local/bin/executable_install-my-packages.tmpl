#!/usr/bin/env bash
set -euo pipefail

IFS=$'\n\t'

# Source shared logging library and setup session logging
source "${HOME}/.local/lib/bash-logging.sh"
setup_session_logging "$(basename "$0")"

#/ Usage:
#/   install-my-packages [--gui]
#/
#/ Description:
#/   Installs non-critical packages.
#/
#/ Environment Variables:
#/   DEBUG=1      Enable command tracing (set -x) in logs
#/
#/ Options:
#/   --gui:       Includes GUI app packages, like browsers etc.
#/   --help:      Display this help message
usage() { grep '^#/' "$0" | cut -c4-; }

parse_args() {
  gui=1

  while [ "$#" -gt 0 ]; do
    case "$1" in
      --help)
        usage
        exit 0
        ;;
      --gui)
        gui=0
        ;;
      *)
        usage
        fatal "Unknown argument: $1"
        ;;
    esac
    shift
  done
}

main() {
  parse_args "$@"
  info "▶ Installing non-critical packages"

  export PATH="${HOME}/.local/bin:${PATH}"
  export PATH="$HOME/.local/share/mise/shims:$PATH"

  {{ if eq .chezmoi.os "darwin" }}
  #
  #-----------------------------------------------------------------------------
  # Macos-only
  #-----------------------------------------------------------------------------
  #

  info "╍ Running 'brew install'"
  if ! command -v brew >/dev/null 2>&1; then
    fatal "Homebrew is not installed. Please install Homebrew first: https://brew.sh"
  fi

  PATH="$PATH:{{ .brewprefix }}/bin"

  {{ $brews := list
       "bash"
       "coreutils"
       "ffmpeg"
       "ghostscript"
       "git"
       "git-lfs"
       "gnupg"
       "handbrake"
       "htop"
       "less"
       "lua"
       "make"
       "ncdu"
       "ncurses"
       "PeonPing/tap/peon-ping"
       "pinentry"
       "pinentry-mac"
       "readline"
       "rename"
       "safe-rm"
       "poppler"
       "shellcheck"
       "terminal-notifier"
       "tesseract"
       "tree"
       "wget"
       "wireguard-tools"
       "zsh" -}}
  {{ $casks := list
       "alfred"
       "bartender"
       "brave-browser"
       "docker"
       "figma"
       "finicky"
       "firefox"
       "fontgoggles"
       "glyphs"
       "google-chrome"
       "imageoptim"
       "insomnia"
       "iterm2"
       "jetbrains-toolbox"
       "kap"
       "logitune"
       "smart-mcp-proxy/mcpproxy/mcpproxy"
       "notion"
       "stablyai/orca/orca"
       "paseo"
       "private-internet-access"
       "qlcolorcode"
       "qlimagesize"
       "qlmarkdown"
       "quicklook-video"
       "quicklookase"
       "rectangle"
       "rive"
       "rocket"
       "slack"
       "spotify"
       "sublime-text"
       "visual-studio-code" -}}

  if ! command -v brew > /dev/null; then
    NONINTERACTIVE=1 /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
  fi

  {{ $taps := list
       "smart-mcp-proxy/mcpproxy"
       "stablyai/orca" -}}

  # Brew managed programs/libraries
  run_quiet brew bundle --file=/dev/stdin <<EOF
{{ range ($taps | sortAlpha | uniq) -}}
tap {{ . | quote }}
{{ end -}}
{{ range ($brews | sortAlpha | uniq) -}}
brew {{ . | quote }}
{{ end -}}
EOF

  # Brew managed GUI
  if [ $gui -eq 0 ]; then
    run_quiet brew bundle --file=/dev/stdin <<EOF
{{ range ($casks | sortAlpha | uniq) -}}
cask {{ . | quote }}
{{ end -}}
EOF
  fi

  {{ else if eq .chezmoi.os "linux" -}}
  #
  #-----------------------------------------------------------------------------
  # Linux-only
  #-----------------------------------------------------------------------------
  #

  {{ $pkgs := list
  "bash"
  "bison"
  "coreutils"
  "ffmpeg"
  "git"
  "ghostscript"
  "git-lfs"
  "gnupg"
  "less"
  "libevent-dev"
  "libncurses-dev"
  "make"
  "pkg-config"
  "poppler-utils"
  "python3"
  "rename"
  "safe-rm"
  "tesseract-ocr"
  "tesseract-ocr-eng"
  "tree"
  "wget"
  "zsh" -}}

  # Distro-specific package name divergence:
  # - Ubuntu/Debian provides notify-send via the `libnotify-bin` package
  # - Alpine + RHEL/Fedora provide it via `libnotify`
  # FUSE2 (needed for AppImage execution; orca's runtime mode on Linux):
  # - Ubuntu 22.04 / Debian 12: `libfuse2`
  # - Ubuntu 24.04+: `libfuse2t64` (t64 is the time_t-64bit transition variant)
  # - Alpine: `fuse`
  # - RHEL/Fedora: `fuse-libs`
  # Apt's name is version-dependent so we pick at runtime; see the apt branch
  # below. The other distros have stable names.
  {{ $pkgsAptExtra := list "libnotify-bin" -}}
  {{ $pkgsApkExtra := list "libnotify" "fuse" -}}
  {{ $pkgsYumExtra := list "libnotify" "fuse-libs" -}}

  packages=$(cat <<EOF
{{ range ($pkgs | sortAlpha | uniq) -}}
  {{ . | quote }}
{{ end -}}
EOF
)

  if [ "$(id -u)" = "0" ]; then
    Sudo=''
    info "╍ Root user detected, skipping sudo for following commands"
  elif which sudo >/dev/null 2>&1; then
    Sudo='sudo'
    info "╍ Sudo detected, using it for following commands"
  else
    Sudo=''
    warning "╍ Cannot find 'sudo' so will attempt to run following commands without it"
  fi
  linux_distro=$(
    . /etc/os-release
    echo "$ID"
  )
  case $linux_distro in
    alpine)
      apk_extra=$(cat <<EOF
{{ range ($pkgsApkExtra | sortAlpha | uniq) -}}
  {{ . | quote }}
{{ end -}}
EOF
)
      info "╍ Running 'apk add \$packages \$apk_extra'"
      run_quiet bash -c "$Sudo apk add --update $(echo "$packages $apk_extra" | xargs)"
    ;;
    amzn|rhel|fedora|rocky)
      yum_extra=$(cat <<EOF
{{ range ($pkgsYumExtra | sortAlpha | uniq) -}}
  {{ . | quote }}
{{ end -}}
EOF
)
      info "╍ Running 'yum install \$packages \$yum_extra'"
      run_quiet $Sudo yum update -y
      run_quiet bash -c "$Sudo yum install -y $(echo "$packages $yum_extra" | xargs)"
    ;;
    ubuntu|debian)
      apt_extra=$(cat <<EOF
{{ range ($pkgsAptExtra | sortAlpha | uniq) -}}
  {{ . | quote }}
{{ end -}}
EOF
)
      # FUSE2 package name varies by Ubuntu version. Probe apt-cache for both
      # candidates and pick whichever is available. Skip if neither is found
      # (rare; we'd want to know).
      fuse_pkg=""
      for candidate in libfuse2t64 libfuse2; do
        if apt-cache show "$candidate" >/dev/null 2>&1; then
          fuse_pkg="$candidate"
          break
        fi
      done
      if [ -n "$fuse_pkg" ]; then
        apt_extra="$apt_extra \"$fuse_pkg\""
        info "╍ FUSE2 package resolved to: $fuse_pkg"
      else
        warning "╍ neither libfuse2 nor libfuse2t64 found in apt cache; AppImage execution may fail"
      fi
      info "╍ Running 'apt-get install \$packages \$apt_extra'"
      run_quiet $Sudo apt-get update
      run_quiet bash -c "$Sudo apt-get install --no-install-recommends -y $(echo "$packages $apt_extra" | xargs)"
    ;;
    *)
      fatal "The \"$linux_distro\" is not supported yet. Full release details from /etc/os-release:\n$(cat /etc/os-release)\n\nAdd '$linux_distro' and it's package manager to this script."
    ;;
  esac

  {{ else }}
  #
  #-----------------------------------------------------------------------------
  # Unsupported OS
  #-----------------------------------------------------------------------------
  #

  fatal "Not implemented for this OS: {{ .chezmoi.os }}"

  {{ end }}

  info "╍ Running 'mise self-update --yes'"
  run_quiet mise self-update --yes || true

  info "╍ Running 'mise install'"
  run_quiet mise install -y

  info "╍ Running 'mise upgrade'"
  run_quiet mise upgrade -y
}

main "$@"
