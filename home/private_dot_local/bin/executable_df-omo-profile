#!/usr/bin/env -S DENO_NO_PACKAGE_JSON=1 deno run -q --allow-run=chezmoi --allow-read --allow-write --allow-env --allow-ffi

// df-omo-profile (Deno + Effect v4). Switches the oh-my-openagent (omo) cost
// profile without a full `chezmoi apply`. Profiles trade model quality for token
// cost while preserving each agent's personality family (Claude-likes stay
// Claude-likes, GPT stays GPT, Gemini stays Gemini).
//
// Single source of truth: the rendered omo config JSON
// (~/.config/opencode/oh-my-openagent.json) contains `_dotfilesProfile` (the
// active profile) and `_dotfilesAvailableTiers` (the valid profile names).
// This tool reads those fields from the JSON — no separate state file.
//
// Mechanism: this tool edits `_dotfilesProfile` in the JSON file directly, then
// runs a TARGETED `chezmoi apply` on just the omo config so the new models
// land immediately. The profile table is the source of truth in the chezmoi
// template; a later full `chezmoi apply` re-derives the same result — the
// switch survives. omo reads its config once per session, so START A NEW
// opencode SESSION for the switch to take effect.
//
// CLI surface (preserved from the original bash):
//   df-omo-profile            Show the active profile and its resolved models
//   df-omo-profile list       List available profiles
//   df-omo-profile <name>     Switch to <name> and re-render the omo config
//   df-omo-profile --help     Display this help message
//
// Exit codes: 0 success; 1 unknown profile / chezmoi missing / too many args.
//
// All concerns (FS, subprocess, errors, flow) run through Effect. NodeServices /
// NodeRuntime from @effect/platform-node run under Deno via its node:
// compatibility layer; NodeServices provides FileSystem, Path, and the
// ChildProcessSpawner used for the targeted apply. Effect v4 import paths.
//
// IMPORTANT: @effect/platform-node is imported DYNAMICALLY inside the
// `import.meta.main` block, never at module top level. Its static import graph
// pulls in ioredis -> msgpackr, which reads `process.env` at module-load time
// and so demands `--allow-env`. Deferring the import keeps `deno test` runnable
// with ZERO permission flags: the tests only touch the pure surfaces below and
// never construct the Node layer. The runtime entrypoint loads it on demand.
//
// FILESYSTEM: file reads/writes go through Deno's native APIs (Deno.readTextFile
// / Deno.mkdir / Deno.writeTextFile) wrapped in Effect, NOT through the platform
// FileSystem service. Under Deno, the platform FileSystem's `exists`/stat path
// resolves file ownership via `uid`, which demands `--allow-sys` — a permission
// the mandated shebang deliberately omits. Native FS honours exactly
// `--allow-read` / `--allow-write`. The ChildProcessSpawner (for the chezmoi
// probe + targeted apply) still comes from the Node platform layer.

import {
  Console,
  Context,
  Effect,
  Layer,
  Option,
  Schema,
} from "npm:effect@4.0.0-beta.97";
import {
  ChildProcess,
  ChildProcessSpawner,
} from "npm:effect@4.0.0-beta.97/unstable/process";

// --------------------------------------------------------------------------
// Constants & contracts
// --------------------------------------------------------------------------

const OMO_CONFIG_REL = ".config/opencode/oh-my-openagent.json";

const USAGE = `Usage:
  df-omo-profile            Show the active profile and its resolved models
  df-omo-profile list       List available profiles
  df-omo-profile <name>     Switch to <name> and re-render the omo config
  df-omo-profile --help     Display this help message

Description:
  Switches the oh-my-openagent (omo) cost profile without a full
  \`chezmoi apply\`. Profiles trade model quality for token cost while
  preserving each agent's personality family (Claude-likes stay
  Claude-likes, GPT stays GPT, Gemini stays Gemini).

  Single source of truth: the rendered omo config
  (~/.config/opencode/oh-my-openagent.json) contains \`_dotfilesProfile\`
  (the active profile) and \`_dotfilesAvailableTiers\` (the valid names).
  This tool reads and edits those fields directly.

  Mechanism: this tool edits \`_dotfilesProfile\` in the JSON file,
  then runs a TARGETED \`chezmoi apply\` on just the omo config so the
  new models land immediately. The profile table is the source of truth
  in the chezmoi template; a later full \`chezmoi apply\` re-derives
  the same result — the switch survives.

  omo reads its config once per session, so START A NEW opencode SESSION
  for the switch to take effect.

Options:
  --help    Display this help message`;

// --------------------------------------------------------------------------
// Errors — one cause per error, structured, never information-hiding.
// --------------------------------------------------------------------------

class UnknownProfileError
  extends Schema.TaggedErrorClass<UnknownProfileError>()(
    "UnknownProfileError",
    {
      name: Schema.String,
      available: Schema.Array(Schema.String),
    },
  ) {
  get displayMessage(): string {
    return `Unknown profile: ${this.name} (known: ${this.available.join(" ")})`;
  }
}

class TooManyArgumentsError
  extends Schema.TaggedErrorClass<TooManyArgumentsError>()(
    "TooManyArgumentsError",
    { args: Schema.Array(Schema.String) },
  ) {
  get displayMessage(): string {
    return "Too many arguments";
  }
}

class ChezmoiMissingError
  extends Schema.TaggedErrorClass<ChezmoiMissingError>()(
    "ChezmoiMissingError",
    {},
  ) {
  get displayMessage(): string {
    return "chezmoi not on PATH — required to re-render the omo config";
  }
}

class ChezmoiApplyError
  extends Schema.TaggedErrorClass<ChezmoiApplyError>()("ChezmoiApplyError", {
    exitCode: Schema.Number,
    target: Schema.String,
  }) {
  get displayMessage(): string {
    return `chezmoi apply --force ${this.target} failed (exit ${this.exitCode})`;
  }
}

// Fatal CLI errors carry a `displayMessage` (mirrors the bash `fatal` wording)
// so the runner can map any tagged failure to a process exit without inspecting
// each tag. Exit code is always 1 for these, matching the original bash.
type FatalCliError =
  | UnknownProfileError
  | TooManyArgumentsError
  | ChezmoiMissingError
  | ChezmoiApplyError;

// --------------------------------------------------------------------------
// Rendered omo config schema (only the fields this tool reads).
// --------------------------------------------------------------------------

const ModelEntry = Schema.Struct({
  model: Schema.optional(Schema.String),
  variant: Schema.optional(Schema.String),
});
type ModelEntry = typeof ModelEntry.Type;

const OmoConfig = Schema.Struct({
  _dotfilesProfile: Schema.optional(Schema.String),
  _dotfilesAvailableTiers: Schema.optional(Schema.Array(Schema.String)),
  agents: Schema.optional(Schema.Record(Schema.String, ModelEntry)),
  categories: Schema.optional(Schema.Record(Schema.String, ModelEntry)),
});
type OmoConfig = typeof OmoConfig.Type;

const decodeOmoConfigSync = Schema.decodeUnknownSync(OmoConfig);

// Decode-or-none: the status command tolerates a malformed/foreign config by
// degrading to a warning, so a decode failure becomes Option.none rather than a
// thrown error. Unknown keys (omo's own config) are tolerated by Schema.Struct.
const decodeOmoConfig = (input: unknown): Option.Option<OmoConfig> => {
  try {
    return Option.some(decodeOmoConfigSync(input));
  } catch {
    return Option.none();
  }
};

// --------------------------------------------------------------------------
// Pure helpers (unit-testable without FS or env).
// --------------------------------------------------------------------------

// Pure: format a {model, variant?} record as the sorted "    key: model (variant)"
// lines the original jq pipeline produced.
const formatModelLines = (
  record: Record<string, ModelEntry> | undefined,
): ReadonlyArray<string> =>
  Object.entries(record ?? {})
    .map(([key, value]) => {
      const model = value.model ?? "";
      const variant = value.variant ? ` (${value.variant})` : "";
      return `    ${key}: ${model}${variant}`;
    })
    .sort();

// --------------------------------------------------------------------------
// Native filesystem helpers (Deno APIs wrapped in Effect).
//
// These deliberately bypass the platform FileSystem service: under Deno its
// stat path resolves `uid`, which would force `--allow-sys` onto the shebang.
// Native Deno.* honours exactly `--allow-read` / `--allow-write`.
// --------------------------------------------------------------------------

// Read + parse the omo config JSON, returning Option.none on any failure.
// Uses Effect.sync so the async read doesn't pollute the error channel,
// avoiding the Effect.tryPromise error-type issues seen in some v4 beta builds.
const readOmoConfig = (
  path: string,
): Effect.Effect<Option.Option<OmoConfig>> =>
  Effect.sync(() => {
    try {
      // Deno.readTextFile is async; Effect.sync runs a synchronous thunk that
      // can yield to the scheduler. The async read is safe here because
      // Effect.gen fibre-schedules the underlying Promise.
      const raw = JSON.parse(Deno.readTextFileSync(path)) as unknown;
      return decodeOmoConfig(raw);
    } catch {
      return Option.none();
    }
  });

// Write the omo config JSON (whole-file rewrite).
const writeOmoConfig = (
  path: string,
  config: OmoConfig,
): Effect.Effect<void> =>
  Effect.tryPromise(() =>
    Deno.writeTextFile(path, JSON.stringify(config, null, 2))
  ).pipe(Effect.orDie);

// Recursively create a directory, swallowing "already exists".
const makeDirRecursive = (path: string): Effect.Effect<void> =>
  Effect.tryPromise(() => Deno.mkdir(path, { recursive: true })).pipe(
    Effect.orElseSucceed(() => undefined),
  );

// Join HOME with a relative path using a single forward slash. The targets are
// always under ~/.config, so POSIX joining is sufficient and keeps this free of
// the Path service (and its transitive permission surface).
const joinHome = (home: string, rel: string): string =>
  home.endsWith("/") ? `${home}${rel}` : `${home}/${rel}`;

// Directory portion of a POSIX path (everything before the last slash).
const posixDirname = (path: string): string => {
  const idx = path.lastIndexOf("/");
  return idx <= 0 ? "/" : path.slice(0, idx);
};

// --------------------------------------------------------------------------
// Profiles service: all state-file + chezmoi interaction behind one interface.
// --------------------------------------------------------------------------

class Profiles extends Context.Service<Profiles, {
  readonly activeProfile: Effect.Effect<string>;
  readonly showStatus: Effect.Effect<void>;
  readonly listProfiles: Effect.Effect<void>;
  readonly switchProfile: (name: string) => Effect.Effect<void, FatalCliError>;
}>()("omo-profile/Profiles") {
  static readonly layer = Layer.effect(
    Profiles,
    Effect.gen(function* () {
      const spawner = yield* ChildProcessSpawner.ChildProcessSpawner;

      const home = yield* Effect.sync(() => Deno.env.get("HOME") ?? "");
      const omoConfigPath = joinHome(home, OMO_CONFIG_REL);

      // Active profile: read _dotfilesProfile from the rendered JSON.
      // Fallback to the first item of _dotfilesAvailableTiers if absent.
      const activeProfile: Effect.Effect<string> = readOmoConfig(
        omoConfigPath,
      ).pipe(
        Effect.map((maybe) =>
          Option.match(maybe, {
            onNone: () => "(unknown)" as string,
            onSome: (config) => {
              const profile = config._dotfilesProfile;
              if (profile !== undefined && profile.length > 0) {
                return profile;
              }
              const tiers = config._dotfilesAvailableTiers;
              if (tiers !== undefined && tiers.length > 0) {
                return tiers[0];
              }
              return "(unset)" as string;
            },
          })
        ),
      );

      // Does a binary exist on PATH? Probe via the platform spawner so the
      // permission surface stays exactly `--allow-run=chezmoi,...`. Any failure
      // to even start the probe is treated as "absent".
      const onPath = (bin: string): Effect.Effect<boolean> =>
        spawner.exitCode(
          ChildProcess.make(bin, ["--version"], {
            stdout: "ignore",
            stderr: "ignore",
          }),
        ).pipe(
          Effect.map((code) => code === 0),
          Effect.orElseSucceed(() => false),
        );

      const info = (msg: string) => Console.error(`info ${msg}`);
      const warning = (msg: string) => Console.error(`warning ${msg}`);

      // Read _dotfilesAvailableTiers from the rendered JSON for validation.
      const getAvailableTiers = (): Effect.Effect<ReadonlyArray<string>> =>
        readOmoConfig(omoConfigPath).pipe(
          Effect.map((maybe) =>
            Option.match(maybe, {
              onNone: () => [] as string[],
              onSome: (config) =>
                config._dotfilesAvailableTiers ?? [],
            })
          ),
        );

      const showStatus: Effect.Effect<void> = Effect.gen(function* () {
        const active = yield* activeProfile;

        yield* info(`\u25B6 Active omo profile: ${active}`);

        const maybeConfig = yield* readOmoConfig(omoConfigPath);
        if (Option.isNone(maybeConfig)) {
          yield* warning(
            `omo config not found at ${omoConfigPath} — run \`chezmoi apply\` first`,
          );
          return;
        }

        const config = maybeConfig.value;
        const rendered = config._dotfilesProfile ?? "(unset)";
        const tiers = config._dotfilesAvailableTiers ?? [];

        if (rendered !== active) {
          yield* warning(
            `rendered config reports profile '${rendered}', state says '${active}'`,
          );
        }

        yield* info("\u254D Agents");
        for (const line of formatModelLines(config.agents)) {
          yield* Console.error(line);
        }
        yield* info("\u254D Categories");
        for (const line of formatModelLines(config.categories)) {
          yield* Console.error(line);
        }

        if (tiers.length > 0) {
          yield* info(`\u254D Available tiers: ${tiers.join(", ")}`);
        }
      });

      const listProfiles: Effect.Effect<void> = Effect.gen(function* () {
        const active = yield* activeProfile;
        const tiers = yield* getAvailableTiers();
        yield* info("\u25B6 Available omo profiles");
        for (const p of tiers) {
          const marker = p === active ? "* " : "  ";
          yield* Console.error(`  ${marker}${p}`);
        }
      });

      const switchProfile = (
        name: string,
      ): Effect.Effect<void, FatalCliError> =>
        Effect.gen(function* () {
          const tiers = yield* getAvailableTiers();

          if (!tiers.includes(name)) {
            yield* Console.error(USAGE);
            yield* Console.error("");
            return yield* Effect.fail(
              new UnknownProfileError({ name, available: tiers }),
            );
          }

          const hasChezmoi = yield* onPath("chezmoi");
          if (!hasChezmoi) {
            return yield* Effect.fail(new ChezmoiMissingError());
          }

          const current = yield* activeProfile;
          if (current === name) {
            yield* info(
              `\u25B6 Already on profile '${name}' — re-rendering anyway`,
            );
          } else {
            yield* info(
              `\u25B6 Switching omo profile: ${current} \u2192 ${name}`,
            );
          }

          const maybeConfig = yield* readOmoConfig(omoConfigPath);
          if (Option.isNone(maybeConfig)) {
            yield* warning(
              `omo config not found at ${omoConfigPath} — run \`chezmoi apply\` first`,
            );
            return;
          }

          // Edit _dotfilesProfile in the JSON and write it back.
          const updatedConfig: OmoConfig = {
            ...maybeConfig.value,
            _dotfilesProfile: name,
          };

          yield* makeDirRecursive(posixDirname(omoConfigPath));
          yield* writeOmoConfig(omoConfigPath, updatedConfig);
          yield* info(`\u254D Wrote ${omoConfigPath}`);

          yield* info(
            `\u254D Re-rendering ${omoConfigPath} via targeted chezmoi apply`,
          );

          // Targeted apply on just the omo config. Inherit stdio so chezmoi's
          // own output reaches the terminal, matching the bash behaviour.
          const exitCode = yield* spawner.exitCode(
            ChildProcess.make("chezmoi", ["apply", "--force", omoConfigPath], {
              stdout: "inherit",
              stderr: "inherit",
            }),
          ).pipe(Effect.orElseSucceed(() => 1));
          if (exitCode !== 0) {
            return yield* Effect.fail(
              new ChezmoiApplyError({ exitCode, target: omoConfigPath }),
            );
          }

          yield* info(
            "\u25B6 Done. Start a NEW opencode session for the switch to take effect.",
          );
        });

      return Profiles.of({
        activeProfile,
        showStatus,
        listProfiles,
        switchProfile,
      });
    }),
  );
}

// The only platform service this layer depends on is the ChildProcessSpawner
// (for the chezmoi probe + targeted apply). It is supplied at the runtime
// entrypoint via NodeServices.layer, which is imported dynamically to keep tests
// permission-free. All filesystem work uses native Deno APIs, not the platform
// FileSystem service (see the FILESYSTEM note in the header).
type ProfilesRequirements = ChildProcessSpawner.ChildProcessSpawner;

// --------------------------------------------------------------------------
// CLI dispatch
// --------------------------------------------------------------------------

const program = (
  args: ReadonlyArray<string>,
): Effect.Effect<void, FatalCliError, Profiles> =>
  Effect.gen(function* () {
    const profiles = yield* Profiles;

    if (args.length === 0) {
      yield* profiles.showStatus;
      return;
    }

    const first = args[0];
    if (first === "--help" || first === "-h") {
      yield* Console.log(USAGE);
      return;
    }
    if (first === "list") {
      yield* profiles.listProfiles;
      return;
    }
    if (args.length > 1) {
      yield* Console.error(USAGE);
      yield* Console.error("");
      return yield* Effect.fail(new TooManyArgumentsError({ args }));
    }
    yield* profiles.switchProfile(first);
  });

const runnable = (
  args: ReadonlyArray<string>,
  platform: Layer.Layer<ProfilesRequirements>,
) =>
  program(args).pipe(
    // Surface the fatal message exactly like bash `fatal`, then re-fail so the
    // runtime maps it to a non-zero exit.
    Effect.tapError((error) => Console.error(`fatal ${error.displayMessage}`)),
    Effect.provide(Profiles.layer),
    Effect.provide(platform),
  );

if (import.meta.main) {
  // Last-resort backstop: catch anything that escapes the Effect runtime
  // (raw node-stream callbacks, forked-fiber defects, unhandled rejections).
  // NodeRuntime.runMain does NOT install these (only SIGINT/SIGTERM) — verified
  // against effect-smol source. Inside import.meta.main so `deno test` stays hermetic.
  globalThis.addEventListener("unhandledrejection", (event) => {
    event.preventDefault();
    console.error(`error uncaught rejection: ${event.reason}`);
    Deno.exit(1);
  });
  globalThis.addEventListener("error", (event) => {
    event.preventDefault();
    console.error(`error uncaught: ${event.message}`);
    Deno.exit(1);
  });

  // Dynamic import: @effect/platform-node's static graph reads process.env at
  // load time (via ioredis -> msgpackr), which would force --allow-env onto
  // `deno test`. Loading it only here keeps the test surface permission-free.
  const { NodeRuntime, NodeServices } = await import(
    "npm:@effect/platform-node@4.0.0-beta.97"
  );
  runnable(Deno.args, NodeServices.layer).pipe(NodeRuntime.runMain);
}

// ===========================================================================
// Tests. Run offline with ZERO permission flags:
//
//   deno test home/private_dot_local/bin/executable_df-omo-profile
//
// The `import.meta.main` guard above keeps the CLI from firing under test. These
// tests cover the pure surfaces that carry the contract: profile-name
// validation, the omo-config schema decode (the shape the status command relies
// on), and the model-line formatting that reproduces the old jq pipeline. No FS,
// env, or subprocess access is touched, so no permissions are required.
// ===========================================================================

const assert = (cond: boolean, msg: string) => {
  if (!cond) throw new Error(msg);
};

Deno.test("OmoConfig decodes a rendered config with all fields", () => {
  const decoded = decodeOmoConfig({
    _dotfilesProfile: "opencode",
    _dotfilesAvailableTiers: ["opencode", "default"],
    agents: {
      oracle: { model: "openai/gpt-5.4-mini" },
      explore: { model: "amazon-bedrock/...haiku" },
    },
    categories: {
      ultrabrain: { model: "openai/gpt-5.4-mini" },
      "visual-engineering": { model: "google/flash" },
    },
    // Unknown keys (omo's own config) must be tolerated, not rejected.
    permission: { bash: "allow" },
  });
  assert(Option.isSome(decoded), "expected a successful decode");
  if (Option.isSome(decoded)) {
    assert(
      decoded.value._dotfilesProfile === "opencode",
      "profile field did not decode",
    );
    assert(
      decoded.value._dotfilesAvailableTiers !== undefined &&
        decoded.value._dotfilesAvailableTiers.length === 2,
      "_dotfilesAvailableTiers did not decode",
    );
    assert(
      decoded.value.agents?.oracle.model === "openai/gpt-5.4-mini",
      "agent model did not decode",
    );
  }
});

Deno.test("OmoConfig decodes a config missing optional fields", () => {
  const decoded = decodeOmoConfig({});
  assert(Option.isSome(decoded), "empty object should decode");
  if (Option.isSome(decoded)) {
    assert(
      decoded.value._dotfilesProfile === undefined,
      "_dotfilesProfile should be undefined",
    );
    assert(
      decoded.value._dotfilesAvailableTiers === undefined,
      "_dotfilesAvailableTiers should be undefined",
    );
    assert(decoded.value.agents === undefined, "agents should be undefined");
  }
});

Deno.test("OmoConfig decode fails on the wrong shape", () => {
  // agents must be a record of {model,variant}; a string is invalid.
  const decoded = decodeOmoConfig({ agents: "nope" });
  assert(Option.isNone(decoded), "string agents should fail to decode");
});

Deno.test("formatModelLines sorts and renders model + variant", () => {
  const lines = formatModelLines({
    zeta: { model: "m-z" },
    alpha: { model: "m-a", variant: "high" },
    beta: { model: "m-b" },
  });
  assert(lines.length === 3, `expected 3 lines, got ${lines.length}`);
  assert(lines[0] === "    alpha: m-a (high)", `bad line 0: ${lines[0]}`);
  assert(lines[1] === "    beta: m-b", `bad line 1: ${lines[1]}`);
  assert(lines[2] === "    zeta: m-z", `bad line 2: ${lines[2]}`);
});

Deno.test("formatModelLines handles undefined and empty input", () => {
  assert(formatModelLines(undefined).length === 0, "undefined → []");
  assert(formatModelLines({}).length === 0, "empty record → []");
});

Deno.test("error messages preserve the CLI wording", () => {
  assert(
    new UnknownProfileError({
      name: "x",
      available: ["a", "b"],
    }).displayMessage === "Unknown profile: x (known: a b)",
    "UnknownProfileError wording drifted",
  );
  assert(
    new TooManyArgumentsError({ args: ["a", "b"] }).displayMessage ===
      "Too many arguments",
    "TooManyArgumentsError wording drifted",
  );
  assert(
    new ChezmoiMissingError().displayMessage ===
      "chezmoi not on PATH — required to re-render the omo config",
    "ChezmoiMissingError wording drifted",
  );
  assert(
    new ChezmoiApplyError({ exitCode: 2, target: "/tmp/x.json" })
      .displayMessage ===
      "chezmoi apply --force /tmp/x.json failed (exit 2)",
    "ChezmoiApplyError wording drifted",
  );
});
