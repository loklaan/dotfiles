#!/usr/bin/env -S deno run --allow-read --allow-net=raw.githubusercontent.com,api.github.com,github.com --allow-env --allow-ffi

// opencode-tokenizer-check — local drift guard for the patched OpenCode
// context-usage tokenizer resolver. This intentionally does NOT couple to the
// live upstream plugin at test time: offline checks lock the local source files;
// `drift-json --refresh-upstream` is the only network path.
// Effect v4 beta import paths verified against effect@4.0.0-beta.83.

import { Console, Effect, Schema } from "npm:effect@4.0.0-beta.83";
import { Command } from "npm:effect@4.0.0-beta.83/unstable/cli";
// @effect/platform-node is imported dynamically in import.meta.main only.
// It transitively loads msgpackr, which reads process.env at module load and
// throws NotCapable without --allow-env. Dynamic import keeps deno test
// zero-flag offline.

// ============================================================================
// Constants locked to the reviewed local patch and upstream archive.
// ============================================================================

const EXPECTED_UPSTREAM_COMMIT = "3676b9f2";
const KNOWN_UPSTREAM_TRANSFORMERS_RANGE = "^3.3.3";
const KNOWN_UPSTREAM_TIKTOKEN_RANGE = "latest";
const EXPECTED_TRANSFORMERS_PIN = "3.8.1";
const EXPECTED_TIKTOKEN_PIN = "1.0.21";

const ALIASES_PATH = "home/.chezmoitemplates/opencode-tokenizer-aliases-json";
const REGISTRY_PATH = "home/.chezmoitemplates/opencode-tokenizer-registry-mjs";
const SETUP_SCRIPT_PATH =
  "home/.chezmoiscripts/run_onchange_after_install-065-setup-opencode-plugin.sh.tmpl";
const EXTERNAL_PATH = "home/.chezmoiexternals/opencode.toml.tmpl";

const UPSTREAM_README_URL =
  `https://raw.githubusercontent.com/IgorWarzocha/Opencode-Context-Analysis-Plugin/${EXPECTED_UPSTREAM_COMMIT}/README.md`;

// Qwen3 decision, verified 2026-06-16:
// - HF API for Qwen/Qwen3-32B shows tokenizer.json, tokenizer_config.json, and
//   vocab.json.
// - `AutoTokenizer.from_pretrained("Qwen/Qwen3-32B")` loads under
//   @huggingface/transformers@3.8.1.
// - tokenizer.json differs from Qwen/Qwen2.5-Coder-32B-Instruct:
//   Qwen3-32B sha256 aeb13307a71acd8fe81861d94ad54ab689df773318809eed3cbe794b4492dae4
//   Qwen2.5-Coder sha256 c0382117ea329cdf097041132f6d735924b697924d6f6fc3945713e96ce87539
// Therefore qwen* Bedrock IDs intentionally resolve to the Qwen3 hub, not the
// old Qwen2.5 guess and not char/4.
const QWEN3_HUB = "Qwen/Qwen3-32B";

type TokenizerSpec =
  | { readonly kind: "transformers"; readonly hub: string }
  | { readonly kind: "tiktoken"; readonly model: string }
  | { readonly kind: "approx"; readonly method: "char/4" };

interface ResolutionCase {
  readonly modelID: string;
  readonly expected: TokenizerSpec;
  readonly note: string;
}

// The 16 amazon-bedrock whitelist IDs from modify_opencode.json. These are the
// high-value lock: dotted single-provider IDs exercise the local family tier,
// including unsupported families that deliberately fall through to char/4.
