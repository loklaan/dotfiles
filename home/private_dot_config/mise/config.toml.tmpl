[tools]
# Global tools listed here will be automatically installed.
"github:bitwarden/sdk" = { version = "bws-v1.0.0", exe = "bws", tag_regex = "^bws" }
"github:psastras/sarif-rs" = { version = "sarif-fmt-v0.8.0", exe = "sarif-fmt", matching = "sarif-fmt", tag_regex = "^sarif-fmt" }
{{ if eq .chezmoi.os "linux" -}}
"github:smart-mcp-proxy/mcpproxy-go" = { version = "0.24.2", exe = "mcpproxy" }
{{ end -}}
age = "latest"
bitwarden = "2025.10.0"
chezmoi = "2.67.0"
codex = "latest"
d2 = "0.7.1"
delta = "0.18.2"
deno = "2.5.4"
difftastic = "0.65.0"
fzf = "0.66.0"
gemini = "latest"
go = "1.25.3"
jq = "latest"
yq = "latest"
node = "22.22.0"
"npm:oh-my-openagent" = "latest"
opencode = "latest"
python = "3.12"
rust = "1.90.0"
shellcheck = "0.11.0"
starship = "1.24.2"
tmux = "3.6a"
uv = "0.9.26"

[env]
OMO_SEND_ANONYMOUS_TELEMETRY = "0"

[settings]
idiomatic_version_file_enable_tools = ["node"]
experimental = true
gix = false
