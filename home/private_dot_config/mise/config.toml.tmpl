[tools]
# Global tools listed here will be automatically installed.
"github:bitwarden/sdk" = { version = "bws-v2.1.0", exe = "bws", tag_regex = "^bws" }
"github:psastras/sarif-rs" = { version = "sarif-fmt-v0.8.0", exe = "sarif-fmt", matching = "sarif-fmt", tag_regex = "^sarif-fmt" }
{{ if eq .chezmoi.os "linux" -}}
"github:smart-mcp-proxy/mcpproxy-go" = { version = "0.46.0", exe = "mcpproxy" }
{{ end -}}
{{ if and (eq .chezmoi.os "linux") (dig "paseoDaemon" false .) -}}
"npm:@getpaseo/cli" = "0.1.101"
{{ end -}}
{{ if and (eq .chezmoi.os "linux") (dig "orcaServer" false .) -}}
# orca on Linux: AppImage via http: backend. mise downloads, makes executable,
# and symlinks into ~/.local/share/mise/installs/http-orca/<version>/orca.
# `df-orca-serve` wrapper points there. Pitchfork supervises the daemon lifecycle.
# (macOS uses the Homebrew cask, not mise — see install-my-packages.tmpl.)
"http:orca" = { version = "1.4.114", url = "https://github.com/stablyai/orca/releases/download/v{{ "{{version}}" }}/orca-linux.AppImage", bin = "orca" }
"github:jdx/pitchfork" = { version = "2.14.0", exe = "pitchfork" }
{{ end -}}
age = "latest"
ast-grep = "latest"
bitwarden = "2026.6.0"
bun = "1.3.14"
chezmoi = "2.70.5"
claude = "latest"
codex = "latest"
d2 = "0.7.1"
delta = "0.19.2"
deno = "2.9.0"
difftastic = "0.69.0"
fzf = "0.73.1"
gemini = "latest"
go = "1.26.4"
jq = "latest"
yq = "latest"
node = "24.11.1"
"npm:@openchamber/web" = "latest"
"npm:oh-my-openagent" = "latest"
opencode = "latest"
python = "3.13"
ripgrep = "latest"
rust = "1.96.0"
shellcheck = "0.11.0"
starship = "1.26.0"
tmux = "3.7a"
uv = "0.11.25"

[env]
OMO_SEND_ANONYMOUS_TELEMETRY = "0"
DISABLE_AUTOUPDATER = "1"
DENO_NO_UPDATE_CHECK = "1"

[settings]
idiomatic_version_file_enable_tools = ["node"]
experimental = true
gix = false

# ── Tasks ────────────────────────────────────────────────────────────────────
# Task bodies are hoisted into ~/.local/bin/dotfiles-task-* scripts so they
# follow the repo's standard script header pattern (set -euo pipefail, doc
# block, bash-logging) and can be debugged in isolation. Task entries here
# are thin dispatchers + dependency declarations.

[tasks.update]
description = "Upgrade mise tools, pull dotfiles source, then converge chezmoi state"
depends = ["mise:upgrade"]
depends_post = ["chezmoi:update"]
run = "true"

[tasks."mise:upgrade"]
description = "Refresh tools pinned to `latest` (explicit pins untouched)"
hide = true
run = "df-task-mise-upgrade"

[tasks."chezmoi:apply"]
description = "Apply chezmoi (converges dotfiles + lifecycle scripts)"
hide = true
run = "df-task-chezmoi-apply"

[tasks."chezmoi:update"]
description = "Pull source repo + apply (TTY-aware non-interactive fallback)"
hide = true
run = "df-task-chezmoi-update"

{{ if eq .chezmoi.os "darwin" -}}
# ── Drift detection (macOS only) ─────────────────────────────────────────────
# Surfaces version drift across managed tools without firing notifications on
# Coder boxes (which are non-interactive). Linux drift is visible by SSHing
# into the box and running df-setup.

[tasks."drift:check"]
description = "Aggregate version drift into ~/.cache/dotfiles/drift.json"
run = "df-drift check"

[tasks."prewarm:gh-auth"]
description = "Cache gh auth liveness into ~/.cache/dotfiles/prewarm.json"
run = "df-prewarm gh-auth"

[tasks."drift:notify"]
description = "Surface drift via macOS notification (debounced 24h)"
# Rides the daily launchd fire: refreshing gh-auth liveness here means the
# login.zsh setup reminder reads a fresh boolean from prewarm.json instead of
# forking `gh auth status` per login. Distinct cache + concern from drift, so
# it is a task-dependency edge, not a code merge.
depends = ["drift:check", "prewarm:gh-auth"]
run = "df-drift notify"

{{ end -}}

# ── Hooks ────────────────────────────────────────────────────────────────────
# After any tool install (`mise install`, `mise upgrade`, `mise use`), run
# chezmoi apply so lifecycle scripts that depend on tool versions converge.
# Notable consumer: run_onchange-067 sync-opencode-plugins, which bridges
# mise's tool pins into opencode's plugin cache.

[hooks]
postinstall = { task = "chezmoi:apply" }
