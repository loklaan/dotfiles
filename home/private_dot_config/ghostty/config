# Documentation: https://ghostty.org/docs/config

# We manage titles ourselves via init/title.zsh so 'title' is excluded.
# ssh-terminfo is excluded — macOS system ncurses is too old to correctly
# export xterm-ghostty terminfo. The coder zsh plugin handles terminfo
# installation using Homebrew ncurses instead.
# ssh-env falls back to TERM=xterm-256color and propagates COLORTERM=truecolor.
shell-integration-features = cursor,sudo,ssh-env

font-family = "JetbrainsMono Nerd Font Mono"
font-size = 15
adjust-cell-height = "20%"
theme = "Catppuccin Mocha"
macos-titlebar-proxy-icon = hidden
macos-icon = retro
window-padding-x = 20
window-padding-y = 10,0
keybind = shift+enter=text:\n
