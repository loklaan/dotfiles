#|-----------------------------------------------------------------------------|
#| INIT MODULE: Environment                                                    |
#|-----------------------------------------------------------------------------|
#|                                                                             |
#| Purpose:                                                                    |
#|   Establishes the foundational environment configuration for all shell      |
#|   sessions (login, non-login, interactive, non-interactive). Sets up        |
#|   critical environment variables and constructs $PATH with a specific       |
#|   order of precedence to ensure correct executable resolution across        |
#|   Linux distributions and macOS (primary OS).                               |
#|                                                                             |
#| Responsibilities:                                                           |
#|   - Locale and language settings (UTF-8)                                    |
#|   - User and editor preferences                                             |
#|   - XDG Base Directory specification compliance                             |
#|   - System resource limits (file descriptors)                               |
#|   - Platform-specific configurations (WSL display, Homebrew paths)          |
#|   - Service authentication tokens (personal machines)                       |
#|   - Language toolchain SDKs (Android, Playdate, Node.js, etc.)              |
#|   - User aliases integration                                                |
#|                                                                             |
#| $PATH Order of Precedence (left to right search):                           |
#|   1. Context/Project Specific (most specific)                               |
#|      - Prepended by tools like mise shims, direnv, etc.                     |
#|      - Project-level overrides, e.g. node_modules/.bin                      |
#|                                                                             |
#|   2. User Custom / Local Binaries                                           |
#|      - $HOME/.local/bin                                                     |
#|      - User-installed scripts and binaries                                  |
#|                                                                             |
#|   3. Version Managers                                                       |
#|      - Mise shims (activated separately in login.zsh for full mode)         |
#|      - Language-specific version managers (pyenv, cargo, etc.)              |
#|                                                                             |
#|   4. System Local                                                           |
#|      - /usr/local/sbin, /usr/local/bin                                      |
#|      - Package manager binaries (Homebrew on macOS)                         |
#|      - Locally compiled/installed system software                           |
#|                                                                             |
#|   5. System Default (core utilities)                                        |
#|      - /usr/bin, /bin, /usr/sbin, /sbin                                     |
#|      - Essential system binaries and commands                               |
#|                                                                             |
#|   6. Application SDKs (least specific)                                      |
#|      - Language toolchains: $ANDROID_HOME, $PLAYDATE_SDK_PATH, etc.         |
#|      - Specialized dev tools: $FLYCTL_INSTALL, etc.                         |
#|      - Appended so they don't override system or user tools                 |
#|                                                                             |
#| Note: The shell searches $PATH left to right, so earlier entries take       |
#|       precedence. User and project-specific tools override system           |
#|       defaults while maintaining system stability.                          |
#|                                                                             |
#|       On macOS, /etc/zprofile runs path_helper which reorders PATH,         |
#|       pushing user entries behind system defaults. To counter this,         |
#|       tiers 1-3 are captured in __PATH_PREFIX and re-prepended in           |
#|       .zprofile (which runs after /etc/zprofile). typeset -U PATH           |
#|       deduplicates, keeping the first (correct) occurrence.                 |
#|       Note: -U must be on PATH (uppercase), not path (lowercase),           |
#|       because export PATH=... clears -U on the array form.                  |
#|                                                                             |
#|-----------------------------------------------------------------------------|

#|------------------------------------------------------------|#
#| Locale
#|
export LC_ALL=en_US.UTF-8
export LANG=en_US.UTF-8
export LANGUAGE=en_US.UTF-8

#|------------------------------------------------------------|#
#| User
#|
export DEFAULT_USER=loch
export EDITOR='idea --wait'

#|------------------------------------------------------------|#
#| XDG
#|
{{ if eq .chezmoi.os "darwin" -}}
export XDG_CACHE_HOME="$HOME/Library/Caches"
{{- else -}}
export XDG_CACHE_HOME="$HOME/.cache"
{{- end }}
export XDG_CONFIG_HOME="$HOME/.config"
export XDG_DATA_HOME="$HOME/.local/share"

#|------------------------------------------------------------|#
#| fpath self-heal (MUST run before any autoload)
#|
#|  This is the FIRST init module (sourced from .zshenv), so it runs before
#|  login.zsh (mise/starship `eval` that calls add-zsh-hook) and plugins.zsh
#|  (compinit/bashcompinit) — the earliest points that autoload zsh functions.
#|
#|  fpath can be inherited via an exported FPATH from a parent whose entries no
#|  longer exist on disk. The classic case: a version-pinned Homebrew Cellar
#|  functions dir (…/Cellar/zsh/<ver>/share/zsh/functions) left dangling after
#|  `brew upgrade zsh` bumps the version and deletes the old Cellar tree. A
#|  long-lived process — a tmux server kept alive by @continuum-boot, or a
#|  login shell open across the upgrade — keeps re-exporting the dead path into
#|  every child it spawns. When zsh's own function dir is thus missing,
#|  `autoload -Uz compinit / bashcompinit / is-at-least / add-zsh-hook` fail
#|  with "function definition file not found". Inside a fresh tmux pane that
#|  aborts the login shell, the pane dies, its window+session close, and with
#|  no sessions left the tmux server exits — surfacing as "tmux crashes on
#|  init".
#|
#|  Fix in two moves:
#|   1. Prune fpath to entries that still exist as dirs — (N-/) glob qualifier.
#|   2. If no working core function dir survived (probe: can we autoload a core
#|      function?), derive the RUNNING zsh's function dir from $module_path
#|      (which is always correct — it's how the live binary found its modules)
#|      and prepend it. Never a version-pinned literal, so the next zsh upgrade
#|      can't re-break it.
#|
fpath=(${^fpath}(N-/))
if ! autoload +X -Uz add-zsh-hook 2>/dev/null; then
  _zcore="${module_path[1]:h}/share/zsh/functions"
  [[ -d $_zcore ]] && fpath=("$_zcore" $fpath)
  unset _zcore
fi

#|------------------------------------------------------------|#
#| Filesystem Performance
#|
ulimit -S -n "$(ulimit -H -n)" 2>/dev/null # Raise open-files soft limit to the hard cap — important for large git repos
bgnotify_threshold=8

#|------------------------------------------------------------|#
#| AWS Region (Coder dev boxes)
#|  Work opencode providers use IMDS credentials + SigV4 on Coder boxes, which
#|  need an explicit region. The region is STATIC per workspace, so df-prewarm
#|  resolves it from IMDS once at apply-time into ~/.cache/dotfiles/prewarm.json
#|  (see run_after_install-062-prewarm-aws-region). Here we just stat+read that
#|  cache — no per-shell curl to 169.254.169.254. Fall back to the default
#|  local region for the brief window before the cache is populated.
#|
if [ -n "${CODER:-}" ] && [ -z "${AWS_REGION:-}" ]; then
  _aws_prewarm="${XDG_CACHE_HOME:-$HOME/.cache}/dotfiles/prewarm.json"
  _aws_region=""
  if [ -r "$_aws_prewarm" ] && command -v jq >/dev/null 2>&1; then
    _aws_region=$(jq -r '.aws_region // empty' "$_aws_prewarm" 2>/dev/null)
  fi
  export AWS_REGION="${_aws_region:-ap-southeast-2}"
  export AWS_DEFAULT_REGION="$AWS_REGION"
  unset _aws_prewarm _aws_region
fi

#|------------------------------------------------------------|#
#| WSL
#|
{{ if eq .chezmoi.os "linux" -}}
{{   if (.chezmoi.kernel.osrelease | lower | contains "microsoft") -}}
# VcxSrv Display (WSL hosted UIs)
export DISPLAY=${DISPLAY:-$(grep -Po '(?<=nameserver ).*' /etc/resolv.conf):0}
{{   end -}}
{{- end }}

{{- if ne .machineProfile "work" -}}
#|------------------------------------------------------------|#
#| Service Tokens
#|  - Github
#|
{{- $bwsToken := "" -}}
{{- if and (lookPath "bws") (stat .bwsTokenPath) -}}
{{-   $bwsToken = include .bwsTokenPath | trim -}}
{{- end -}}
{{- $bwsGet := joinPath .chezmoi.homeDir ".local/lib/bws-get-or-empty" -}}
{{- $githubAuthToken := "" -}}
{{- if and (ne "" $bwsToken) (stat $bwsGet) -}}
{{-   $githubAuthToken = output $bwsGet .bwsIdGithubAuthToken .bwsTokenPath | trim -}}
{{- end -}}
{{- if ne "" $githubAuthToken }}
export GITHUB_TOKEN={{ $githubAuthToken }}
{{- else }}
export GITHUB_TOKEN=""
{{- end }}

{{ if eq .chezmoi.os "darwin" -}}
#|------------------------------------------------------------|#
#| Package Manager Settings
#|  - Homebrew
#|
export HOMEBREW_GITHUB_API_TOKEN=$GITHUB_TOKEN
export HOMEBREW_NO_ANALYTICS=1
export HOMEBREW_NO_EMOJI=1
export HOMEBREW_NO_INSECURE_REDIRECT=1
{{- end }}
{{- else -}}
{{ if eq .chezmoi.os "darwin" -}}
#|------------------------------------------------------------|#
#| Package Manager Settings
#|  - Homebrew
#|
export HOMEBREW_NO_ANALYTICS=1
export HOMEBREW_NO_EMOJI=1
export HOMEBREW_NO_INSECURE_REDIRECT=1
{{- end }}
{{- end }}

{{ if ne "" .jetbrainsLicenseServer -}}
export JETBRAINS_LICENSE_SERVER={{ .jetbrainsLicenseServer }}
{{- end }}

#|------------------------------------------------------------|#
#| Base Pathing
#|
#|  PATH precedence (left → right for executables):
#|   1) Context/Project specific (injected by tools like direnv/mise later)
#|   2) User local binaries
#|   3) System local (incl. Homebrew on macOS)
#|   4) System defaults
#|   5) Previous PATH (lowest, so earlier context-specific injectors can re-prepend as needed)
#|
{{ $pkg_manager_path := "" -}}
{{ if eq .chezmoi.os "darwin" -}}
{{   $pkg_manager_path = (printf ":%s/bin:%s/sbin" .brewprefix .brewprefix) -}}
{{- end }}
__PATH_PREFIX="$HOME/.local/share/mise/shims:$HOME/.local/bin{{ $pkg_manager_path }}"
export PATH="${__PATH_PREFIX}:/usr/local/bin:/usr/local/sbin:/usr/bin:/usr/sbin:/bin:/sbin:$PATH"
typeset -U PATH
#| Language/tool chains
#|  Android
{{ if eq .chezmoi.os "darwin" -}}
export ANDROID_HOME="$HOME/Library/Android/sdk"
{{- else -}}
export ANDROID_HOME="$HOME/.local/share/Android"
{{- end }}
export PATH="$PATH:$ANDROID_HOME/platform-tools:$ANDROID_HOME/tools"
#|  Playdate
{{ if eq .chezmoi.os "darwin" -}}
export PLAYDATE_SDK_PATH="$HOME/Developer/PlaydateSDK"
{{- else -}}
export PLAYDATE_SDK_PATH="$HOME/.local/share/PlaydateSDK"
{{- end }}
export PATH="$PATH:$PLAYDATE_SDK_PATH/bin"
#|  Fly.io
export FLYCTL_INSTALL="$HOME/.fly"
export PATH="$PATH:$FLYCTL_INSTALL/bin"
#|  Nodejs
export NODE_MAX_OLD_SPACE_SIZE=8192
export PNPM_HOME="$HOME/.local/share/pnpm"
export PATH="$PATH:$PNPM_HOME"

#|------------------------------------------------------------|#
#| Aliases
#|
source "${HOME}/.local/lib/open.sh"
if [[ -f "${HOME}/.aliases" ]]; then
  # shellcheck source=home/dot_aliases
  source "${HOME}/.aliases"
fi
source "${HOME}/.local/lib/shell-aliases.sh"
if [[ -f "${HOME}/.local/lib/brew.zsh" ]]; then
  source "${HOME}/.local/lib/brew.zsh"
fi
