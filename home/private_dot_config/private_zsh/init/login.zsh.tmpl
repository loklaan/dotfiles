#|-----------------------------------------------------------------------------|
#| INIT MODULE: Login                                                          |
#|-----------------------------------------------------------------------------|
#|                                                                             |
#| Purpose:                                                                    |
#|   Configures the shell environment for login shells, including package      |
#|   managers, background services, development tools, and optional tmux       |
#|   session management.                                                       |
#|                                                                             |
#| Responsibilities:                                                           |
#|   - Activate package managers (mise, nix)                                   |
#|   - Start background daemons (ssh-agent, GPG)                               |
#|   - Initialize development environment (coder boxes)                        |
#|   - Configure tmux session management                                       |
#|                                                                             |
#|-----------------------------------------------------------------------------|

#|------------------------------------------------------------|#
#| Package Managers
#|  - Mise (full)
#|  - Nix
#|
source "${HOME}/.local/lib/term.zsh"
if is_interactive_shell && command -v mise &> /dev/null; then
  # Only activate if not already activated (hook function not defined)
  if ! typeset -f _mise_hook &> /dev/null; then
    path=(${path:#$HOME/.local/share/mise/shims})
    unset __MISE_ORIG_PATH
    eval "$(mise activate zsh)"
  fi
fi
[[ ! $(command -v nix) && -e "/nix/var/nix/profiles/default/etc/profile.d/nix-daemon.sh" ]] && source "/nix/var/nix/profiles/default/etc/profile.d/nix-daemon.sh"

#|------------------------------------------------------------|#
#| Background Daemons / Agents
#|  - SSH
#|
source "${HOME}/.local/lib/ssh.sh"
if typeset -f _ssh_agent > /dev/null; then
  _ssh_agent
fi
export GPG_TTY=$(tty)

#|------------------------------------------------------------|#
#| Dev Machines & LLM Agents
#|  - Coder boxes
#|
[ -e "$HOME/.coder.sh" ] && . "$HOME/.coder.sh"

#|------------------------------------------------------------|#
#| Dotfiles Setup Reminder
#|
#| Shows a reminder if secrets were not applied during chezmoi install.
#|
_incomplete_setup=false

# Check for BWS token file
if [[ ! -f "{{ .bwsTokenPath }}" ]]; then
  _incomplete_setup=true
fi

# Check for signing key
{{- if eq "" .signingKey }}
_incomplete_setup=true
{{- end }}

{{ if ne "" .emailWork -}}
# Check for GitHub CLI auth (credential agent for short-lived tokens)
if ! gh auth status 2>&1 | grep -q "Logged in.*keyring"; then
  _incomplete_setup=true
fi
{{- end }}

if [[ "$_incomplete_setup" == "true" ]]; then
  echo ""
  print -P "%F{yellow}Dotfiles applied with incomplete configuration.%f"
  print -P "Run %F{cyan}df-setup%f for instructions."
  echo ""
fi
unset _incomplete_setup

#|------------------------------------------------------------|#
#| Tool Drift Reminder (macOS only)
#|
#| Surfaces a one-liner once per 24h when managed tools are behind
#| their pinned versions. Reads the cache populated by the launchd
#| agent (drift:notify) so the cost here is only a stat + jq.
#|
{{- if eq .chezmoi.os "darwin" }}
if is_interactive_shell && command -v jq &> /dev/null; then
  _drift_cache="${HOME}/.cache/dotfiles/drift.json"
  _drift_login_marker="${HOME}/.cache/dotfiles/.drift-login-shown"

  # Only act when cache exists and is parseable
  if [[ -f "$_drift_cache" ]]; then
    _drift_show=true
    if [[ -f "$_drift_login_marker" ]]; then
      _drift_now=$(date +%s)
      _drift_age=$(( _drift_now - $(stat -f %m "$_drift_login_marker" 2>/dev/null || echo 0) ))
      [[ $_drift_age -lt 86400 ]] && _drift_show=false
    fi

    if [[ "$_drift_show" == "true" ]]; then
      _drift_count=$(jq '.tools | length' "$_drift_cache" 2>/dev/null || echo 0)
      if [[ "$_drift_count" -gt 0 ]]; then
        echo ""
        print -P "%F{yellow}⚠ ${_drift_count} tool(s) behind.%f Run %F{cyan}df-setup%f for details, or %F{cyan}mise run update%f to refresh."
        echo ""
        mkdir -p "${HOME}/.cache/dotfiles"
        touch "$_drift_login_marker"
      fi
    fi
    unset _drift_show _drift_now _drift_age _drift_count
  fi
  unset _drift_cache _drift_login_marker
fi
{{- end }}
