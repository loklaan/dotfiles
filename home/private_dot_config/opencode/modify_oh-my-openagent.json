{{- /* chezmoi:modify-template */ -}}
{{- $base := fromJson (default "{}" .chezmoi.stdin) -}}
{{- $config := $base -}}

{{- /* Schema for editor validation */ -}}
{{- $config = $config | setValueAtPath "$schema" "https://github.com/code-yeongyu/oh-my-openagent/blob/dev/assets/oh-my-opencode.schema.json" -}}

{{- /* Disable git commit footers — conflicts with commit conventions */ -}}
{{- $config = mergeOverwrite $config (dict
      "git_master" (dict
        "commit_footer" false
        "include_co_authored_by" false)) -}}

{{- /* Disable Claude Code interop — hooks misreport as claude-code in
       telemetry, MCP servers are behind mcpproxy-go instead */ -}}
{{- $config = mergeOverwrite $config (dict
      "claude_code" (dict
        "hooks" false
        "mcp" false
        "commands" false
        "skills" false
        "agents" false
        "plugins" false)) -}}

{{- /* Disable default built-in MCPs — context7, websearch, and webfetch are
      served via mcpproxy-managed EXA instead (web_search_exa + web_fetch_exa
      at https://mcp.exa.ai; provider block in modify_private_mcp_config.json).
      grep_app is not needed. */ -}}
{{- $config = $config | setValueAtPath "disabled_mcps" (list "context7" "websearch" "webfetch" "grep_app") -}}

{{- /* Team Mode — off on cost grounds */ -}}
{{- $config = mergeOverwrite $config (dict
      "team_mode" (dict
        "enabled" false
        "tmux_visualization" false
        "max_parallel_members" 4
        "max_members" 8)) -}}

{{- $p := index .profiles (dig "machineProfile" "personal" .) -}}

{{- /* Single-tier fast path: profile has only one tier, no read-back needed */ -}}
{{- if eq (len $p.agent_tiers) 1 -}}
{{-   $tier := index $p.agent_tiers 0 -}}
{{-   $config = set $config "agents" (index $p "agents") -}}
{{-   $config = set $config "categories" (index $p "categories") -}}
{{-   $config = set $config "_dotfilesProfile" $tier -}}
{{-   $config = set $config "_dotfilesAvailableTiers" $p.agent_tiers -}}
{{- else -}}
{{-   $requested := "" -}}
{{-   if hasKey $base "_dotfilesProfile" -}}
{{-     $requested = index $base "_dotfilesProfile" -}}
{{-   end -}}
{{-   $effective := index $p.agent_tiers 0 -}}
{{-   if and (ne "" $requested) (has $requested $p.agent_tiers) -}}
{{-     $effective = $requested -}}
{{-   else if ne "" $requested -}}
{{-     $config = set $config "_dotfilesProfileRequested" $requested -}}
{{-   end -}}
{{-   $config = set $config "_dotfilesProfile" $effective -}}
{{-   $config = set $config "_dotfilesAvailableTiers" $p.agent_tiers -}}
{{-   $config = set $config "agents" (index (index $p $effective) "agents") -}}
{{-   $config = set $config "categories" (index (index $p $effective) "categories") -}}
{{- end -}}

{{- $config = set $config "_dotfilesUnmanaged" (dict "agents" (list) "categories" (list)) -}}

{{ $config | toPrettyJson }}
