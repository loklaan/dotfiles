{{- /* chezmoi:modify-template */ -}}
{{- $base := fromJson (default "{}" .chezmoi.stdin) -}}
{{- $config := $base -}}

{{- /* Schema for editor validation */ -}}
{{- $config = $config | setValueAtPath "$schema" "https://github.com/code-yeongyu/oh-my-openagent/blob/dev/assets/oh-my-opencode.schema.json" -}}

{{- /* Disable git commit footers — conflicts with commit conventions */ -}}
{{- $config = mergeOverwrite $config (dict
      "git_master" (dict
        "commit_footer" false
        "include_co_authored_by" false)) -}}

{{- /* Disable Claude Code interop — hooks misreport as claude-code in
       telemetry, MCP servers are behind mcpproxy-go instead */ -}}
{{- $config = mergeOverwrite $config (dict
      "claude_code" (dict
        "hooks" false
        "mcp" false
        "commands" false
        "skills" false
        "agents" false
        "plugins" false)) -}}

{{- /* Disable default built-in MCPs — context7 and websearch are behind
       mcpproxy-go, grep_app is not needed */ -}}
{{- $config = $config | setValueAtPath "disabled_mcps" (list "context7" "websearch" "grep_app") -}}

{{- /* Team Mode (oh-my-openagent v4.0.0+). Lead agent orchestrates a team
       of category-specialised members in parallel via team_* tools. Off by
       default upstream; this turns it on for our machines. tmux_visualization
       stays off here — turn it on per-machine if you live in tmux. */ -}}
{{- $config = mergeOverwrite $config (dict
      "team_mode" (dict
        "enabled" true
        "tmux_visualization" false
        "max_parallel_members" 4
        "max_members" 8)) -}}

{{- /* Bedrock-proxied model + variant overrides (work machines only).
       Bedrock isn't in omo's hardcoded fallback chains, so anthropic-intended
       agents would silently degrade to OpenAI/Google fallbacks unless pinned
       here. Variants mirror omo's intended reasoning levels.

       This template is the SOURCE OF TRUTH for agents/categories: we use `set`
       (not `mergeOverwrite`), so anything not listed here is REMOVED on apply.
       That kills install-time leftovers (e.g. stale opencode/gpt-5-nano pins
       written by `oh-my-openagent install`). New omo agents/categories not
       listed here will fall through to omo's hardcoded chain — the right
       default until you decide to pin them.

       The `_dotfilesUnmanaged` sidecar is read by `dotfiles-task-drift-omo`:
       names listed there are agents/categories we know exist but intentionally
       leave on omo's chain. Drift fires only on names that are neither pinned
       below nor listed there. The underscore prefix signals "not omo's key";
       omo ignores unknown top-level keys.

       COST PROFILES. The agents/categories pins below come from a named
       profile, selected at render time. Profiles let you trade quality for
       token cost without hand-editing this file:

         default — best-in-class per role. Opus/Sonnet for Claude-personality
                   agents, GPT-5.5 for GPT-personality, Gemini Pro for visual.
         cheap   — same personality families, cheaper members. Claude-likes
                   drop to Bedrock Kimi (orchestrators) / Haiku (support);
                   GPT roles stay native but smaller (gpt-5.4-mini); Gemini
                   roles drop to flash. Personality is preserved per omo's
                   agent-model-matching guide — we never cross-swap a GPT
                   reviewer onto a Claude-like, etc.

       The active profile is read from ~/.config/opencode/.omo-profile (a tiny
       plaintext file, NOT chezmoi-managed). Absent/unknown → "default". The
       `omo-profile` bin script flips it and re-renders just this file via a
       targeted `chezmoi apply`, so switching needs no full apply. omo reads
       this config once per session, so a new session picks up the switch.

       Adding a profile is one entry in $profiles below — keep every key
       present in `default` present in every profile (the drift checker and
       omo both expect the full roster). */ -}}
{{- if ne "" .emailWork -}}
{{-   $bedrockOpus := "amazon-bedrock/global.anthropic.claude-opus-4-8" -}}
{{-   $bedrockSonnet := "amazon-bedrock/global.anthropic.claude-sonnet-4-6" -}}
{{-   $bedrockHaiku := "amazon-bedrock/global.anthropic.claude-haiku-4-5-20251001-v1:0" -}}
{{-   $bedrockKimi := "amazon-bedrock/moonshotai.kimi-k2.5" -}}
{{-   $openaiBig := "openai/gpt-5.5" -}}
{{-   $openaiMini := "openai/gpt-5.4-mini" -}}
{{-   $googleFlash := "google/gemini-3.5-flash" -}}
{{-   $googlePro := "google/gemini-3.1-pro-preview" -}}
{{- /* Profile table. Each profile carries the full agents + categories
       roster. `default` is the original best-in-class set; `cheap` is the
       budget set with personality preserved. */ -}}
{{-   $profiles := dict
        "default" (dict
          "categories" (dict
            "unspecified-high"   (dict "model" $bedrockOpus)
            "unspecified-low"    (dict "model" $bedrockSonnet)
            "ultrabrain"         (dict "model" $openaiBig    "variant" "xhigh")
            "deep"               (dict "model" $openaiBig    "variant" "medium")
            "quick"              (dict "model" $googleFlash)
            "visual-engineering" (dict "model" $googlePro    "variant" "high")
            "artistry"           (dict "model" $googlePro    "variant" "high")
            "writing"            (dict "model" $googleFlash))
          "agents" (dict
            "sisyphus"        (dict "model" $bedrockOpus)
            "oracle"          (dict "model" $bedrockOpus)
            "prometheus"      (dict "model" $bedrockOpus)
            "metis"           (dict "model" $bedrockSonnet)
            "momus"           (dict "model" $bedrockOpus)
            "atlas"           (dict "model" $bedrockSonnet)
            "sisyphus-junior" (dict "model" $bedrockSonnet)
            "librarian"       (dict "model" $bedrockHaiku)
            "explore"         (dict "model" $bedrockHaiku)))
        "cheap" (dict
          "categories" (dict
            "unspecified-high"   (dict "model" $bedrockKimi)
            "unspecified-low"    (dict "model" $bedrockHaiku)
            "ultrabrain"         (dict "model" $openaiMini)
            "deep"               (dict "model" $openaiMini)
            "quick"              (dict "model" $googleFlash)
            "visual-engineering" (dict "model" $googleFlash)
            "artistry"           (dict "model" $googleFlash)
            "writing"            (dict "model" $googleFlash))
          "agents" (dict
            "sisyphus"        (dict "model" $bedrockKimi)
            "oracle"          (dict "model" $openaiMini)
            "prometheus"      (dict "model" $bedrockKimi)
            "metis"           (dict "model" $bedrockHaiku)
            "momus"           (dict "model" $openaiMini)
            "atlas"           (dict "model" $bedrockHaiku)
            "sisyphus-junior" (dict "model" $bedrockHaiku)
            "librarian"       (dict "model" $bedrockHaiku)
            "explore"         (dict "model" $bedrockHaiku))) -}}
{{- /* Read active profile from the non-chezmoi state file; fall back to
       "default" when missing or unrecognised. We avoid `warnf` here: chezmoi's
       modify-template apply path doesn't register it (only `chezmoi cat` /
       `execute-template` do), so calling it aborts the render. Instead we
       record the raw request in `_dotfilesProfileRequested` whenever it
       differs from the effective profile; the `omo-profile` status command
       surfaces the mismatch. The `omo-profile` script also validates names
       before writing the state file, so an unknown value only appears via a
       hand-edited state file. */ -}}
{{-   $profileFile := joinPath .chezmoi.homeDir ".config/opencode/.omo-profile" -}}
{{-   $profileName := "default" -}}
{{-   $requested := "" -}}
{{-   if stat $profileFile -}}
{{-     $requested = include $profileFile | trim -}}
{{-     if hasKey $profiles $requested -}}
{{-       $profileName = $requested -}}
{{-     end -}}
{{-   end -}}
{{-   $active := get $profiles $profileName -}}
{{-   $config = set $config "categories" (get $active "categories") -}}
{{-   $config = set $config "agents" (get $active "agents") -}}
{{- /* Record the active profile so it's visible in the rendered file and to
       tooling. Underscore prefix → omo ignores it as an unknown key. */ -}}
{{-   $config = set $config "_dotfilesProfile" $profileName -}}
{{-   if and (ne "" $requested) (ne $requested $profileName) -}}
{{-     $config = set $config "_dotfilesProfileRequested" $requested -}}
{{-   end -}}
{{-   $config = set $config "_dotfilesUnmanaged" (dict
        "agents" (list "hephaestus" "multimodal-looker")
        "categories" (list)) -}}
{{- end -}}

{{ $config | toPrettyJson }}
