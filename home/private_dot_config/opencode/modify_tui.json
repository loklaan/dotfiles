{{- /* chezmoi:modify-template */ -}}
{{- $base := fromJson (default "{}" .chezmoi.stdin) -}}
{{- $config := $base -}}

{{- /* Registers the oh-my-openagent TUI plugin so opencode's TUI shows the
       Roles · Models sidebar section.

       History: opencode's TUI plugin loader used to treat "oh-my-openagent/tui"
       as a GitHub shorthand and tried to clone a non-existent repo on every
       startup, which hung opencode on Coder devboxes behind a git credential
       prompt. Tracked in:
        - https://github.com/code-yeongyu/oh-my-openagent/issues/4303
        - https://github.com/code-yeongyu/oh-my-openagent/pull/4305

       PR #4305 has since landed (the package now exposes a ./tui subpath
       export). BUT the correct TUI plugin spec is the PACKAGE spec
       "oh-my-openagent@latest", NOT the "oh-my-openagent/tui" subpath:
       opencode installs the configured package spec BEFORE resolving the TUI
       export, so a bare subpath entry is reported unresolvable by
       `oh-my-openagent doctor` ("OpenCode installs the configured package spec
       before resolving the TUI export"). Using the package spec lets opencode
       install it, then resolve the ./tui export from it. We therefore register
       "oh-my-openagent@latest" and strip any legacy bare-subpath entries. */ -}}
{{- $omoTuiPlugin := "oh-my-openagent@latest" -}}
{{- $plugins := default (list) (get $config "plugin") -}}
{{- $cleaned := list -}}
{{- range $p := $plugins -}}
{{-   if and (ne $p "oh-my-openagent/tui") (ne $p "oh-my-opencode/tui") -}}
{{-     $cleaned = append $cleaned $p -}}
{{-   end -}}
{{- end -}}
{{- if not (has $omoTuiPlugin $cleaned) -}}
{{-   $cleaned = append $cleaned $omoTuiPlugin -}}
{{- end -}}
{{- $config = $config | setValueAtPath "plugin" $cleaned -}}

{{ $config | toPrettyJson }}
