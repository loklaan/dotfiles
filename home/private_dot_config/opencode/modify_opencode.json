{{- /* chezmoi:modify-template */ -}}
{{- $base := fromJson (default "{}" .chezmoi.stdin) -}}

{{- /* Load MCP servers from template */ -}}
{{- $mcpServers := includeTemplate "mcp-servers-opencode-mcpproxy-json-tmpl" . | fromJson -}}

{{- /* Configure instructions to reference shared agent rules and project rules directories */ -}}
{{- $instructions := list
      (printf "%s/.agents/rules/coding-system-prompts.md" .chezmoi.homeDir)
      "AGENTS.md"
      "CLAUDE.md"
      ".claude/rules/*.md"
      ".agents/rules/*.md"
-}}

{{- /* Build OpenCode config */ -}}
{{- $config := $base -}}
{{- $config = $config | setValueAtPath "mcp" $mcpServers -}}
{{- $config = $config | setValueAtPath "instructions" $instructions -}}

{{- /* Register plugins */ -}}
{{- $plugins := list "oh-my-openagent@latest" -}}
{{- /* Local path overrides the npm package name when set — for in-place dev iteration */ -}}
{{- $workPlugin := .openCodeWorkPlugin -}}
{{- $localPath := dig "openCodeWorkPluginLocalPath" "" . -}}
{{- if ne "" $localPath -}}
{{-   $workPlugin = $localPath -}}
{{- end -}}
{{- if ne "" $workPlugin -}}
{{-   $plugins = prepend $plugins $workPlugin -}}
{{- end -}}
{{- $config = $config | setValueAtPath "plugin" $plugins -}}

{{- /* Set schema for editor validation */ -}}
{{- $config = $config | setValueAtPath "$schema" "https://opencode.ai/config.json" -}}

{{- /* Set OpenCode-specific defaults (only if not already set by OpenCode) */ -}}
{{- if not (hasKey $base "autoupdate") -}}
{{-   $config = $config | setValueAtPath "autoupdate" false -}}
{{- end -}}

{{- /* Canva Coder boxes: disable filesystem snapshots globally for the user.
       A ~/work/canva project config would not reliably apply inside nested Git
       repos because opencode walks only to the nearest Git root. */ -}}
{{- if and (ne "" (env "CODER")) (ne "" .emailWork) -}}
{{-   $config = $config | setValueAtPath "snapshot" false -}}
{{- end -}}

{{- if and (ne "" .emailWork) (ne "" .openCodeWorkPlugin) -}}
{{-   $bedrockOpus := "global.anthropic.claude-opus-4-8" -}}
{{-   $opusLimit := dict "limit" (dict "context" 1000000 "output" 128000) -}}
{{- /* Sonnet 4-6 degrades badly past 300k tokens — cap context there. */ -}}
{{-   $sonnetLimit := dict "limit" (dict "context" 300000 "output" 64000) -}}
{{-   $config = $config | setValueAtPath "share" "disabled" -}}
{{-   $config = $config | setValueAtPath "enabled_providers" (list "amazon-bedrock" "google" "openai") -}}
{{-   $config = mergeOverwrite $config (dict
        "provider" (dict
          "amazon-bedrock" (dict
            "models" (dict
              $bedrockOpus                                       $opusLimit
              "global.anthropic.claude-opus-4-7"                 $opusLimit
              "global.anthropic.claude-sonnet-4-6"               $sonnetLimit)
            "whitelist" (list
              $bedrockOpus
              "global.anthropic.claude-opus-4-7"
              "global.anthropic.claude-opus-4-6-v1"
              "global.anthropic.claude-opus-4-5-20251101-v1:0"
              "global.anthropic.claude-sonnet-4-6"
              "global.anthropic.claude-sonnet-4-5-20250929-v1:0"
              "global.anthropic.claude-haiku-4-5-20251001-v1:0"
              "global.amazon.nova-2-lite-v1:0"
              "moonshotai.kimi-k2.5"
              "deepseek.v3.2"
              "qwen.qwen3-coder-next"
              "qwen.qwen3-next-80b-a3b"
              "minimax.minimax-m2.5"
              "minimax.minimax-m2.1"
              "mistral.mistral-large-3-675b-instruct"
              "mistral.devstral-2-123b"
              "zai.glm-5"
              "nvidia.nemotron-super-3-120b"
              "meta.llama4-scout-17b-instruct-v1:0"
              "mistral.magistral-small-2509"))))  -}}
{{-   if not (hasKey $base "model") -}}
{{-     $config = $config | setValueAtPath "model" (printf "amazon-bedrock/%s" $bedrockOpus) -}}
{{-   end -}}
{{- else if not (hasKey $base "share") -}}
{{-   $config = $config | setValueAtPath "share" "manual" -}}
{{- end -}}
{{- if and (ne "" .emailWork) (eq "" .openCodeWorkPlugin) -}}
{{-   warnf "opencode bedrock config skipped — openCodeWorkPlugin is empty. Run: chezmoi edit-config\n" -}}
{{- end -}}

{{ $config | toPrettyJson }}
