{{- /* chezmoi:modify-template */ -}}
{{- $base := fromJson (default "{}" .chezmoi.stdin) -}}

{{- /* Load MCP servers from template */ -}}
{{- $mcpServers := includeTemplate "mcp-servers-opencode-mcpproxy-json-tmpl" . | fromJson -}}

{{- /* Configure instructions to reference shared Claude rules and project rules directories */ -}}
{{- $instructions := list
      (printf "%s/.claude/rules/coding-system-prompts.md" .chezmoi.homeDir)
      "AGENTS.md"
      "CLAUDE.md"
      ".claude/rules/*.md"
      ".agents/rules/*.md"
-}}

{{- /* Build OpenCode config */ -}}
{{- $config := $base -}}
{{- $config = $config | setValueAtPath "mcp" $mcpServers -}}
{{- $config = $config | setValueAtPath "instructions" $instructions -}}

{{- /* Register plugins */ -}}
{{- $plugins := list "oh-my-openagent@latest" -}}
{{- if ne "" .openCodeWorkPlugin -}}
{{-   $plugins = prepend $plugins .openCodeWorkPlugin -}}
{{- end -}}
{{- $config = $config | setValueAtPath "plugin" $plugins -}}

{{- /* Set schema for editor validation */ -}}
{{- $config = $config | setValueAtPath "$schema" "https://opencode.ai/config.json" -}}

{{- /* Set OpenCode-specific defaults (only if not already set by OpenCode) */ -}}
{{- if not (hasKey $base "autoupdate") -}}
{{-   $config = $config | setValueAtPath "autoupdate" true -}}
{{- end -}}

{{- if ne "" .emailWork -}}
{{-   if eq "" .openCodeWorkPlugin -}}
{{-     fail "emailWork is set but openCodeWorkPlugin is empty — opencode bedrock config requires the llmproxy plugin. Run: chezmoi edit-config" -}}
{{-   end -}}
{{-   $config = $config | setValueAtPath "share" "disabled" -}}
{{-   $config = $config | setValueAtPath "enabled_providers" (list "amazon-bedrock" "google" "openai") -}}
{{-   $opusLimit := dict "limit" (dict "context" 200000 "output" 128000) -}}
{{-   $bedrockModels := dict
        "global.anthropic.claude-opus-4-7" $opusLimit -}}
{{-   $bedrockWhitelist := list
        "global.anthropic.claude-opus-4-7"
        "global.anthropic.claude-opus-4-6-v1"
        "global.anthropic.claude-opus-4-5-20251101-v1:0"
        "global.anthropic.claude-sonnet-4-6"
        "global.anthropic.claude-sonnet-4-5-20250929-v1:0"
        "global.anthropic.claude-sonnet-4-20250514-v1:0"
        "global.anthropic.claude-haiku-4-5-20251001-v1:0"
        "moonshotai.kimi-k2.5"
        "deepseek.v3.2"
        "qwen.qwen3-coder-next"
        "minimax.minimax-m2.5"
        "mistral.mistral-large-3-675b-instruct"
        "nvidia.nemotron-super-3-120b"
        "meta.llama4-scout-17b-instruct-v1:0"
        "mistral.magistral-small-2509" -}}
{{-   $config = $config | setValueAtPath "provider" (dict "amazon-bedrock" (dict "models" $bedrockModels "whitelist" $bedrockWhitelist)) -}}
{{- else if not (hasKey $base "share") -}}
{{-   $config = $config | setValueAtPath "share" "manual" -}}
{{- end -}}

{{ $config | toPrettyJson }}
