{{- /* chezmoi:modify-template */ -}}
{{- $base := fromJson (default "{}" .chezmoi.stdin) -}}

{{- /* Load MCP servers from template (unchanged) */ -}}
{{- $mcpServers := includeTemplate "mcp-servers-opencode-mcpproxy-json-tmpl" . | fromJson -}}

{{- /* Configure instructions to reference shared agent rules and project rules directories (unchanged) */ -}}
{{- $instructions := list
      (printf "%s/.agents/rules/coding-system-prompts.md" .chezmoi.homeDir)
      "AGENTS.md"
      "CLAUDE.md"
      ".claude/rules/*.md"
      ".agents/rules/*.md"
-}}

{{- /* Load profile — machineProfile gates which profile dict we use */ -}}
{{- $p := index .profiles (dig "machineProfile" "personal" .) -}}

{{- /* Build config from base, then overlay profile values */ -}}
{{- $config := $base -}}
{{- $config = $config | setValueAtPath "mcp" $mcpServers -}}
{{- $config = $config | setValueAtPath "instructions" $instructions -}}

{{- /* Register plugins: oh-my-openagent@latest + work plugin with local-path override (unchanged) */ -}}
{{- $plugins := list "oh-my-openagent@latest" -}}
{{- $workPlugin := .openCodeWorkPlugin -}}
{{- $localPath := dig "openCodeWorkPluginLocalPath" "" . -}}
{{- if ne "" $localPath -}}
{{-   $workPlugin = $localPath -}}
{{- end -}}
{{- if ne "" $workPlugin -}}
{{-   $plugins = prepend $plugins $workPlugin -}}
{{- end -}}
{{- $config = $config | setValueAtPath "plugin" $plugins -}}

{{- /* Set schema for editor validation (unchanged) */ -}}
{{- $config = $config | setValueAtPath "$schema" "https://opencode.ai/config.json" -}}

{{- /* Set autoupdate default only if not already set (unchanged) */ -}}
{{- if not (hasKey $base "autoupdate") -}}
{{-   $config = $config | setValueAtPath "autoupdate" false -}}
{{- end -}}

{{- /* Snapshot: disable on Coder boxes when profile snapshot is falsy */ -}}
{{- if and (ne "" (env "CODER")) (not (dig "snapshot" true $p)) -}}
{{-   $config = $config | setValueAtPath "snapshot" false -}}
{{- end -}}

{{- /* enabled_providers from profile (if non-empty) */ -}}
{{- $enabledProviders := dig "enabled_providers" nil $p -}}
{{- if ne nil $enabledProviders -}}
{{-   $config = $config | setValueAtPath "enabled_providers" $enabledProviders -}}
{{- end -}}

{{- /* provider block is authoritative from the profile: replace, don't merge,
     so a provider absent from the profile (e.g. a stale opencode entry carried
     in from a prior apply) is dropped rather than preserved. */ -}}
{{- $providerBlock := dig "provider_block" nil $p -}}
{{- if ne nil $providerBlock -}}
{{-   $config = $config | setValueAtPath "provider" $providerBlock -}}
{{- else -}}
{{-   $config = unset $config "provider" -}}
{{- end -}}

{{- /* Self-heal: drop retired per-model limit entries so re-applies don't
     leave orphaned caps (e.g. claude-sonnet-4-6 was superseded by 5). */ -}}
{{- if hasKey (dig "provider" (dict) $config) "amazon-bedrock" -}}
{{-   $bedrockModels := dig "provider" "amazon-bedrock" "models" (dict) $config -}}
{{-   $bedrockModels = unset $bedrockModels "global.anthropic.claude-sonnet-4-6" -}}
{{-   $config = $config | setValueAtPath "provider.amazon-bedrock.models" $bedrockModels -}}
{{- end -}}

{{- /* Inject the OpenCode API key into every opencode-family provider present
      in the profile's provider block, via the documented options.apiKey config
      path (https://opencode.ai/docs/providers). Go and Zen are DISTINCT
      providers in opencode's registry — `opencode-go` (subscription bundling,
      endpoint https://opencode.ai/zen/go/v1/...) and `opencode` (Zen per-token,
      endpoint https://opencode.ai/zen/v1/...) — but they share ONE account key
      (SKU-agnostic), fetched from BWS as bwsIdOpencodeApiKey.

      The provider's liveness check reads provider[<id>].options.apiKey
      (packages/opencode/src/provider/provider.ts); without a key it strips
      non-free models from autoload.

      We embed the literal key (fetched from BWS at render time) rather than
      {env:OPENCODE_API_KEY}: that env var is only exported in zsh shells
      (env.zsh.tmpl), so the pitchfork-managed `opencode serve` daemon and
      any bash-launched opencode would see an empty value and fall back to the
      "public" free-tier key. The key is already stored plaintext in
      auth.json (chezmoi-managed), so embedding it here is equivalent
      exposure. */ -}}
{{- if hasKey $config "provider" -}}
{{-   $bwsToken := "" -}}
{{-   if and (lookPath "bws") (stat .bwsTokenPath) -}}
{{-     $bwsToken = include .bwsTokenPath | trim -}}
{{-   end -}}
{{-   $bwsGet := joinPath .chezmoi.homeDir ".local/lib/bws-get-or-empty" -}}
{{-   $opencodeApiKey := "" -}}
{{-   $bwsIdOpencodeApiKey := dig "bwsIdOpencodeApiKey" "" . -}}
{{-   if and (ne "" $bwsToken) (ne "" $bwsIdOpencodeApiKey) (stat $bwsGet) -}}
{{-     $opencodeApiKey = output $bwsGet $bwsIdOpencodeApiKey .bwsTokenPath | trim -}}
{{-   end -}}
{{-   $opencodeFamily := list "opencode-go" "opencode" -}}
{{-   range $provId := $opencodeFamily -}}
{{-     if hasKey $config "provider" -}}
{{-       if hasKey (index $config "provider") $provId -}}
{{-         if ne "" $opencodeApiKey -}}
{{-           $config = $config | setValueAtPath (printf "provider.%s.options.apiKey" $provId) $opencodeApiKey -}}
{{-         else -}}
{{- /* Drop the provider when no key resolves. A keyless block makes opencode
      advertise the provider and its models, but every call fails auth. Keep
      enabled_providers in sync. */ -}}
{{-           $providers := index $config "provider" -}}
{{-           $providers = unset $providers $provId -}}
{{-           if eq 0 (len $providers) -}}
{{-             $config = unset $config "provider" -}}
{{-           else -}}
{{-             $config = $config | setValueAtPath "provider" $providers -}}
{{-           end -}}
{{-           if hasKey $config "enabled_providers" -}}
{{-             $ep := list -}}
{{-             range $eprov := (index $config "enabled_providers") -}}
{{-               if ne $eprov $provId -}}
{{-                 $ep = append $ep $eprov -}}
{{-               end -}}
{{-             end -}}
{{-             $config = $config | setValueAtPath "enabled_providers" $ep -}}
{{-           end -}}
{{-         end -}}
{{-       end -}}
{{-     end -}}
{{-   end -}}
{{- end -}}

{{- /* model: authoritative from the profile (matches small_model below).
      The previous `if not (hasKey $base "model")` guard prevented convergence
      — a stale model in the live config (e.g. opencode/... after a profile
      switch to opencode-go/...) survived every re-apply. */ -}}
{{- $model := dig "model" nil $p -}}
{{- if ne nil $model -}}
{{-   $config = $config | setValueAtPath "model" $model -}}
{{- end -}}

{{- /* small_model from profile (if non-null) */ -}}
{{- $smallModel := dig "small_model" nil $p -}}
{{- if ne nil $smallModel -}}
{{-   $config = $config | setValueAtPath "small_model" $smallModel -}}
{{- end -}}

{{- /* server: only if openCodeServer flag is true AND profile has a non-null
      server. The hostname/port match the pitchfork daemon bind: loopback +
      internal port when nginxProxy is on, 0.0.0.0 + external port when off. */ -}}
{{- if and (dig "openCodeServer" false .) (ne nil (dig "server" nil $p)) -}}
{{-   $ocHost := "0.0.0.0" -}}
{{-   $ocPort := .ports.opencode.external -}}
{{-   if dig "nginxProxy" false . -}}
{{-     $ocHost = "127.0.0.1" -}}
{{-     $ocPort = .ports.opencode.internal -}}
{{-   end -}}
{{-   $config = $config | setValueAtPath "server" (dict "hostname" $ocHost "port" $ocPort) -}}
{{- end -}}

{{- /* share from profile (only if base doesn't have it) */ -}}
{{- if not (hasKey $base "share") -}}
{{-   $share := dig "share" nil $p -}}
{{-   if ne nil $share -}}
{{-     $config = $config | setValueAtPath "share" $share -}}
{{-   end -}}
{{- end -}}

{{ $config | toPrettyJson }}
