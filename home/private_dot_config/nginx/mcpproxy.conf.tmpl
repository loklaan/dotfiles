{{- if and (eq .chezmoi.os "linux") (dig "nginxProxy" false .) (dig "mcpproxyGate" true .) -}}
# mcpproxy control panel: expose its loopback web UI on a port the
# exe.dev proxy can forward (3000-9999). WebSocket upgrade is passed through
# so the UI's live features work.
server {
    listen {{ .ports.mcpproxy.external }};
    listen [::]:{{ .ports.mcpproxy.external }};
    server_name _;

    location / {
        proxy_pass http://127.0.0.1:{{ .ports.mcpproxy.internal }};
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_read_timeout 600s;
    }
}
{{- end }}
