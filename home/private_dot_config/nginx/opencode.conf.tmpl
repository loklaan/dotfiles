{{- if and (eq .chezmoi.os "linux") (dig "nginxProxy" false .) (dig "openCodeServer" false .) -}}
server {
    listen {{ .ports.opencode.external }};
    listen [::]:{{ .ports.opencode.external }};
    server_name _;

    gzip on;
    gzip_vary on;
    gzip_proxied any;
    gzip_comp_level 6;
    gzip_types
        text/plain
        text/css
        text/xml
        text/javascript
        application/javascript
        application/xml+rss
        application/json
        font/woff2
        image/svg+xml;

    location / {
        proxy_pass http://127.0.0.1:{{ .ports.opencode.internal }};
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_read_timeout 600s;
        proxy_send_timeout 600s;
    }
}
{{- end }}
