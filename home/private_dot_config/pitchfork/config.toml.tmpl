{{- if and (eq .chezmoi.os "linux") (dig "orcaServer" false .) -}}
{{- /* CODER_WORKSPACE_NAME is the canonical workspace identifier on Coder
       boxes, set by the Coder agent in /run/coder/agent.conf. We extract it
       at chezmoi-render time so Pitchfork gets a baked-in pairing address — no
       runtime shell parsing, no risk of leaking sibling secrets from agent.conf
       (e.g. CODER_AGENT_TOKEN) into the orca process.

       LOAD-BEARING: the pairing address MUST be <workspace>.coder. Do NOT
       "simplify" this to $(hostname).coder — on a Coder box $(hostname) is the
       container/pod id, not the workspace name, so Coder Connect's <ws>.coder
       DNS would not resolve it and every paired client would fail to connect. */ -}}
{{- $agentConf := "" -}}
{{- if stat "/run/coder/agent.conf" -}}
{{-   $agentConf = include "/run/coder/agent.conf" -}}
{{- end -}}
{{- $workspaceName := $agentConf | regexFind `CODER_WORKSPACE_NAME="[^"]+"` | regexFind `[^"]+"$` | trimSuffix `"` -}}
{{- if eq "" $workspaceName -}}
{{-   fail "orcaServer = true but CODER_WORKSPACE_NAME could not be resolved from /run/coder/agent.conf" -}}
{{- end -}}
#:schema https://pitchfork.jdx.dev/schema.json

[daemons.df-orca-server]
run = "exec df-orca-serve --pairing-address {{ $workspaceName }}.coder --json"
dir = "{{ .chezmoi.homeDir }}"
env = { HOME = "{{ .chezmoi.homeDir }}", PATH = "{{ .chezmoi.homeDir }}/.local/bin:{{ .chezmoi.homeDir }}/.local/share/mise/shims:/usr/bin:/usr/local/bin:/bin" }
retry = true
boot_start = true
ready_delay = 2
{{- end }}

{{- if and (eq .chezmoi.os "linux") (dig "openCodeServer" false .) }}
[daemons.df-opencode-serve]
run = "exec opencode serve --hostname 0.0.0.0 --port 4096"
watch = ["{{ .chezmoi.homeDir }}/.config/opencode/opencode.json"]
dir = "{{ .chezmoi.homeDir }}"
env = { HOME = "{{ .chezmoi.homeDir }}", PATH = "{{ .chezmoi.homeDir }}/.local/bin:{{ .chezmoi.homeDir }}/.local/share/mise/shims:/usr/bin:/usr/local/bin:/bin" }
retry = true
boot_start = true
ready_delay = 2
{{- end }}

{{- if and (eq .chezmoi.os "linux") (dig "codeServer" false .) }}
[daemons.df-code-server]
run = "exec code-server --bind-addr 0.0.0.0:4444 --auth password"
watch = ["{{ .chezmoi.homeDir }}/.config/code-server/config.yaml"]
dir = "{{ .chezmoi.homeDir }}"
env = { HOME = "{{ .chezmoi.homeDir }}", PATH = "{{ .chezmoi.homeDir }}/.local/bin:{{ .chezmoi.homeDir }}/.local/share/mise/shims:/usr/bin:/usr/local/bin:/bin" }
retry = true
boot_start = true
ready_delay = 2
{{- end }}

{{- if and (eq .chezmoi.os "linux") (dig "mcpproxyGate" true .) }}
[daemons.df-mcpproxy]
run = "exec mcpproxy serve --log-level info"
watch = ["{{ .chezmoi.homeDir }}/.mcpproxy/mcp_config.json"]
dir = "{{ .chezmoi.homeDir }}"
env = { HOME = "{{ .chezmoi.homeDir }}", PATH = "{{ .chezmoi.homeDir }}/.local/bin:{{ .chezmoi.homeDir }}/.local/share/mise/shims:/usr/bin:/usr/local/bin:/bin" }
retry = true
boot_start = true
ready_delay = 2
{{- end }}
