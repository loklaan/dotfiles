[".config/opencode"]
    type = "archive"
    url = "https://github.com/IgorWarzocha/Opencode-Context-Analysis-Plugin/archive/3676b9f2.tar.gz"
    exact = false
    stripComponents = 2
    include = ["*/.opencode", "*/.opencode/**"]
    # Opencode auto-loads every file in plugin/, so .d.ts type declarations
    # crash plugin loading. Exclude them from the extracted archive.
    exclude = ["**/*.d.ts"]
