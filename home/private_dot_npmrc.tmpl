{{ if ne "" .npmWorkRegistry -}}
@canva:registry={{ .npmWorkRegistry }}
{{ else if ne "" .emailWork -}}
{{   fail "emailWork is set but npmWorkRegistry is empty — @canva scoped packages cannot be resolved. Run: chezmoi edit-config" }}
{{ end -}}
init-author-name=Lochlan Bunn
init-author-email=bunn@lochlan.io
init-version=0.1.0
init-license=MIT
{{- $bwsToken := "" -}}
{{- if and (lookPath "bws") (stat .bwsTokenPath) -}}
{{-   $bwsToken = include .bwsTokenPath | trim -}}
{{- end -}}
{{- $bwsGet := joinPath .chezmoi.homeDir ".local/lib/bws-get-or-empty" -}}
{{- $npmAuthToken := "" -}}
{{- if and (ne "" $bwsToken) (stat $bwsGet) -}}
{{-   $npmAuthToken = output $bwsGet .bwsIdNpmAuthToken .bwsTokenPath | trim -}}
{{- end -}}
{{- if ne "" $npmAuthToken }}
//registry.npmjs.org/:_authToken={{ $npmAuthToken }}
{{- end }}
